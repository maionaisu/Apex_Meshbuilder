# [Code Cell]
import os
import numpy as np
import matplotlib.pyplot as plt
from pyproj import CRS, Transformer
import geopandas as gpd
from shapely.geometry import Polygon, LineString

# Toleransi Import dfm_tools
try:
    import dfm_tools as dfmt
except ImportError:
    print("❌ [FATAL] Library 'dfm_tools' tidak ditemukan. Jalankan: pip install dfm_tools")
    dfmt = None

print("🕸️ [TAHAP 4] BASE MESH GENERATION & COASTLINE")

# =========================================================================
# [APEX NEXUS]: CRS STATE INJECTION
# =========================================================================
if 'target_epsg' not in globals():
    print("⚠️ [WARNING] 'target_epsg' tidak ditemukan di memori. Menggunakan default Jatim (32749).")
    target_epsg = "32749"

# =========================================================================
# [AUTO-SYNC & CLI INPUT]: MACRO & MICRO AOI
# =========================================================================
print("\n🌍 --- DOMAIN MAKRO (Batas Grid Kasar / ERA5) ---")
if all(k in globals() for k in ['lat_max', 'lat_min', 'lon_max', 'lon_min']):
    print("✅ [AUTO-SYNC] Bounding Box Makro terdeteksi dari memori Tahap 1 (ERA5).")
    mac_N = globals()['lat_max']
    mac_S = globals()['lat_min']
    mac_E = globals()['lon_max']
    mac_W = globals()['lon_min']
    print(f"   N: {mac_N:.4f}° | S: {mac_S:.4f}° | E: {mac_E:.4f}° | W: {mac_W:.4f}°")
else:
    print("⚠️ Data ERA5 tidak terdeteksi. Silakan masukkan batas Makro secara manual:")
    mac_N = float(input("North (Utara) [-8.0]: ") or -8.0)
    mac_S = float(input("South (Selatan) [-9.0]: ") or -9.0)
    mac_E = float(input("East (Timur) [113.0]: ") or 113.0)
    mac_W = float(input("West (Barat) [112.0]: ") or 112.0)

print("\n🎯 --- [INPUT] DOMAIN MIKRO (Area Fokus Detail) ---")
print("Catatan: Area ini akan divisualisasikan untuk acuan refinement di tahap selanjutnya.")
mic_N = float(input("North (Utara) [contoh: -8.428196]: ") or -8.428196)
mic_S = float(input("South (Selatan) [contoh: -8.457200]: ") or -8.457200)
mic_E = float(input("East (Timur) [contoh: 112.678100]: ") or 112.678100)
mic_W = float(input("West (Barat) [contoh: 112.659781]: ") or 112.659781)

print("\n🗺️ --- [INPUT] DATA VEKTOR & RESOLUSI ---")
ldb_raw = input("📂 Masukkan path Land Boundary (.shp/.gpkg) [Kosongkan/Enter jika tidak ada]: ").strip().strip('\'"').replace('"', '').replace("'", "")
ldb_path = ldb_raw if os.path.exists(ldb_raw) else ""

try:
    base_res_input = input("📐 Masukkan Resolusi Base Grid Makro (m) [1000]: ").strip()
    base_res = float(base_res_input) if base_res_input else 1000.0
except ValueError:
    print("⚠️ Input tidak valid. Menggunakan default resolusi 1000.0 m.")
    base_res = 1000.0

print(f"\n⏳ Mengonversi koordinat WGS84 ke UTM EPSG:{target_epsg} dan Membangun Metric Grid...")

try:
    # 1. Transformasi Geografis (WGS84) ke Metrik (UTM)
    tr_bounds = Transformer.from_crs("EPSG:4326", f"EPSG:{target_epsg}", always_xy=True)
    
    # Transformasi Domain Makro
    utm_mac_W, utm_mac_S = tr_bounds.transform(mac_W, mac_S)
    utm_mac_E, utm_mac_N = tr_bounds.transform(mac_E, mac_N)
    min_x, max_x = min(utm_mac_W, utm_mac_E), max(utm_mac_W, utm_mac_E)
    min_y, max_y = min(utm_mac_S, utm_mac_N), max(utm_mac_S, utm_mac_N)

    # Transformasi Domain Mikro (Fokus Area)
    utm_mic_W, utm_mic_S = tr_bounds.transform(mic_W, mic_S)
    utm_mic_E, utm_mic_N = tr_bounds.transform(mic_E, mic_N)
    
    # 2. Pembuatan Poligon Mikro untuk Visualisasi
    micro_poly = Polygon([
        (utm_mic_W, utm_mic_S), 
        (utm_mic_E, utm_mic_S), 
        (utm_mic_E, utm_mic_N), 
        (utm_mic_W, utm_mic_N)
    ])

    # 3. Membangun Base Grid Makro (Delft3D Flexible Mesh Tools)
    if dfmt is not None:
        mk = dfmt.make_basegrid(
            lon_min=min_x, lon_max=max_x, 
            lat_min=min_y, lat_max=max_y, 
            dx=base_res, dy=base_res, 
            crs=f"EPSG:{target_epsg}"
        )
    else:
        raise RuntimeError("dfm_tools tidak aktif. Pembuatan grid dibatalkan.")
    
    # 4. Penanganan Vektor Pesisir (Land Boundary)
    gdf_coast = None
    if ldb_path:
        print(f"📖 Memuat data garis pantai (Coastline) dari: {os.path.basename(ldb_path)}")
        gdf_coast = gpd.read_file(ldb_path)
        
        # Robust CRS Alignment
        if gdf_coast.crs is None:
            if gdf_coast.total_bounds[2] <= 180:
                gdf_coast = gdf_coast.set_crs(epsg=4326)
            else:
                gdf_coast = gdf_coast.set_crs(epsg=int(target_epsg))
                
        if gdf_coast.crs.to_epsg() != int(target_epsg):
            print(f"🔄 Menyelaraskan Proyeksi Vektor Pesisir ke EPSG:{target_epsg}...")
            gdf_coast = gdf_coast.to_crs(epsg=int(target_epsg))

        # Auto-Healer Topologi Shapefile
        if any(gdf_coast.geom_type.isin(['Point', 'MultiPoint'])):
            print("\n⚠️ [AUTO-HEALER AKTIF] Menjahit kumpulan titik pesisir menjadi Poligon/Garis...")
            coords = []
            for geom in gdf_coast.geometry:
                if geom is None: continue
                if geom.geom_type == 'Point':
                    coords.append((geom.x, geom.y))
                elif geom.geom_type == 'MultiPoint':
                    coords.extend([(pt.x, pt.y) for pt in geom.geoms])
            
            if len(coords) >= 3:
                stitched_poly = Polygon(coords)
                if not stitched_poly.is_valid:
                    stitched_poly = stitched_poly.buffer(0)
                gdf_coast = gpd.GeoDataFrame(geometry=[stitched_poly], crs=gdf_coast.crs)
            elif len(coords) == 2:
                gdf_coast = gpd.GeoDataFrame(geometry=[LineString(coords)], crs=gdf_coast.crs)

    # =========================================================================
    # [ENTERPRISE RENDERER]: MESHDATA & AOI OVERLAYS
    # =========================================================================
    try:
        plt.close('all') 
    except: pass
    
    fig, ax = plt.subplots(figsize=(12, 10))
    ax.set_aspect('equal')
    
    # Render Mesh Edges (Grid Makro)
    mk.mesh2d_get().plot_edges(ax, color='#94A3B8', linewidth=0.5, zorder=1, alpha=0.8)
    
    # Render Land Boundary
    if gdf_coast is not None:
        if any(gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])):
            gdf_coast.boundary.plot(ax=ax, color='#B91C1C', linewidth=2.0, zorder=3, label="Land Boundary")
            gdf_coast.plot(ax=ax, color='#FCA5A5', alpha=0.3, zorder=2)
        else:
            gdf_coast.plot(ax=ax, color='#B91C1C', linewidth=2.0, zorder=3, label="Coastline")
            
    # Render Micro AOI Bounding Box
    gpd.GeoSeries([micro_poly]).boundary.plot(
        ax=ax, color='#F59E0B', linewidth=2.5, linestyle='--', zorder=4, label="Micro AOI (Fokus Area)"
    )
    # Highlight area dalam Mikro AOI agar terlihat jelas
    gpd.GeoSeries([micro_poly]).plot(ax=ax, color='#FDE68A', alpha=0.4, zorder=2)
        
    ax.set_title(f"Arsitektur Jaring Spasial (Spatial Mesh Architecture)\nGrid Makro: {base_res}m | Proyeksi: EPSG:{target_epsg}", fontweight='bold', fontsize=15, pad=15)
    ax.set_xlabel(f"Easting (m)", fontsize=12)
    ax.set_ylabel(f"Northing (m)", fontsize=12)
    
    ax.grid(True, linestyle=':', alpha=0.6, color='gray')
    
    # Custom Legend Handling
    import matplotlib.lines as mlines
    legend_elements = [
        mlines.Line2D([], [], color='#94A3B8', linewidth=1, label=f'Base Mesh ({base_res}m)'),
        mlines.Line2D([], [], color='#F59E0B', linewidth=2.5, linestyle='--', label='Micro AOI (Refinement Zone)')
    ]
    if gdf_coast is not None:
        legend_elements.insert(1, mlines.Line2D([], [], color='#B91C1C', linewidth=2, label='Land Boundary'))
        
    ax.legend(handles=legend_elements, loc='upper right', framealpha=0.9, edgecolor='black', fontsize=11)
        
    plt.tight_layout()
    plt.show()
    print("✅ Base grid dan Domain Spasial berhasil disinkronisasi.")

    # Menyimpan polygon mikro ke globals agar dapat diakses sel selanjutnya (Tahap 5)
    globals()['micro_poly_utm'] = micro_poly

except Exception as e:
    print(f"\n❌ [FATAL ERROR] Proses Base Grid gagal!")
    print(f"Detail Kegagalan: {e}")

# [Code Cell]
print("🌊 [TAHAP 1] EKSTRAKSI METOCEAN ERA5")

# Bulletproof path input loop
while True:
    era5_path = input("📂 Masukkan path file ERA5 (.nc): ").strip().strip('\'"').replace('"', '').replace("'", "")
    if os.path.exists(era5_path):
        break
    print(f"❌ File tidak ditemukan di: {os.path.abspath(era5_path)}\nPastikan path benar dan coba lagi.")

try:
    with xr.open_dataset(era5_path) as ds:
        # Spatial variables auto-detect
        lat_var = 'latitude' if 'latitude' in ds else 'lat'
        lon_var = 'longitude' if 'longitude' in ds else 'lon'
        
        if lat_var not in ds or lon_var not in ds:
            raise KeyError("Dimensi lat/lon tidak ditemukan pada file NetCDF.")
            
        # Bounding Box Extraction
        lat_min, lat_max = float(ds[lat_var].min()), float(ds[lat_var].max())
        lon_min, lon_max = float(ds[lon_var].min()), float(ds[lon_var].max())
        
        print(f"\n🗺️ [MACRO BBOX DITEMUKAN]")
        print(f"   Utara (N): {lat_max:.4f}°  |  Selatan (S): {lat_min:.4f}°")
        print(f"   Timur (E): {lon_max:.4f}°   |  Barat (W) : {lon_min:.4f}°")
        
        # Wave Parameters auto-detect
        var_hs = next((v for v in ['swh', 'shww', 'hs'] if v in ds), None)
        var_tp = next((v for v in ['pp1d', 'mwp', 'tp'] if v in ds), None)
        var_dir = next((v for v in ['mwd', 'dir'] if v in ds), None)
        
        Hs_val = float(ds[var_hs].max(skipna=True)) if var_hs else 1.5
        Tp_val = float(ds[var_tp].mean(skipna=True)) if var_tp else 8.0
        Dir_val = float(ds[var_dir].mean(skipna=True)) if var_dir else 180.0
        
        print(f"\n🌊 [KONDISI GELOMBANG EKSTREM]")
        print(f"   Significant Height (Hs_Max): {Hs_val:.2f} m")
        print(f"   Peak Period (Tp_Mean)      : {Tp_val:.2f} s")
        print(f"   Wave Direction (Dir_Mean)  : {Dir_val:.2f}°")

except Exception as e:
    print(f"❌ Proses data ERA5 gagal: {e}")

# [Code Cell]
import numpy as np
import matplotlib.pyplot as plt
import geopandas as gpd
import xarray as xr
import pandas as pd
import os
from pyproj import Transformer
from scipy.stats import binned_statistic_2d
import scipy.ndimage as ndimage

try:
    import dfm_tools as dfmt
    import xugrid as xu
    from meshkernel import GeometryList, OrthogonalizationParameters, ProjectToLandBoundaryOption
except ImportError:
    print("❌ [FATAL] Library 'dfm_tools', 'xugrid', atau 'meshkernel' tidak ditemukan.")
    dfmt = None
    xu = None

print("📐 [TAHAP 6] SANITY CHECK, KUALITAS MESH & FINAL INJECTION")

# =========================================================================
# STATE VALIDATION
# =========================================================================
if 'mk' not in globals() or mk.mesh2d_get().node_x.size == 0:
    print("❌ [FATAL ERROR] MeshKernel (mk) tidak ditemukan di memori atau kosong.")
    raise RuntimeError("Jalankan Tahap 4 dan 5 terlebih dahulu.")

crs_str = f"EPSG:{target_epsg}" if 'target_epsg' in globals() else "EPSG:32749"

# =========================================================================
# PHASE 1: PASSIVE ORTHOGONALITY AUDIT (NO AUTO-FIX)
# =========================================================================
def get_clean_ortho(mk_obj):
    raw = mk_obj.mesh2d_get_orthogonality().values
    return raw[(~np.isnan(raw)) & (raw != -999.0)]

vals_before = get_clean_ortho(mk)

# Ortogonalitas Delft3D: 0.0 = Sempurna, > 0.1 = Bahaya
max_o, avg_o = np.max(vals_before), np.mean(vals_before)
print(f"\n📊 [AUDIT KUALITAS AWAL] Deviasi Terburuk (Max): {max_o:.4f} | Rata-rata: {avg_o:.4f}")

if max_o > 0.1:
    print("⚠️ [INFO] Ditemukan sel dengan deviasi tinggi (> 0.1).")
    print("   ├ Hal ini NORMAL terjadi pada sel yang tertebas oleh garis pantai (Coastline).")
    print("   ├ Tindakan: Bypass penjahit otomatis C++ untuk mencegah Memory Access Violation.")
    print("   ├ Catatan : Jika terjadi model crash saat simulasi, rapikan sel pesisir manual di RGFGRID.")
else:
    print("✅ Jaring luar biasa stabil (Deviasi Maksimal < 0.1).")

vals_after = vals_before # Kita tidak mengubah topologi lagi di tahap ini (bypass C++ crash)

# =========================================================================
# PHASE 2: RAM-SAFE BATHYMETRY RECOVERY
# =========================================================================
print("\n⏳ [AUTO-RECOVERY] Mengamankan matriks Batimetri untuk interpolasi akhir...")
bathy_path_mem = globals().get('bathy_path', '')
if not bathy_path_mem or not os.path.exists(bathy_path_mem):
    bathy_path_mem = input("📂 Masukkan kembali path file Batimetri (.xyz): ").strip().strip('\'"').replace('"', '').replace("'", "")

with open(bathy_path_mem, 'r', encoding='utf-8', errors='ignore') as f:
    df_bathy = pd.read_csv(f, delim_whitespace=True, header=None, names=['x','y','z'], dtype=np.float32)

is_wgs84 = df_bathy['x'].abs().max() <= 180 and df_bathy['y'].abs().max() <= 90
if is_wgs84:
    print(f"🔄 Mengonversi ulang WGS84 ke UTM {crs_str} via Chunking...")
    tr = Transformer.from_crs("EPSG:4326", crs_str, always_xy=True)
    x_vals, y_vals = df_bathy['x'].values, df_bathy['y'].values
    for i in range(0, len(x_vals), 5_000_000):
        end_idx = min(i + 5_000_000, len(x_vals))
        tx, ty = tr.transform(x_vals[i:end_idx], y_vals[i:end_idx])
        x_vals[i:end_idx], y_vals[i:end_idx] = tx, ty

# Membangun Xarray DataArray
print("⏳ Membangun Peta Raster (O(N) Binning) untuk interpolasi node...")
target_res = globals().get('target_res', 20.0)
gx = np.arange(df_bathy['x'].min(), df_bathy['x'].max(), target_res / 2.0)
gy = np.arange(df_bathy['y'].min(), df_bathy['y'].max(), target_res / 2.0)

x_vals, y_vals, z_vals = df_bathy['x'].values, df_bathy['y'].values, df_bathy['z'].values
del df_bathy; import gc; gc.collect()

count = np.zeros((len(gx)-1, len(gy)-1), dtype=np.float32)
z_sum = np.zeros((len(gx)-1, len(gy)-1), dtype=np.float32)
for i in range(0, len(x_vals), 5_000_000):
    end_idx = min(i + 5_000_000, len(x_vals))
    c_chunk, _, _ = np.histogram2d(x_vals[i:end_idx], y_vals[i:end_idx], bins=[gx, gy])
    z_chunk, _, _ = np.histogram2d(x_vals[i:end_idx], y_vals[i:end_idx], bins=[gx, gy], weights=z_vals[i:end_idx])
    count += c_chunk; z_sum += z_chunk

del x_vals, y_vals, z_vals; gc.collect()

with np.errstate(divide='ignore', invalid='ignore'):
    grid_z_raw = np.true_divide(z_sum, count)
    grid_z_raw[count == 0] = np.nan
    
grid_z = grid_z_raw.T 
mask = np.isnan(grid_z)
if mask.any():
    ind = ndimage.distance_transform_edt(mask, return_distances=False, return_indices=True)
    grid_z = grid_z[tuple(ind)]

data_bathy_macro = xr.DataArray(
    data=grid_z, 
    coords={"lat": gy[:-1] + np.diff(gy)/2, "lon": gx[:-1] + np.diff(gx)/2}, 
    dims=("lat", "lon")
)

# =========================================================================
# PHASE 3: INTERPOLASI FINAL & UGRID EXPORT
# =========================================================================
print("\n💾 [PHASE 3] INTERPOLASI KEDALAMAN & UGRID EXPORT")
xu_grid_uds = dfmt.meshkernel_to_UgridDataset(mk=mk, crs=crs_str)

print(f"⏳ Menginterpolasi Batimetri ke {xu_grid_uds.obj.mesh2d_node_x.size:,} Node Jaring...")
data_bathy_interp = data_bathy_macro.interp(lon=xu_grid_uds.obj.mesh2d_node_x, lat=xu_grid_uds.obj.mesh2d_node_y)

# Menggali nilai absolut untuk kalkulasi dinamik batas warna plot
valid_z = data_bathy_interp.values[~np.isnan(data_bathy_interp.values)]
if len(valid_z) > 0:
    dynamic_vmin = np.percentile(valid_z, 1)  # 1% nilai terdalam
    dynamic_vmax = np.percentile(valid_z, 99) # 99% nilai terdangkal
else:
    dynamic_vmin, dynamic_vmax = -50.0, 5.0

# Clip dan FillNaN untuk simulasi stabilitas
xu_grid_uds['mesh2d_node_z'] = data_bathy_interp.clip(max=10)
xu_grid_uds['mesh2d_node_z'] = xu_grid_uds['mesh2d_node_z'].fillna(dynamic_vmin)
xu_grid_uds.obj.mesh2d_node_z.encoding["_FillValue"] = 1e20

out_nc = os.path.join(os.getcwd(), "Apex_Final_Model_Mesh.nc")
tmp_nc = out_nc + ".tmp"

print("⏳ Menulis UGRID NetCDF secara Atomic...")
xu_grid_uds.ugrid.to_netcdf(tmp_nc)
if os.path.exists(out_nc):
    try: os.remove(out_nc)
    except: pass
os.replace(tmp_nc, out_nc)
print(f"✅ [SUCCESS] File arsitektur XUGrid diamankan ke: {out_nc}")

# =========================================================================
# PHASE 4: VISUALISASI MAHAKARYA & DIAGNOSTIK (SCIENTIFIC STANDARD)
# =========================================================================
try:
    plt.close('all')
    fig = plt.figure(figsize=(18, 8), dpi=150)
    
    # --- Plot 1: Diagnostik Ortogonalitas ---
    ax1 = plt.subplot(1, 2, 1)
    ax1.hist(vals_before, bins=50, alpha=0.5, color='#EF4444', label='Sebelum Diperbaiki (Raw)')
    if max_o > 0.1:
        # Karena C++ crash pada mesh terpotong, kita menampilkan kondisi existing
        # dengan transparansi penuh untuk menandakan bypass C++
        ax1.hist(vals_after, bins=50, alpha=0.7, color='#10B981', label='Kondisi Final (Bypass C++)')
    else:
        ax1.hist(vals_after, bins=50, alpha=0.7, color='#10B981', label='Kondisi Final (Sempurna)')
        
    ax1.axvline(0.1, color='black', linestyle='dashed', linewidth=2, label='Batas Rawan (0.10)')
    ax1.set_title("Distribusi Histografik Ortogonalitas Mesh", fontweight='bold', fontsize=13)
    ax1.set_xlabel("Nilai Ortogonalitas (0.0 = Sempurna)")
    ax1.set_ylabel("Jumlah Sel")
    ax1.legend()
    ax1.grid(True, linestyle=':', alpha=0.6, color='gray')

    # --- Plot 2: Final UGRID Rendering ---
    ax2 = plt.subplot(1, 2, 2)
    ax2.set_aspect('equal', adjustable='datalim')

    # [ENTERPRISE FIX]: Menggunakan cmap='viridis' (Tanpa _r)
    # Laut Dalam (Negatif) = Ungu/Biru Gelap | Dangkal/Darat (Positif) = Hijau/Kuning Terang
    # Menggunakan dynamic_vmin dan dynamic_vmax berdasarkan distribusi data batimetri asli
    plot_obj = xu_grid_uds.mesh2d_node_z.ugrid.plot(
        ax=ax2, cmap='viridis', vmin=dynamic_vmin, vmax=dynamic_vmax, add_colorbar=False, zorder=1
    )
    
    # Overlay Mesh Wireframe transparan dengan warna netral
    xu_grid_uds.grid.plot(ax=ax2, linewidth=0.2, color='#94A3B8', alpha=0.6, zorder=2)

    if 'gdf_coast' in globals() and gdf_coast is not None:
        if any(gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])):
            gdf_coast.boundary.plot(ax=ax2, color='#B91C1C', linewidth=1.5, zorder=3, label="Garis Pesisir (Pulau/Darat)")
        else:
            gdf_coast.plot(ax=ax2, color='#B91C1C', linewidth=1.5, zorder=3, label="Garis Pesisir (Pulau/Darat)")
            
    # Hiasan Legenda dan Metadata
    cbar = plt.colorbar(plot_obj, ax=ax2, label='Kedalaman Dasar (meter MSL)', fraction=0.046, pad=0.04)
    cbar.ax.tick_params(labelsize=10)
    
    ax2.set_title("Apex Digital Twin Mesh Architecture\nAbsolute Bathymetry Interpolation", fontweight='bold', fontsize=14, pad=15)
    ax2.set_xlabel(f"Easting ({crs_str})", fontsize=12)
    ax2.set_ylabel("Northing", fontsize=12)
    
    ax2.grid(True, linestyle=':', alpha=0.6, color='gray')
    if 'gdf_coast' in globals() and gdf_coast is not None:
        ax2.legend(loc='upper right', framealpha=0.9, edgecolor='black')

    plt.tight_layout()
    plt.show()

    print("="*60)
    print("🚀 SELURUH PIPELINE SPASIAL OSEANOGRAFI SELESAI DENGAN SEMPURNA!")
    print("============================================================")

except Exception as e:
    print(f"⚠️ [WARNING] Proses render plot visual mengalami kendala: {e}")

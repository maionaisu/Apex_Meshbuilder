# [Code Cell 7] - LANDWARD CLIPPING, DUAL NETCDF EXPORT & DIAGNOSTICS
import os
import gc
import numpy as np
import pandas as pd
import xarray as xr
import geopandas as gpd
import matplotlib.pyplot as plt
import scipy.ndimage as ndimage
from shapely.geometry import Polygon, LineString
from pyproj import Transformer
import dfm_tools as dfmt
from meshkernel import GeometryList, DeleteMeshOption

print("📐 [TAHAP 7] SANITY CHECK, CLIPPING & FINAL INJECTION")

# =========================================================================
# STATE VALIDATION
# =========================================================================
if 'mk' not in globals() or mk.mesh2d_get().node_x.size == 0:
    print("❌ [FATAL ERROR] MeshKernel (mk) tidak ditemukan di memori atau kosong.")
    raise RuntimeError("Jalankan Tahap 4, 5, dan 6 terlebih dahulu.")

crs_str = f"EPSG:{globals().get('target_epsg', '32749')}"
target_res = globals().get('target_res', 20.0)
gdf_coast = globals().get('gdf_coast')

def get_clean_ortho(mk_obj):
    raw = mk_obj.mesh2d_get_orthogonality().values
    return raw[(~np.isnan(raw)) & (raw != -999.0)]

# =========================================================================
# PHASE 1: PRE-CLIP ORTHOGONALITY CAPTURE & CLI CLIPPING LOGIC
# =========================================================================
print("\n📊 Mengambil Snapshot Ortogonalitas (Pre-Clip)...")
vals_before = get_clean_ortho(mk)
max_o, avg_o = np.max(vals_before), np.mean(vals_before)
print(f"   ├ Deviasi Terburuk (Max): {max_o:.4f} | Rata-rata: {avg_o:.4f}")

print("\n✂️ [PHASE 1] Eksekusi Landward Clipping (Custom Boundary)...")
print("   [PILIHAN MODE PEMOTONGAN DARATAN]")
print("   [1] Conservative (Default) : Mempertahankan sel air yang berpotongan (Overlap murni ke darat).")
print("   [2] Aggressive             : Menghapus mutlak seluruh sel yang bersentuhan dengan darat (Tanpa Overlap).")
clip_mode = input("   Pilih mode pemotongan [1/2]: ").strip()

buffer_tol_m = 0.0
if clip_mode == '2':
    delete_opt_val = DeleteMeshOption.INSIDE_AND_INTERSECTED if hasattr(DeleteMeshOption, 'INSIDE_AND_INTERSECTED') else 1
    print("   -> Mode AGGRESSIVE diaktifkan. Jaring akan lebih rapi di area laut.")
    tol_input = input("   Berapa meter toleransi overlap jaring ke darat? (contoh: 5.0) [0.0]: ").strip()
    if tol_input:
        try:
            buffer_tol_m = -abs(float(tol_input))
            print(f"   -> Toleransi {abs(buffer_tol_m)}m diaplikasikan ke mesin pemotong C++.")
        except ValueError:
            print("   -> Input tidak valid. Toleransi diatur ke 0.0m.")
else:
    delete_opt_val = DeleteMeshOption.INSIDE_NOT_INTERSECTED if hasattr(DeleteMeshOption, 'INSIDE_NOT_INTERSECTED') else 0
    print("   -> Mode CONSERVATIVE diaktifkan. Mengutamakan preservasi volume laut.")

clipped_success = False

if gdf_coast is not None and not gdf_coast.empty:
    print("⏳ Memotong grid menggunakan batas vektor (gdf_coast)...")
    try:
        poly_count = 0
        islands_saved = 0
        
        def extract_rings(geom):
            coords_list = []
            if geom.geom_type == 'Polygon':
                coords_list.append(list(geom.exterior.coords))
            elif geom.geom_type == 'MultiPolygon':
                for p in geom.geoms:
                    coords_list.append(list(p.exterior.coords))
            return coords_list

        raw_polygons = []
        for geom in gdf_coast.geometry:
            if geom is None or geom.is_empty: continue
            if geom.geom_type == 'Polygon':
                raw_polygons.append(geom)
            elif geom.geom_type == 'MultiPolygon':
                raw_polygons.extend(list(geom.geoms))
            elif geom.geom_type in ['LineString', 'MultiLineString']:
                lines = [geom] if geom.geom_type == 'LineString' else list(geom.geoms)
                for line in lines:
                    if len(line.coords) >= 3:
                        try:
                            p = Polygon(line.coords)
                            raw_polygons.append(p if p.is_valid else p.buffer(0))
                        except: pass

        for poly in raw_polygons:
            pisau_potong = poly
            
            # [ENTERPRISE FIX]: Scale-Aware Island Preservation
            if buffer_tol_m != 0.0:
                try:
                    pisau_coba = poly.buffer(buffer_tol_m)
                    if pisau_coba.is_empty:
                        pisau_potong = poly
                        islands_saved += 1
                    else:
                        pisau_potong = pisau_coba
                except: pass
            
            rings = extract_rings(pisau_potong)
            
            for ring in rings:
                if len(ring) < 3: continue
                x, y = zip(*ring)
                x, y = list(x), list(y)
                    
                if x[0] != x[-1] or y[0] != y[-1]:
                    x.append(x[0])
                    y.append(y[0])
                
                land_geom = GeometryList(np.array(x, dtype=np.double), np.array(y, dtype=np.double))
                mk.mesh2d_delete(geometry_list=land_geom, delete_option=delete_opt_val, invert_deletion=False)
                poly_count += 1
        
        if poly_count > 0:
            print(f"✅ Pemotongan presisi berhasil dieksekusi ({poly_count} poligon/pulau diproses).")
            if islands_saved > 0:
                print(f"   🛡️ [AUTO-HEALER] {islands_saved} pulau kecil berhasil diselamatkan dari kepunahan toleransi buffer.")
            clipped_success = True
        else:
            print("⚠️ Tidak ada poligon valid yang ditemukan untuk dipotong.")
            
    except Exception as e:
        print(f"⚠️ Potong manual gagal: {e}. Mengeksekusi Auto fallback...")

if not clipped_success:
    print("⏳ Mengeksekusi GSHHS auto-coastline clipping sebagai fallback...")
    try:
        dfmt.meshkernel_delete_withcoastlines(mk=mk, res='f')
        print("✅ Pemotongan GSHHS berhasil.")
    except Exception as e:
        print(f"⚠️ GSHHS Clip failed: {e}")

# [ENTERPRISE FIX]: Membersihkan "Hanging Nodes" akibat pemotongan kasar
print("\n🔍 Membersihkan residu sel terlipat paska pemotongan batas darat...")
try:
    illegal_gdf = dfmt.meshkernel_get_illegalcells(mk=mk)
    if not illegal_gdf.empty:
        for idx in illegal_gdf.index:
            try: mk.mesh2d_delete_face(idx)
            except: pass
        print(f"✅ {len(illegal_gdf)} sel boundary cacat berhasil diamankan.")
except: pass

print("\n📊 Mengambil Snapshot Ortogonalitas (Post-Clip)...")
vals_after = get_clean_ortho(mk)

# =========================================================================
# PHASE 2: EXPORT 1 - CLIPPED MESH (NO BATHYMETRY)
# =========================================================================
print("\n💾 [PHASE 2] EXPORT CLIPPED MESH (NO BATHYMETRY)")
xu_grid_no_bathy = dfmt.meshkernel_to_UgridDataset(mk=mk, crs=crs_str)
out_no_bathy = os.path.join(os.getcwd(), "Apex_Clipped_NoBathy_net.nc")
tmp_no_bathy = out_no_bathy + ".tmp"
xu_grid_no_bathy.ugrid.to_netcdf(tmp_no_bathy)
if os.path.exists(out_no_bathy):
    try: os.remove(out_no_bathy)
    except: pass
os.replace(tmp_no_bathy, out_no_bathy)
print(f"✅ [SUCCESS] File arsitektur MURNI (Tanpa Batimetri) diamankan ke: {out_no_bathy}")

# =========================================================================
# PHASE 3: RAM-SAFE MACRO BATHYMETRY RECOVERY (FULL DOMAIN)
# =========================================================================
print("\n⏳ [PHASE 3] Membangun Peta Raster Full Domain (O(N) RAM-Safe Binning)...")
bathy_path = globals().get('bathy_path', '')
if not bathy_path or not os.path.exists(bathy_path):
    bathy_path = input("📂 Masukkan kembali path file Batimetri (.xyz): ").strip().strip('\'"').replace('"', '')

mesh_geom = mk.mesh2d_get()
min_x, max_x = np.min(mesh_geom.node_x), np.max(mesh_geom.node_x)
min_y, max_y = np.min(mesh_geom.node_y), np.max(mesh_geom.node_y)

grid_spacing = target_res / 2.0  
gx = np.arange(min_x, max_x + grid_spacing, grid_spacing)
gy = np.arange(min_y, max_y + grid_spacing, grid_spacing)

count = np.zeros((len(gx)-1, len(gy)-1), dtype=np.float32)
z_sum = np.zeros((len(gx)-1, len(gy)-1), dtype=np.float32)

tr = Transformer.from_crs("EPSG:4326", crs_str, always_xy=True)
chunk_size = 5_000_000
is_wgs84 = None

for chunk_idx, chunk in enumerate(pd.read_csv(bathy_path, delim_whitespace=True, header=None, names=['x','y','z'], dtype=np.float32, chunksize=chunk_size)):
    if is_wgs84 is None:
        is_wgs84 = chunk['x'].abs().max() <= 180 and chunk['y'].abs().max() <= 90
            
    if is_wgs84:
        tx, ty = tr.transform(chunk['x'].values, chunk['y'].values)
    else:
        tx, ty = chunk['x'].values, chunk['y'].values
        
    tz = chunk['z'].values
    
    valid_mask = (tx >= min_x) & (tx <= max_x) & (ty >= min_y) & (ty <= max_y)
    tx, ty, tz = tx[valid_mask], ty[valid_mask], tz[valid_mask]
    
    if len(tx) > 0:
        c_chunk, _, _ = np.histogram2d(tx, ty, bins=[gx, gy])
        z_chunk, _, _ = np.histogram2d(tx, ty, bins=[gx, gy], weights=tz)
        count += c_chunk
        z_sum += z_chunk
    print(f"   │  └ Memproses blok ke-{chunk_idx+1} ({len(chunk):,} baris dievaluasi)...")
    
gc.collect()

with np.errstate(divide='ignore', invalid='ignore'):
    grid_z_raw = np.true_divide(z_sum, count)
    grid_z_raw[count == 0] = np.nan
    
grid_z = grid_z_raw.T 
mask = np.isnan(grid_z)
if mask.any():
    ind = ndimage.distance_transform_edt(mask, return_distances=False, return_indices=True)
    grid_z = grid_z[tuple(ind)]

gx_mid, gy_mid = gx[:-1] + np.diff(gx)/2, gy[:-1] + np.diff(gy)/2
data_bathy_macro_full = xr.DataArray(data=grid_z, coords={"lat": gy_mid, "lon": gx_mid}, dims=("lat", "lon"))

# =========================================================================
# PHASE 4: EXPORT 2 - INTERPOLASI FINAL & UGRID MESH
# =========================================================================
print("\n💾 [PHASE 4] DUAL-PASS INTERPOLASI KEDALAMAN & UGRID EXPORT")
xu_grid_uds = dfmt.meshkernel_to_UgridDataset(mk=mk, crs=crs_str)

print(f"⏳ Menginterpolasi Batimetri ke {xu_grid_uds.obj.mesh2d_node_x.size:,} Node Jaring Digital Twin...")

# [ENTERPRISE FIX]: Dual-Pass Interpolation Algorithm
interp_linear = data_bathy_macro_full.interp(lon=xu_grid_uds.obj.mesh2d_node_x, lat=xu_grid_uds.obj.mesh2d_node_y, method='linear')
interp_nearest = data_bathy_macro_full.interp(lon=xu_grid_uds.obj.mesh2d_node_x, lat=xu_grid_uds.obj.mesh2d_node_y, method='nearest')
data_bathy_interp = interp_linear.fillna(interp_nearest)

valid_z = data_bathy_interp.values[~np.isnan(data_bathy_interp.values)]
if len(valid_z) > 0:
    dynamic_vmin = np.percentile(valid_z, 1)  
    dynamic_vmax = np.percentile(valid_z, 99) 
else:
    dynamic_vmin, dynamic_vmax = -50.0, 5.0

xu_grid_uds['mesh2d_node_z'] = data_bathy_interp.clip(max=10)
xu_grid_uds['mesh2d_node_z'] = xu_grid_uds['mesh2d_node_z'].fillna(dynamic_vmin)
xu_grid_uds.obj.mesh2d_node_z.encoding["_FillValue"] = 1e20

out_mesh = os.path.join(os.getcwd(), "Apex_Final_Model_Mesh.nc")
tmp_mesh = out_mesh + ".tmp"

xu_grid_uds.ugrid.to_netcdf(tmp_mesh)
if os.path.exists(out_mesh):
    try: os.remove(out_mesh)
    except: pass
os.replace(tmp_mesh, out_mesh)
print(f"✅ [SUCCESS] File Model Utama (Dengan Batimetri) diamankan ke: {out_mesh}")

# =========================================================================
# PHASE 5: VISUALISASI MAHAKARYA & DIAGNOSTIK (SCIENTIFIC STANDARD)
# =========================================================================
print("\n🎨 [PHASE 5] Merender Scientific Diagnostic Overlay...")
try:
    plt.close('all')
    fig = plt.figure(figsize=(18, 8), dpi=150)
    
    # --- Plot 1: Diagnostik Ortogonalitas ---
    ax1 = plt.subplot(1, 2, 1)
    ax1.hist(vals_before, bins=50, alpha=0.5, color='#3B82F6', label='Pre-Clip (Relaxed Mesh)')
    ax1.hist(vals_after, bins=50, alpha=0.7, color='#10B981', label='Post-Clip (Final Boundary)')
        
    ax1.axvline(0.1, color='black', linestyle='dashed', linewidth=2, label='Batas Rawan D-Flow FM (0.10)')
    ax1.set_title("Distribusi Histografik Ortogonalitas Mesh", fontweight='bold', fontsize=12)
    ax1.set_xlabel("Nilai Ortogonalitas (0.0 = Sempurna)")
    ax1.set_ylabel("Jumlah Sel")
    ax1.legend()
    ax1.grid(True, linestyle=':', alpha=0.6, color='gray')

    # --- Plot 2: Final UGRID Rendering ---
    ax2 = plt.subplot(1, 2, 2)
    ax2.set_aspect('equal')

    plot_obj = xu_grid_uds.mesh2d_node_z.ugrid.plot(
        ax=ax2, cmap='viridis', vmin=dynamic_vmin, vmax=dynamic_vmax, add_colorbar=False, zorder=1
    )
    
    xu_grid_uds.grid.plot(ax=ax2, linewidth=0.1, color='#94A3B8', alpha=0.4, zorder=2)

    if gdf_coast is not None:
        if any(gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])):
            gdf_coast.boundary.plot(ax=ax2, color='#B91C1C', linewidth=1.5, zorder=3, label="Garis Pesisir (Daratan)")
        else:
            gdf_coast.plot(ax=ax2, color='#B91C1C', linewidth=1.5, zorder=3, label="Garis Pesisir (Daratan)")
            
    cbar = plt.colorbar(plot_obj, ax=ax2, label='Kedalaman Dasar (meter MSL)', fraction=0.046, pad=0.04)
    cbar.ax.tick_params(labelsize=10)
    
    ax2.set_title("Interpolated Bathymetry to Mesh Nodes", fontweight='bold', fontsize=12, pad=15)
    ax2.set_xlabel(f"Easting ({crs_str})", fontsize=12)
    ax2.set_ylabel("Northing", fontsize=12)
    
    ax2.grid(True, linestyle=':', alpha=0.6, color='gray')
    if gdf_coast is not None:
        ax2.legend(loc='upper right', framealpha=0.9, edgecolor='black')

    plt.tight_layout()
    plt.show()

    print("="*60)
    print("🚀 SELURUH PIPELINE SPASIAL OSEANOGRAFI SELESAI DENGAN SEMPURNA!")
    print("============================================================")

except Exception as e:
    print(f"⚠️ [WARNING] Proses render plot visual mengalami kendala: {e}")

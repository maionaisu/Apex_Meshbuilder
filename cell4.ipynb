# [Code Cell]
from pyproj import CRS, Transformer
import pandas as pd
import numpy as np
import os
import matplotlib.pyplot as plt

print("⛰️ [TAHAP 3] DEPTH OF CLOSURE & HIGH-DENSITY BATHYMETRY")

# 1. Bulletproof path input loop
while True:
    bathy_path = input("📂 Masukkan path file Batimetri (.xyz): ").strip().strip('\'"').replace('"', '').replace("'", "")
    if os.path.exists(bathy_path):
        if bathy_path.lower().endswith('.nc'):
            print("❌ FORMAT SALAH: Anda memasukkan file NetCDF (.nc). Batimetri harus berupa file teks murni (.xyz / .csv).")
            continue
        break
    print(f"❌ File tidak ditemukan di: {os.path.abspath(bathy_path)}\nCoba lagi.")

# 2. [ENTERPRISE FIX]: Anti-Typo & Validation untuk EPSG Code
while True:
    target_epsg = input("🌐 Masukkan Target UTM EPSG (contoh: 32749 untuk Jatim/Malang): ").strip()
    try:
        crs_test = CRS.from_string(f"EPSG:{target_epsg}")
        print(f"✅ Sistem Proyeksi Valid: {crs_test.name}")
        break
    except Exception:
        print(f"❌ KODE EPSG '{target_epsg}' TIDAK VALID ATAU TIDAK DITEMUKAN!")
        print("💡 Tips: Pastikan Anda tidak salah ketik (typo). Untuk wilayah Malang/Jawa Timur gunakan 32749 (UTM Zone 49S).")

# 3. Failsafe Depth of Closure
if 'Hs_val' not in globals():
    print("⚠️ Parameter gelombang ekstrem (Hs_val) belum disetel. Menggunakan default Hs = 1.5 m.")
    Hs_val = 1.5

doc_depth = -abs(1.57 * Hs_val)
print(f"⚓ [LIMIT AKTIF] Depth of Closure (DoC): {doc_depth:.2f} m")

print(f"⏳ Memuat point-cloud XYZ dari {os.path.basename(bathy_path)}...")
try:
    # Membaca data dengan proteksi errors='ignore'
    with open(bathy_path, 'r', encoding='utf-8', errors='ignore') as f:
        # Gunakan chunking jika RAM masih tidak kuat, namun untuk 121M biasanya float32 memakan ~1.5GB RAM
        df_bathy = pd.read_csv(f, delim_whitespace=True, header=None, names=['x','y','z'], dtype=np.float32)
    
    # 4. CRS Auto-Correction Logic
    is_wgs84 = df_bathy['x'].abs().max() <= 180 and df_bathy['y'].abs().max() <= 90
    if is_wgs84:
        print(f"🔄 Koordinat Geographic/WGS84 terdeteksi (X max: {df_bathy['x'].max():.2f}).")
        print(f"   Mengonversi ke sistem Metrik UTM EPSG:{target_epsg} (Proses ini mungkin memakan waktu ~10-30 detik)...")
        tr = Transformer.from_crs("EPSG:4326", f"EPSG:{target_epsg}", always_xy=True)
        # Transformasi in-place untuk menghemat memori
        df_bathy['x'], df_bathy['y'] = tr.transform(df_bathy['x'].values, df_bathy['y'].values)
        print("✅ Transformasi spasial selesai.")
    else:
        print(f"✅ Koordinat Proyeksi/Metrik terdeteksi (X max: {df_bathy['x'].max():.2f}).")
        print(f"   Diasumsikan sudah dalam sistem EPSG:{target_epsg}.")

    print(f"📊 Batimetri siap: {len(df_bathy):,} points.")
    
    # =========================================================================
    # [APEX NEXUS CORE]: 2D SPATIAL RASTERIZATION (BINNING)
    # Merender vektor point-cloud jutaan titik menggunakan scatter akan memicu Kernel Crash.
    # Solusi: Kita kompres data menjadi Matriks Resolusi Tinggi (Grid) menggunakan komputasi C native numpy.
    # =========================================================================
    grid_resolution = 1000 # Menghasilkan gambar 1000x1000 pixel
    
    print(f"⚙️ Memproses rasterisasi {len(df_bathy):,} titik ke dalam grid {grid_resolution}x{grid_resolution}...")
    
    x = df_bathy['x'].values
    y = df_bathy['y'].values
    z = df_bathy['z'].values

    # Hitung jumlah titik jatuh di setiap pixel/bin (Grid Density)
    count, x_edges, y_edges = np.histogram2d(x, y, bins=grid_resolution)
    
    # Hitung total kedalaman (Z) yang jatuh di setiap pixel/bin
    z_sum, _, _ = np.histogram2d(x, y, bins=[x_edges, y_edges], weights=z)

    # Hitung nilai rata-rata kedalaman per pixel (Hindari pembagian dengan nol)
    with np.errstate(divide='ignore', invalid='ignore'):
        z_mean = np.true_divide(z_sum, count)
        # Jika pixel kosong (tidak ada data batimetri yang diliput), ubah menjadi NaN agar transparan
        z_mean[count == 0] = np.nan 

    print("🎨 Merender visualisasi permukaan solid (Surface Mesh)...")
    
    # Render Peta dengan Pcolormesh (O(1) Render Time, tidak akan bolong)
    fig, ax = plt.subplots(figsize=(12, 10))
    
    # Kalkulasi batas warna secara dinamis dengan persentil (mengabaikan outlier/puncak ekstrim anomali)
    v_min = np.nanpercentile(z, 2)
    v_max = np.nanpercentile(z, 98)
    
    # Transpose z_mean (.T) karena pcolormesh mengekspektasikan baris sebagai koordinat Y
    mesh = ax.pcolormesh(x_edges, y_edges, z_mean.T, cmap='viridis', shading='auto', vmin=v_min, vmax=v_max)
    
    # Kustomisasi estetika enterprise
    cbar = plt.colorbar(mesh, ax=ax, label='Kedalaman (m)')
    cbar.ax.tick_params(labelsize=10)
    
    ax.set_title("Topologi Permukaan Batimetri (High-Density Rasterized Grid)", fontweight='bold', fontsize=14, pad=15)
    ax.set_xlabel(f"Easting (EPSG: {target_epsg})", fontsize=12, labelpad=10)
    ax.set_ylabel(f"Northing (EPSG: {target_epsg})", fontsize=12, labelpad=10)
    
    # Menambahkan contour opsional (membantu melihat gradien pantai)
    # ax.contour(x_edges[:-1], y_edges[:-1], z_mean.T, levels=10, colors='black', linewidths=0.3, alpha=0.5)

    ax.grid(True, linestyle=':', alpha=0.6, color='gray')
    plt.axis('equal') # Menjaga agar skala X dan Y tidak terdistorsi (1 meter utara = 1 meter timur)
    plt.tight_layout()
    plt.show()

    # Bebaskan memori secara eksplisit
    del df_bathy, x, y, z, z_mean, count, z_sum

except Exception as e:
    print(f"❌ Proses Batimetri gagal: {e}")

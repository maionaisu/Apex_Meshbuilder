    cl = ax.tricontour(triang_full, val_reg_plot, levels=levels, colors='#2d1f10', linewidths=0.4, alpha=0.8, zorder=3)
    
    contour_labels = cl.levels[::2]  
    ax.clabel(cl, levels=contour_labels, inline=True, inline_spacing=3, fontsize=6.5, fmt='%.4f', colors='#1e1b18')

    # Plot Garis Pantai
    if gdf_coast is not None:
        try:
            has_poly_c = any(g in gdf_coast.geom_type.unique() for g in ['Polygon', 'MultiPolygon'])
            if has_poly_c:
                gdf_coast[gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])].plot(
                    ax=ax, color='#e5d5b7', edgecolor='#166534', linewidth=1.2, zorder=4)
            else:
                gdf_coast.plot(ax=ax, color='#166534', linewidth=1.5, zorder=4)
        except Exception: pass

    # Plot Stasiun Sampel Sedimen Lapangan
    ax.scatter(sed_x_proj, sed_y_proj, c=manning_vals, cmap=cmap, vmin=vmin_data, vmax=vmax_data,
               s=15, edgecolors='black', linewidth=0.5, zorder=8, label='Stasiun Sampel (Manning n)')

    # Bounding Box Macro Grid D-Waves (UTM Cartesian) & Rendering Jaring Kotak Struktural Sebenarnya
    # DENSE SENSITIVE HARDENING FOR COARSE MACRO GRID:
    # Menghitung spasi render makro secara dinamis agar tetap merepresentasikan resolusi coarse ERA5 (berkisar 15 - 25 garis)
    mac_dx = mac_box["dX_m"]
    mac_dy = mac_box["dY_m"]
    
    total_mac_x = (mac_box["E_m"] - mac_box["W_m"]) / mac_dx
    total_mac_y = (mac_box["N_m"] - mac_box["S_m"]) / mac_dy
    
    step_mac_x = 1
    if total_mac_x > 25:
        step_mac_x = max(1, int(np.ceil(total_mac_x / 25)))
        logger.info(f"Visualisasi jaring makro Easting di-downsample secara dinamis (step={step_mac_x}) agar tetap terlihat kasar (coarse).")
        
    step_mac_y = 1
    if total_mac_y > 25:
        step_mac_y = max(1, int(np.ceil(total_mac_y / 25)))
        logger.info(f"Visualisasi jaring makro Northing di-downsample secara dinamis (step={step_mac_y}) agar tetap terlihat kasar (coarse).")

    mac_x_coords = np.arange(mac_box["W_m"], mac_box["E_m"] + mac_dx, mac_dx * step_mac_x)
    mac_y_coords = np.arange(mac_box["S_m"], mac_box["N_m"] + mac_dy, mac_dy * step_mac_y)
    
    for x in mac_x_coords:
        ax.plot([x, x], [mac_box["S_m"], mac_box["N_m"]], color='#dc2626', lw=0.4, ls='--', alpha=0.5, zorder=6)
    for y in mac_y_coords:
        ax.plot([mac_box["W_m"], mac_box["E_m"]], [y, y], color='#dc2626', lw=0.4, ls='--', alpha=0.5, zorder=6)

    rect_macro = Rectangle((mac_box["W_m"], mac_box["S_m"]), mac_box["E_m"] - mac_box["W_m"], mac_box["N_m"] - mac_box["S_m"],
                           lw=2.2, edgecolor='#dc2626', facecolor='none', ls='--', zorder=6,
                           label='Batas D-Waves Macro Grid (skala ERA5)')
    ax.add_patch(rect_macro)

    # Bounding Box Micro Grid D-Waves (UTM Cartesian) & Rendering Jaring Kotak Struktural Sebenarnya (DENSE SENSITIVE HARDENING)
    # Menghitung spasi render agar jaring mikro terlihat halus, rapat, dan detail tanpa mengorbankan performa RAM/CPU
    mic_dx = mic_box["dX_m"]
    mic_dy = mic_box["dY_m"]
    
    total_mic_x = (mic_box["E_m"] - mic_box["W_m"]) / mic_dx
    total_mic_y = (mic_box["N_m"] - mic_box["S_m"]) / mic_dy
    
    # Menghitung langkah visual agar jaring mikro terlihat jauh lebih rapat (dense) dibandingkan jaring makro
    # Jika grid mikro beresolusi tinggi, kita ingin visualisasinya mencerminkan kerapatan halus ini (berkisar antara 40 - 80 garis kisi)
    step_mic_x = 1
    if total_mic_x > 80:
        step_mic_x = max(1, int(np.ceil(total_mic_x / 80)))
        logger.info(f"Visualisasi jaring mikro Easting di-downsample secara dinamis (step={step_mic_x}) untuk menampilkan jaring yang padat dan detail.")
        
    step_mic_y = 1
    if total_mic_y > 80:
        step_mic_y = max(1, int(np.ceil(total_mic_y / 80)))
        logger.info(f"Visualisasi jaring mikro Northing di-downsample secara dinamis (step={step_mic_y}) untuk menampilkan jaring yang padat dan detail.")

    mic_x_coords = np.arange(mic_box["W_m"], mic_box["E_m"] + mic_dx, mic_dx * step_mic_x)
    mic_y_coords = np.arange(mic_box["S_m"], mic_box["N_m"] + mic_dy, mic_dy * step_mic_y)
    
    for x in mic_x_coords:
        ax.plot([x, x], [mic_box["S_m"], mic_box["N_m"]], color='#7c3aed', lw=0.35, ls='-', alpha=0.5, zorder=7)
    for y in mic_y_coords:
        ax.plot([mic_box["W_m"], mic_box["E_m"]], [y, y], color='#7c3aed', lw=0.35, ls='-', alpha=0.5, zorder=7)

    rect_micro = Rectangle((mic_box["W_m"], mic_box["S_m"]), mic_box["E_m"] - mic_box["W_m"], mic_box["N_m"] - mic_box["S_m"],
                           lw=2.2, edgecolor='#7c3aed', facecolor='none', ls='-', zorder=7,
                           label='Batas D-Waves Micro Grid (Nested Focused Inner)')
    ax.add_patch(rect_micro)

    # Skala legenda warna (Colorbar)
    cbar = plt.colorbar(cf, ax=ax, label='Distribusi Spasial Koefisien Manning n (s/m^(1/3))', fraction=0.046, pad=0.04, shrink=0.85)
    cbar.ax.tick_params(labelsize=9)

    # Legenda digambar paling akhir di zorder=100
    legend_elements = [
        mlines.Line2D([], [], color='none', marker='o', markerfacecolor='#f59e0b', markeredgecolor='black', markersize=6, label='Sampel Manning (n) Lapangan'),
        mlines.Line2D([], [], color='#dc2626', ls='--', lw=2.0, label='D-Waves Macro Box (Coarse)'),
        mlines.Line2D([], [], color='#7c3aed', ls='-', lw=2.0, label='D-Waves Micro Box (Fine)'),
    ]
    if gdf_coast is not None:
        legend_elements.append(mlines.Line2D([], [], color='#166534', lw=1.5, label='Garis Pantai'))

    leg = ax.legend(handles=legend_elements, loc='upper right', framealpha=0.95, edgecolor='gray', fontsize=8)
    leg.set_zorder(100)

    # Panel Ringkasan Metadata - Ikon Emojis dihilangkan untuk kompatibilitas Font DejaVu Sans
    stats_text = (
        "=== METADATA INTEGRASI DUAL-GRID ===\n"
        f"Kopel Model    : D-Flow FM & D-Waves (DIMR)\n"
        f"Metode Spasial  : {engine_label.upper()}\n"
        f"Rentang Manning n: {manning_vals.min():.5f} - {manning_vals.max():.5f}\n"
        f"---------------------------------\n"
        f"Batas Blending  : {r_inner:.0f}m s/d {r_outer:.0f}m\n"
        f"Nilai Background: {val_background_manning:.5f} s/m^(1/3)\n"
        f"Tetangga Lokal : {k_val}\n"
    )
    if engine_choice == "2":
        stats_text += f"Bentuk Variogram: {var_model.upper()}\nRange Spasial   : {range_a:.0f} m"
    else:
        stats_text += f"Bobot Jarak (P) : {p_val}"
        
    ax.text(0.02, 0.03, stats_text, transform=ax.transAxes, fontsize=8, verticalalignment='bottom',
            bbox=dict(boxstyle='round,pad=0.6', facecolor='white', alpha=0.92, edgecolor='gray', zorder=100),
            zorder=100)

    ax.set_title("Bottom Friction Generator (Manning n Spasial) — Delft3D-FM Suite\nOnline Dynamic Coupling Model & Rectilinear Grid Multi-Nesting (D-Waves)", fontweight='bold', fontsize=12, pad=12)
    ax.set_xlabel(f"Easting Proyeksi ({crs_str}) [meter]", fontsize=10)
    ax.set_ylabel("Northing Proyeksi [meter]", fontsize=10)
    ax.grid(True, linestyle=':', alpha=0.5, color='gray')
    ax.ticklabel_format(style='sci', axis='both', scilimits=(0, 0))

    # Auto-zoom dikunci ketat ke area Micro Grid (Sesuai Kebutuhan Deteksi Detail)
    if 'mic_box' in locals() and mic_box is not None:
        f_min_x = mic_box["W_m"]
        f_max_x = mic_box["E_m"]
        f_min_y = mic_box["S_m"]
        f_max_y = mic_box["N_m"]
    else:
        # Fallback ke koordinat jaring regional D-Flow FM jika mic_box tidak terdefinisi
        f_min_x, f_max_x = node_x.min(), node_x.max()
        f_min_y, f_max_y = node_y.min(), node_y.max()

    # Menhitung span dan memberikan padding 15% di sekitar Micro Grid untuk visualisasi terfokus
    span_x = max(f_max_x - f_min_x, 1000.0)
    span_y = max(f_max_y - f_min_y, 1000.0)
    pad_x, pad_y = span_x * 0.15, span_y * 0.15
    
    zoom_xlim = (f_min_x - pad_x, f_max_x + pad_x)
    zoom_ylim = (f_min_y - pad_y, f_max_y + pad_y)
    
    ax.set_xlim(zoom_xlim)
    ax.set_ylim(zoom_ylim)

    # Inset peta orientasi wilayah kerja (Minimap)
    try:
        ax_mini = inset_axes(ax, width="22%", height="22%", loc='lower right', borderpad=2.5)
        ax_mini.set_facecolor('#f0f4f8')
        ax_mini.tricontourf(triang_full, val_reg_plot, levels=levels, cmap=cmap, alpha=0.85)
        if gdf_coast is not None:
            try:
                gdf_coast[gdf_coast.isin(['Polygon', 'MultiPolygon'])].plot(ax=ax_mini, color='#c8b89a', edgecolor='#166534', lw=0.5)
            except Exception: pass
        ax_mini.scatter(sed_x_proj, sed_y_proj, c='red', s=8, zorder=5, edgecolors='none')
        rect_zoom = Rectangle((zoom_xlim[0], zoom_ylim[0]), zoom_xlim[1] - zoom_xlim[0], zoom_ylim[1] - zoom_ylim[0],
                              lw=1.5, edgecolor='red', facecolor='rgba(255,0,0,0.05)', zorder=6)
        ax_mini.add_patch(rect_zoom)
        ax_mini.set_xlim(node_x.min(), node_x.max())
        ax_mini.set_ylim(node_y.min(), node_y.max())
        ax_mini.set_xticks([])
        ax_mini.set_yticks([])
        ax_mini.set_title("Orientasi Wilayah", fontsize=7, pad=2)
        for spine in ax_mini.spines.values(): spine.set_edgecolor('#64748b')
    except Exception: pass

    plt.tight_layout()
    out_fig = os.path.join(target_dir, "Sediment_Manning_Friction_v18.png")
    plt.savefig(out_fig, dpi=180, bbox_inches='tight')
    plt.show()

    print("\n" + "=" * 80)
    print(f"🚀 SELESAI — Analisis spasial sukses dan grafik visualisasi bottom-friction dual-grid disimpan ke:")
    print(f"   📂 Berkas Peta: {out_fig}")
    print("=" * 80)

except Exception as e_plot:
    print(f"⚠️ [WARNING] Kegagalan sistem plot visualisasi: {e_plot}")
    import traceback
    traceback.print_exc()

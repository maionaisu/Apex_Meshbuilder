def dapatkan_input_cli_grid_cartesian(nama_grid, defaults=None):
    """Menanyakan batas koordinat spasial (Lat/Lon) via CLI dan mengubahnya ke UTM Cartesian."""
    print(f"\n" + "="*60)
    print(f" INTERACTIVE CLI: SPESIFIKASI BATAS {nama_grid} ")
    print(f" (Inputan tetap derajat Lat/Lon, sistem auto-convert ke meter UTM)")
    print(f"="*60)
    
    d_w = defaults.get("W", 112.5) if defaults else 112.5
    d_e = defaults.get("E", 112.8) if defaults else 112.8
    d_s = defaults.get("S", -8.6) if defaults else -8.6
    d_n = defaults.get("N", -8.3) if defaults else -8.3
    
    d_dx_m = defaults.get("dX_m", 1000.0) if defaults else 1000.0
    d_dy_m = defaults.get("dY_m", 1000.0) if defaults else 1000.0
    
    while True:
        try:
            w_in = input(f"  [1/6] Batas Barat (West / Lon-Min) [Default: {d_w:.6f}] : ").strip()
            w = float(w_in) if w_in else d_w
            
            e_in = input(f"  [2/6] Batas Timur (East / Lon-Max) [Default: {d_e:.6f}] : ").strip()
            e = float(e_in) if e_in else d_e
            
            s_in = input(f"  [3/6] Batas Selatan (South / Lat-Min) [Default: {d_s:.6f}] : ").strip()
            s = float(s_in) if s_in else d_s
            
            n_in = input(f"  [4/6] Batas Utara (North / Lat-Max) [Default: {d_n:.6f}] : ").strip()
            n = float(n_in) if n_in else d_n
            
            if e <= w or n <= s:
                print("\n  [Error] Batas tidak logis! East harus > West and North > South.")
                continue
                
            dx_in = input(f"  [5/6] Spasi Grid Arah-X dX (Meter)   [Default: {d_dx_m:.1f} m] : ").strip()
            dx_m = float(dx_in) if dx_in else d_dx_m
            
            dy_in = input(f"  [6/6] Spasi Grid Arah-Y dY (Meter)   [Default: {d_dy_m:.1f} m] : ").strip()
            dy_m = float(dy_in) if dy_in else d_dy_m
            break
        except ValueError:
            print("\n  [Error] Input wajib berupa angka desimal murni!")
            
    # Proyeksikan batas Lat/Lon menjadi meter UTM secara dinamis
    transformer = Transformer.from_crs("EPSG:4326", f"EPSG:{target_epsg}", always_xy=True)
    x_min, y_min = transformer.transform(w, s)
    x_max, y_max = transformer.transform(e, n)
            
    return {"W_m": x_min, "E_m": x_max, "S_m": y_min, "N_m": y_max, "dX_m": dx_m, "dY_m": dy_m, "W_deg": w, "E_deg": e, "S_deg": s, "N_deg": n}

def export_delft3d_grd_file_cartesian(filename, bbox):
    """
    Menghasilkan file jaring *.grd rectilinear standar RGFGRID Deltares Cartesian.
    Mengunci sistem koordinat pada: Coordinate System = Cartesian (UTM meter).
    Melakukan proyeksi dari koordinat Lat/Lon ke metrik UTM Zone 49S (EPSG:32749).
    Mengemas seluruh koordinat dalam baris tunggal per Eta untuk kepatuhan kaku DFM/SWAN parser.
    GRID DIBIARKAN RECTILINEAR UTUH TANPA DIKLIP OLEH GARIS PANTAI DEMI KEKOKOHAN NUMERIK.
    """
    # Melakukan proyeksi koordinat ke UTM Zone 49S (EPSG:32749) secara presisi
    transformer = Transformer.from_crs("EPSG:4326", "EPSG:32749", always_xy=True)
    
    # Konversi batas spasial Lat/Lon ke Easting/Northing UTM meter
    w_m, s_m = transformer.transform(bbox["W_deg"], bbox["S_deg"])
    e_m, n_m = transformer.transform(bbox["E_deg"], bbox["N_deg"])
    
    # Membuat deret koordinat metrik UTM
    x_coords = np.arange(w_m, e_m + bbox["dX_m"], bbox["dX_m"])
    y_coords = np.arange(s_m, n_m + bbox["dY_m"], bbox["dY_m"])
    
    mx = len(x_coords)
    my = len(y_coords)
    
    with open(filename, 'w') as f:
        # Header Resmi Delft3D RGFGRID Cartesian metrik
        f.write("*\n")
        f.write("* File generated by APEX NEXUS Mesh Builder\n")
        f.write("Coordinate System = Cartesian\n")
        f.write("Missing Value = -9.99999000000000024E+02\n")
        f.write(f" {mx} {my}\n")
        f.write(" 0      0      0\n")
        
        # 1. Menuliskan Sumbu X (Easting meter) per Baris Eta (Tanpa continuation lines gantung!)
        for j in range(1, my + 1):
            val_str = " ".join([f"{v:.17E}" for v in x_coords])
            f.write(f"Eta= {j:<4} {val_str}\n")
            
        # 2. Menuliskan Sumbu Y (Northing meter) per Baris Eta (Tanpa continuation lines gantung!)
        for j in range(1, my + 1):
            y_row = np.full(mx, y_coords[j-1])
            val_str = " ".join([f"{v:.17E}" for v in y_row])
            f.write(f"Eta= {j:<4} {val_str}\n")
            
    print(f"   ✅ [GRD EXPORT SUCCESS] File Delft3D Cartesian GRD disimpan -> {os.path.basename(filename)} ({mx}x{my} Nodes)")
    return mx, my, bbox


# [Code Cell]
import os
import numpy as np
import xarray as xr
import pandas as pd
import matplotlib.pyplot as plt
import xugrid as xu
import matplotlib.lines as mlines

print("🌊 [TAHAP 7 & 8] DYNAMIC BOUNDARY EXTRACTION & METOCEAN FORCING INJECTION")

# =========================================================================
# 1. PENGAMBILAN DATA ERA5 DARI MEMORI TAHAP 1
# =========================================================================
try:
    hs_target = globals().get('Hs_val')
    tp_target = globals().get('Tp_val')
    dir_target = globals().get('Dir_val')
    
    if hs_target is None:
        print("⚠️ Data ERA5 dari Tahap 1 tidak ditemukan di memori.")
        hs_target = float(input("   Masukkan Significant Wave Height (Hs) [contoh: 1.5]: ") or 1.5)
        tp_target = float(input("   Masukkan Peak Period (Tp) [contoh: 8.0]: ") or 8.0)
        dir_target = float(input("   Masukkan Wave Direction (Dir) [contoh: 225.0]: ") or 225.0)
    else:
        print("✅ Data ERA5 (Tahap 1) berhasil disinkronisasi dari memori!")
        
    print(f"📊 Parameter Injeksi: Hs = {hs_target:.2f} m | Tp = {tp_target:.2f} s | Dir = {dir_target:.2f}°")
except Exception as e:
    raise RuntimeError(f"Gagal memuat data metocean: {e}")

# =========================================================================
# 2. MEMBACA DOMAIN MESH & MENENTUKAN BATAS DINAMIS
# =========================================================================
mesh_file = r"F:\Kuliah\CoastalResearch\CrashCourse\Mesh Builder\Apex_Final_Model_5m_Mesh.nc"
if not os.path.exists(mesh_file):
    raise FileNotFoundError(f"❌ File {mesh_file} tidak ditemukan! Harap selesaikan Tahap 6.")

print(f"\n⏳ Membaca topologi dari {mesh_file}...")
ds_mesh = xu.open_dataset(mesh_file)

node_x = ds_mesh.grid.node_x
node_y = ds_mesh.grid.node_y

# Sedikit padding inward (5m) agar boundary line 100% mendeteksi/memotong face mesh
pad = 5.0
min_x, max_x = node_x.min() + pad, node_x.max() - pad
min_y, max_y = node_y.min() + pad, node_y.max() - pad

# [APEX NEXUS LOGIC]: Pembuatan Smart Polyline berdasar Arah Gelombang Datang
# Arah (Dir) = Darimana gelombang berasal (Coming From)
# N=0, E=90, S=180, W=270
dir_mod = dir_target % 360
bx, by = [], []
boundary_name = "Boundary_Dynamic"

print(f"🧭 Menganalisis orientasi Boundary berdasarkan arah datang gelombang ({dir_mod:.1f}°)...")

if 337.5 <= dir_mod or dir_mod < 22.5: 
    print("   -> Dominan UTARA (North). Menarik garis lurus di tepi Utara.")
    bx, by = [min_x, max_x], [max_y, max_y]
    boundary_name = "Boundary_North"
elif 22.5 <= dir_mod < 67.5: 
    print("   -> Dominan TIMUR LAUT (North-East). Membuat garis L-Shape (Utara & Timur).")
    bx, by = [min_x, max_x, max_x], [max_y, max_y, min_y]
    boundary_name = "Boundary_NorthEast"
elif 67.5 <= dir_mod < 112.5: 
    print("   -> Dominan TIMUR (East). Menarik garis lurus di tepi Timur.")
    bx, by = [max_x, max_x], [max_y, min_y]
    boundary_name = "Boundary_East"
elif 112.5 <= dir_mod < 157.5: 
    print("   -> Dominan TENGGARA (South-East). Membuat garis L-Shape (Selatan & Timur).")
    bx, by = [max_x, max_x, min_x], [max_y, min_y, min_y]
    boundary_name = "Boundary_SouthEast"
elif 157.5 <= dir_mod < 202.5: 
    print("   -> Dominan SELATAN (South). Menarik garis lurus di tepi Selatan.")
    bx, by = [max_x, min_x], [min_y, min_y]
    boundary_name = "Boundary_South"
elif 202.5 <= dir_mod < 247.5: 
    print("   -> Dominan BARAT DAYA (South-West). Membuat garis L-Shape (Selatan & Barat).")
    bx, by = [max_x, min_x, min_x], [min_y, min_y, max_y]
    boundary_name = "Boundary_SouthWest"
elif 247.5 <= dir_mod < 292.5: 
    print("   -> Dominan BARAT (West). Menarik garis lurus di tepi Barat.")
    bx, by = [min_x, min_x], [min_y, max_y]
    boundary_name = "Boundary_West"
elif 292.5 <= dir_mod < 337.5: 
    print("   -> Dominan BARAT LAUT (North-West). Membuat garis L-Shape (Utara & Barat).")
    bx, by = [min_x, min_x, max_x], [min_y, max_y, max_y]
    boundary_name = "Boundary_NorthWest"

# =========================================================================
# 3. GENERASI FILE .PLI (POLYLINE GEOMETRY DELFT3D)
# =========================================================================
pli_filename = f"{boundary_name}.pli"
print(f"✍️ Mengekspor Boundary Geometri: {pli_filename}")

with open(pli_filename, 'w') as f:
    f.write(f"{boundary_name}\n")    
    f.write(f" {len(bx)} 2\n")     
    for x, y in zip(bx, by):
        f.write(f"  {x:.6f}  {y:.6f}\n")

# =========================================================================
# 4. GENERASI FILE .BC (BOUNDARY CONDITIONS DELFT3D)
# =========================================================================
bc_filename = "Wave_Forcing_ERA5.bc"
print(f"✍️ Mengekspor Boundary Conditions: {bc_filename}")

with open(bc_filename, 'w') as f:
    f.write("[forcing]\n")
    f.write(f"Name                            = {boundary_name}\n")
    f.write("Function                        = timeseries\n")
    f.write("Time-interpolation              = linear\n")
    f.write("Quantity                        = time\n")
    f.write("Unit                            = minutes since 2026-01-01 00:00:00\n")
    f.write("Quantity                        = waveheightbnd\n")
    f.write("Unit                            = m\n")
    f.write("Quantity                        = waveperiodbnd\n")
    f.write("Unit                            = s\n")
    f.write("Quantity                        = wavedirectionbnd\n")
    f.write("Unit                            = deg\n")
    f.write(f"0.0      {hs_target:.2f}    {tp_target:.2f}    {dir_target:.2f}\n")
    f.write(f"1440.0   {hs_target:.2f}    {tp_target:.2f}    {dir_target:.2f}\n")

print("\n✅ File .pli dan .bc telah berhasil dibuat di direktori kerja.")

# =========================================================================
# 5. VISUALISASI VERIFIKASI BATAS GELOMBANG
# =========================================================================
try:
    plt.close('all')
    fig, ax = plt.subplots(figsize=(10, 8), dpi=100)
    ax.set_aspect('equal', adjustable='datalim')
    
    # Render XUGrid 
    ds_mesh.grid.plot(ax=ax, linewidth=0.2, color='#94A3B8', alpha=0.5, zorder=1)
    
    # Plot Garis Boundary Dinamis
    ax.plot(bx, by, color='#DC2626', linewidth=4, zorder=4, solid_capstyle='round')
    
    # Kalkulasi Pusat Panah Arah Gelombang
    mid_bx = np.mean(bx)
    mid_by = np.mean(by)
    
    # Konversi sudut (Compass to Cartesian)
    math_angle = 270 - dir_target 
    rad = np.radians(math_angle)
    
    # Vektor Panah: Gelombang bergerak MENUJU mid_bx, mid_by
    length = (max_x - min_x) * 0.15 # Panjang panah 15% dari lebar grid
    start_x = mid_bx - (np.cos(rad) * length)
    start_y = mid_by - (np.sin(rad) * length)
    dx = mid_bx - start_x
    dy = mid_by - start_y
    
    ax.arrow(start_x, start_y, dx, dy, 
             head_width=length*0.2, head_length=length*0.2, 
             fc='#EF4444', ec='#EF4444', zorder=5, width=length*0.04)
    
    ax.set_title(f"Dynamic Wave Boundary & Metocean Forcing\nBoundary Type: {boundary_name}", fontweight='bold', fontsize=14, pad=15)
    ax.set_xlabel("Easting", fontsize=12)
    ax.set_ylabel("Northing", fontsize=12)
    ax.grid(True, linestyle=':', alpha=0.6, color='gray')
    
    legend_elements = [
        mlines.Line2D([], [], color='#94A3B8', linewidth=1, label='XUGrid Domain'),
        mlines.Line2D([], [], color='#DC2626', linewidth=4, label=f'Wave Boundary (.pli)'),
        mlines.Line2D([], [], color='#EF4444', marker='^', linestyle='None', markersize=10, label=f'Direction ({dir_target}°)')
    ]
    ax.legend(handles=legend_elements, loc='best', framealpha=0.9, edgecolor='black')

    plt.tight_layout()
    plt.show()

except Exception as e:
    print(f"⚠️ [WARNING] Proses render plot visual mengalami kendala: {e}")

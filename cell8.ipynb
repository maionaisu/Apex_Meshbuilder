def generate_dwaves_bathymetry(grd_file, xyz_file, output_dep_name):
    """
    Membaca grid .grd, menginterpolasikan data batimetri lapangan .xyz raksasa secara efisien,
    dan mengekspornya ke format .dep standard D-Waves SWAN dengan baris kaku max 132 karakter.
    """
    logger.info(f"Memproses interpolasi batimetri untuk grid: {os.path.basename(grd_file)}")
    
    if not os.path.exists(grd_file):
        logger.error(f"Berkas grid {grd_file} tidak ditemukan!")
        return False
        
    try:
        # 1. Parse dimensi dan koordinat dari jaring .grd
        logger.info("Memparsing file grid komputasi .grd...")
        with open(grd_file, 'r') as f:
            grd_lines = [line.strip() for line in f.readlines() if line.strip() and not line.startswith('*')]
            
        dim_line = None
        for cl in grd_lines:
            parts = cl.split()
            if len(parts) == 2 and parts[0].isdigit() and parts[1].isdigit():
                dim_line = cl
                break
                
        if not dim_line:
            raise ValueError("Matriks dimensi grid (mx, my) tidak ditemukan dalam berkas .grd.")
            
        mx, my = map(int, dim_line.split())
        eta_lines = [cl for cl in grd_lines if cl.startswith("Eta=")]
        
        numeric_tokens = []
        for el in eta_lines:
            parts = el.split()
            numeric_tokens.extend(parts[2:]) # Skip "Eta=" dan "idx"
            
        all_coords = np.array([float(val) for val in numeric_tokens])
        half = mx * my
        x_grid = all_coords[:half].reshape((my, mx))
        y_grid = all_coords[half:2*half].reshape((my, mx))
        
        # 2. Membaca berkas .xyz secara kilat via Pandas (Downsampled / Batched)
        xyz_x, xyz_y, xyz_z = [], [], []
        if os.path.exists(xyz_file):
            logger.info("Membaca berkas batimetri raksasa .xyz...")
            df_xyz = pd.read_csv(
                xyz_file, 
                sep=r'\s+', 
                header=None, 
                names=['x', 'y', 'z'], 
                dtype={'x': np.float64, 'y': np.float64, 'z': np.float32},
                engine='c'
            )
            xyz_x = df_xyz['x'].values
            xyz_y = df_xyz['y'].values
            xyz_z = df_xyz['z'].values
            logger.info(f"Berhasil memuat {len(xyz_x):,} titik data batimetri asli.")
        else:
            logger.warning(f"Berkas .xyz tidak ditemukan di '{xyz_file}'. Menggunakan batimetri sintetik (sloping shelf)!")
            # Sintetik slope linear offshore ke onshore
            x_min, x_max = x_grid.min(), x_grid.max()
            y_min, y_max = y_grid.min(), y_grid.max()
            # Buat jaring sampel acak tipikal
            np.random.seed(123)
            num_syn = 50000
            xyz_x = np.random.uniform(x_min - 5000, x_max + 5000, num_syn)
            xyz_y = np.random.uniform(y_min - 5000, y_max + 5000, num_syn)
            # Semakin ke Selatan (y kecil), laut semakin dalam (Z negatif)
            slope = (xyz_y - y_min) / (y_max - y_min) # 0 di Selatan, 1 di Utara
            xyz_z = -100.0 * (1.0 - slope) + 5.0 # -100 meter di offshore, +5 meter di darat
            
        # 3. Proses interpolasi spasial berperforma tinggi berbasis cKDTree
        logger.info("Membangun spasial KD-Tree batimetri lapangan...")
        tree = cKDTree(np.c_[xyz_x, xyz_y])
        
        grid_flat = np.c_[x_grid.ravel(), y_grid.ravel()]
        logger.info("Melakukan penelusuran interpolasi spasial tercepat (Nearest Neighbor)...")
        
        # Menggunakan batching kueri untuk mengamankan lonjakan konsumsi RAM
        batch_size = 200000
        distances = []
        indices = []
        for i in range(0, len(grid_flat), batch_size):
            batch = grid_flat[i:i+batch_size]
            dist, idx = tree.query(batch, k=1)
            distances.append(dist)
            indices.append(idx)
            
        distances = np.concatenate(distances)
        indices = np.concatenate(indices)
        
        # Ekstrak Z dan lakukan clipping threshold radius
        interpolated_z = xyz_z[indices]
        # Data di luar jangkauan grid batimetri > 3000 meter diisi missing value
        interpolated_z[distances > 3000.0] = -999.0
        
        # 4. Konversi Tanda Fisis D-Waves (Kedalaman positif ke bawah, darat negatif)
        # Z Lapangan: air = negatif (contoh: -25m), darat = positif
        # SWAN depth = -1 * Z. Air menjadi +25m (positif), darat menjadi negatif
        depth_flat = -1.0 * interpolated_z
        depth_flat[interpolated_z == -999.0] = -999.0 # Biarkan missing value -999.0 tetap
        
        depth_matrix = depth_flat.reshape((my, mx))
        
        # 5. Ekspor Berkas .dep dengan Chunker 10 Kolom per Baris (SWAN Max 132 chars compliant)
        dep_out_path = os.path.join(target_dir, output_dep_name)
        logger.info(f"Menulis berkas batimetri SWAN .dep: {dep_out_path}")
        
        with open(dep_out_path, 'w') as f_dep:
            for j in range(my):
                row_vals = depth_matrix[j, :]
                # Memecah baris menjadi chunk berisi maksimal 10 nilai kedalaman (%.3f)
                for i in range(0, mx, 10):
                    chunk = row_vals[i:i+10]
                    val_str = " ".join([f"{v:.3f}" for v in chunk])
                    f_dep.write(val_str + "\n")
                    
        print(f"   ✅ [DEP EXPORT SUCCESS] Berkas batimetri SWAN '{output_dep_name}' tercetak legal ({mx}x{my} Nodes).")
        return True
    except Exception as e_dep:
        logger.error(f"Gagal memproses generator batimetri .dep: {e_dep}")
        import traceback
        traceback.print_exc()
        return False

# Eksekusi pembuatan file .dep untuk Macro dan Micro Grid

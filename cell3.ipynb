# [Code Cell]
print("🌕 [TAHAP 2] ANALISIS HARMONIK PASANG SURUT (UTide)")

# Bulletproof path input loop
while True:
    tide_path = input("📂 Masukkan path file Pasut (CSV/TXT): ").strip().strip('\'"').replace('"', '').replace("'", "")
    if os.path.exists(tide_path):
        break
    print(f"❌ File tidak ditemukan di: {os.path.abspath(tide_path)}\nCoba lagi.")

try:
    # --- SRGI AUTO-DETECT ---
    print("\n⏳ Memeriksa format data...")
    with open(tide_path, 'r', encoding='utf-8', errors='ignore') as f:
        header_lines = [f.readline() for _ in range(15)]
        
    is_srgi = any("big" in line.lower() or "srgi" in line.lower() for line in header_lines)
    
    if is_srgi:
        print("✅ Format Data SRGI BIG terdeteksi! Memproses auto-parsing...")
        
        skip_n = 0
        for i, line in enumerate(header_lines):
            if 'yyyy-mm-dd' in line.lower() or 'z(m)' in line.lower() or 'utc' in line.lower():
                skip_n = i + 1
                break
        if skip_n == 0: skip_n = 8 
            
        df_tide = pd.read_csv(tide_path, skiprows=skip_n, delim_whitespace=True, 
                              names=['Lat', 'Lon', 'Date', 'Time', 'Z'], 
                              on_bad_lines='skip', skip_blank_lines=True)
        
        df_tide['Z'] = pd.to_numeric(df_tide['Z'], errors='coerce')
        df_tide = df_tide.dropna(subset=['Z'])
        
        df_tide['clean_time'] = pd.to_datetime(df_tide['Date'].astype(str) + ' ' + df_tide['Time'].astype(str), errors='coerce')
        df_clean = df_tide.dropna(subset=['clean_time', 'Z']).sort_values('clean_time').copy()
        col_z = 'Z'
        
    else:
        print("ℹ️ Format CSV normal terdeteksi. Melakukan manual parsing...")
        skip_input = input("Berapa baris metadata yang ingin dilewati? (Enter=0): ").strip()
        skip_rows = int(skip_input) if skip_input.isdigit() else 0
        
        try:
            df_tide = pd.read_csv(tide_path, skiprows=skip_rows, sep=None, engine='python')
        except Exception:
            df_tide = pd.read_csv(tide_path, skiprows=skip_rows)
            
        print("\n📊 Pratinjau 3 Baris Pertama:")
        print("-" * 50)
        print(df_tide.head(3).to_string())
        print("-" * 50)
        
        columns = list(df_tide.columns)
        for i, col in enumerate(columns):
            print(f"  [{i+1}] {col}")
            
        while True:
            try:
                col_t_idx = int(input(f"\nMasukkan NOMOR kolom Waktu/Time: ").strip()) - 1
                col_t = columns[col_t_idx]
                break
            except (ValueError, IndexError):
                print("⚠️ Masukkan nomor yang valid dari daftar di atas.")
                
        while True:
            try:
                col_z_idx = int(input(f"Masukkan NOMOR kolom Elevasi/Z: ").strip()) - 1
                col_z = columns[col_z_idx]
                break
            except (ValueError, IndexError):
                print("⚠️ Masukkan nomor yang valid dari daftar di atas.")
        
        df_tide[col_t] = pd.to_datetime(df_tide[col_t], errors='coerce')
        df_tide['clean_time'] = df_tide[col_t].dt.tz_localize(None)
        df_tide[col_z] = pd.to_numeric(df_tide[col_z], errors='coerce')
        df_clean = df_tide.dropna(subset=['clean_time', col_z]).sort_values('clean_time').copy()
        
    # --- PRE-PROCESSING DATA ---
    print("⏳ Membersihkan data (Timezone stripping & Outlier removal)...")
    df_clean = df_clean.drop_duplicates(subset=['clean_time'])
    
    mean_z, std_z = df_clean[col_z].mean(), df_clean[col_z].std()
    initial_len = len(df_clean)
    df_clean = df_clean[(df_clean[col_z] >= mean_z - 3*std_z) & (df_clean[col_z] <= mean_z + 3*std_z)]
    print(f"  ├ {initial_len - len(df_clean)} outliers dihapus.")
    
    time_dates = df_clean['clean_time'].values  
    elevations = df_clean[col_z].values
    
    msl = np.mean(elevations)
    z_centered = elevations - msl
    
    ref_lat = globals().get('lat_min', -8.0) 
    
    print(f"⏳ Mengeksekusi LSHA ({len(elevations):,} sampel) di Latitude {ref_lat:.2f}°...")
    coef = utide.solve(time_dates, z_centered, lat=ref_lat, method='ols', conf_int='linear', white=True)
    
    # --- RECONSTRUCT & VALIDATION ---
    print("⏳ Merekonstruksi Hindcast...")
    tide_recon = utide.reconstruct(time_dates, coef)
    z_reconstructed = tide_recon.h
    
    residuals = z_centered - z_reconstructed
    rmse_val = np.sqrt(np.mean(residuals**2))
    var_exp = 100 * (1 - (np.var(residuals) / np.var(z_centered)))
    
    def clean_name(n):
        if isinstance(n, bytes): return n.decode('utf-8').strip()
        return str(n).strip()
        
    constituents = {clean_name(name): {'amp': coef.A[i], 'phase': coef.g[i]} for i, name in enumerate(coef.name)}
    
    m2_amp = constituents.get('M2', {}).get('amp', 0)
    s2_amp = constituents.get('S2', {}).get('amp', 0)
    k1_amp = constituents.get('K1', {}).get('amp', 0)
    o1_amp = constituents.get('O1', {}).get('amp', 0)
    sa_amp = constituents.get('SA', {}).get('amp', 0)
    ssa_amp = constituents.get('SSA', {}).get('amp', 0)
    
    print(f"\n✅ [HASIL UTIDE LSHA]")
    print(f"  ├ Mean Sea Level (MSL/Z0) : {msl:.3f} m")
    print(f"  ├ RMSE (Skill)            : {rmse_val:.4f} m (Var Exp: {var_exp:.1f}%)")
    print(f"  ├ M2 (Lunar Semidiurnal)  : {m2_amp:.3f} m | Fase: {constituents.get('M2', {}).get('phase', 0):.1f}°")
    print(f"  ├ S2 (Solar Semidiurnal)  : {s2_amp:.3f} m | Fase: {constituents.get('S2', {}).get('phase', 0):.1f}°")
    print(f"  ├ K1 (Luni-solar Diurnal) : {k1_amp:.3f} m | Fase: {constituents.get('K1', {}).get('phase', 0):.1f}°")
    print(f"  ├ O1 (Lunar Diurnal)      : {o1_amp:.3f} m | Fase: {constituents.get('O1', {}).get('phase', 0):.1f}°")
    
    if sa_amp > 0 or ssa_amp > 0:
        print(f"  ├ SA (Solar Annual)       : {sa_amp:.3f} m | Fase: {constituents.get('SA', {}).get('phase', 0):.1f}°")
        print(f"  ├ SSA (Solar Semi-Annual) : {ssa_amp:.3f} m | Fase: {constituents.get('SSA', {}).get('phase', 0):.1f}°")
    
    form_factor = (k1_amp + o1_amp) / (m2_amp + s2_amp) if (m2_amp + s2_amp) > 0 else 0
    tide_type = "Semi-Diurnal Murni"
    if form_factor > 3.0: tide_type = "Diurnal Murni"
    elif form_factor > 1.5: tide_type = "Mixed (Diurnal dominan)"
    elif form_factor > 0.25: tide_type = "Mixed (Semidiurnal dominan)"
        
    print(f"  └ Form Factor (F)         : {form_factor:.2f} ➔ {tide_type}")

    # Plot (Native Window)
    try:
        plt.close('all') 
    except: pass
    
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 6), gridspec_kw={'height_ratios': [3, 1]})
    fig.canvas.manager.set_window_title("Apex Hydro - Tidal Analysis (1 Year Full)")
    
    # [ENTERPRISE FIX]: Menampilkan SELURUH data 1 Tahun, tidak lagi di-crop 1 bulan.
    plot_times = df_clean['clean_time']
    
    # Karena datanya sangat padat, kita menipiskan garis agar gelombangnya jelas.
    ax1.plot(plot_times, z_centered, color='#9CA3AF', linewidth=0.8, label='Observasi')
    ax1.plot(plot_times, z_reconstructed, color='#DC2626', linewidth=0.6, alpha=0.9, label='Model UTide (Full Series)')
             
    ax1.set_title(f"Elevasi Pasut ({tide_type}) - Observasi vs Model LSHA", fontweight='bold')
    ax1.set_ylabel("Elevasi (m)")
    ax1.legend(loc='upper right')
    
    residuals_plot = residuals
    ax2.fill_between(plot_times, residuals_plot, color='#3B82F6', alpha=0.5, label='Residual Error')
    ax2.set_ylabel("Residual (m)")
    ax2.legend(loc='upper right')
    
    plt.tight_layout()
    plt.show()

except Exception as e:
    print(f"❌ Proses UTide gagal: {e}")

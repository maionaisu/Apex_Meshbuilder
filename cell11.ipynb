# =========================================================================
# [Code Cell 11 - v7.1] ECOSYSTEM-BASED COUPLING: BATCH SCENARIO GENERATOR
# =========================================================================
# DIKEMBANGKAN OLEH: APEX NEXUS (Principal Coastal Modeler & Expert Automation)
# RUJUKAN ILMIAH UTAMA:
#   1. Mangrove (De Dominicis et al., 2023) - Baptist Drag Model (FormulaNr = 153)
#   2. Seagrass (Twomey et al., 2020) - Wave Dissipation in Canopy Boundary Layer
#   3. Coral Reef (Boodoo & Villarroel-Lamb, 2025) - Coral Fringing Reef-Flat Friction
# RUJUKAN MANUAL DELTARES:
#   - D-Flow FM User Manual Appendix C.8.2 (Trachytope Table Definition Syntax .ttd)
#   - D-Flow FM User Manual Appendix C.8.3 (Area Roughness on Links .arl)
#   - D-Flow FM User Manual Appendix D.4.1 (IniField Multi-Layer Friction .ini)
#   - D-Waves / SWAN User Manual Section 4 (Vegetation Wave Dissipation .veg)
# CHANGELOG v7.1:
#   - BATCH MULTI-SCENARIO AUTOMATION:
#     * Skrip otomatis memproduksi 4 folder skenario komparasi skripsi sekaligus secara serentak.
#     * Skenario 1: Complete Ecosystem (Mangrove, Seagrass, Coral AKTIF)
#     * Skenario 2: No Vegetation (Hanya Coral AKTIF, Mangrove & Seagrass NON-AKTIF)
#     * Skenario 3: No Coral Reef (Hanya Mangrove & Seagrass AKTIF, Coral NON-AKTIF)
#     * Skenario 4: Baseline Sand Only (Eksisting tanpa ekosistem, hanya pasir Kriging AKTIF)
#   - ADAPTIVE UNIT DETECTOR: Cerdas mendeteksi satuan cm/m pada DBH dan tinggi tanaman dari LiDAR.
#   - CONSOLIDATED MANGROVE CLASS: Menyatukan kelas Mangrove Rapat & Renggang menjadi 
#     satu kelas tunggal "Mangrove" (ID 101) dengan kerapatan realistis N = 1.25 pohon/m2 
#     untuk mencegah over-damping akibat penjarangan alami (self-thinning).
#   - GPS SEAGRASS CONVEX HULL & BUFFER: Mengonversi koordinat GPS mentah lapangan 
#     menjadi Poligon UTM 49S dengan buffer 15 meter untuk meng-clip sel grid model secara presisi.
#   - SINGLE FILE .TTD (KATALOG TRACHYTOPE): Menghasilkan file vegetation.ttd dengan format 
#     numerik baku sesuai manual resmi: [Trachytope_ID] [FormulaNr=153] [height] [n_equiv] [Cd] [Cb].
#   - SINGLE FILE .ARL (FLOW LINKS GEOMETRIC INTERSECTION): Mengekstrak link koordinat (xu, yu) 
#     dari jaring hidrodinamika menggunakan xugrid, memotong dengan poligon spasial, 
#     dan mengekspor file vegetation.arl dengan format: [xu] [yu] 0.0 [Trachytope_ID] [Fraction].
# =========================================================================

import os
import sys
import glob
import shutil
import numpy as np
import pandas as pd
import geopandas as gpd
import xarray as xr
import xugrid as xu
import matplotlib.pyplot as plt
import matplotlib.tri as mtri
import matplotlib.lines as mlines
from shapely.geometry import Point, Polygon
from pyproj import Transformer

print("🌱 [TAHAP 11 - v7.1] ECOSYSTEM-BASED VEGETATION PARAMETERS GENERATOR")
print("=========================================================================")
print("Membuat berkas parameter vegetasi spasial legal (.ttd, .arl, .veg) dan .pol")
print("  - Rujukan Mangrove : Baptist Formula 153 (De Dominicis et al., 2023)")
print("  - Rujukan Lamun    : Baptist Formula 153 (Twomey et al., 2020)")
print("  - Terumbu Karang   : Multi-Layer IniField Polygon Overriding (value = 0.05)")
print("  - Automasi Batch   : 4 Folder Skenario Komparatif Dibuat Sekaligus!")
print("=========================================================================\n")

# =========================================================================
# FASE 0: INTERAKTIF CLI UNTUK SETUP DIREKTORI OUTPUT UTAMA & BACKGROUND
# =========================================================================
print("📂 [SETUP] DIREKTORI OUTPUT UTAMA")
target_dir = input("   📂 Tentukan folder output utama proyek vegetasi [Default: direktori aktif]: ").strip().strip('\'"').replace('"', '')
if not target_dir:
    target_dir = os.getcwd()

try:
    os.makedirs(target_dir, exist_ok=True)
    print(f"   ✅ Direktori tujuan disetujui: {target_dir}")
except Exception as e_dir:
    print(f"   ⚠️ Gagal membuat direktori khusus: {e_dir}. Ekspor dialihkan kembali ke direktori kerja utama.")
    target_dir = os.getcwd()

# Meminta input nama berkas pasir background hasil Kriging sebelumnya (Tahap 8)
print("\n🏖️ [SETUP] KOPEL DATA GESEKAN SEDIMEN SEBELUMNYA")
default_bg_xyz = "DFM_Manning_Roughness.xyz"
bg_xyz_path = input(f"   📂 Masukkan nama/path berkas background Manning pasir dari TAHAP 8 [{default_bg_xyz}]: ").strip().strip('\'"').replace('"', '') or default_bg_xyz

# Meminta nilai Manning terumbu karang kaku
default_coral_manning = 0.050
coral_manning_str = input(f"   ❓ Masukkan nilai kekasaran Manning (n) Terumbu Karang [Default: {default_coral_manning}]: ").strip()
coral_manning = float(coral_manning_str) if coral_manning_str else default_coral_manning

# =========================================================================
# FASE 1: AUTOMATED DBH & HEIGHT EXTRACTION DARI METADATA LIDAR (EXCEL / CSV)
# =========================================================================
print("\n📊 [FASE 1] EKSTRAKSI DIMENSI MANGROVE DARI METADATA LIDAR")
default_lidar_path = "Metadata LiDAR Mangrove.xlsx - Data.csv"
lidar_path = input(f"   📂 Masukkan path file metadata LiDAR (xlsx/csv) [{default_lidar_path}]: ").strip().strip('\'"').replace('"', '') or default_lidar_path

avg_dbh_m = 0.0550    # Default fallback fisis (5.5 cm / 0.055 m) - Sesuai data pohon muda mapan
avg_height_m = 3.685  # Default fallback fisis (3.685 m)

if os.path.exists(lidar_path):
    try:
        if lidar_path.lower().endswith('.csv'):
            df_lidar = pd.read_csv(lidar_path, header=None)
        else:
            xls_lidar = pd.ExcelFile(lidar_path)
            print("      Sheets tersedia:", xls_lidar.sheet_names)
            suggested_sheet = next((sn for sn in xls_lidar.sheet_names if 'data' in sn.lower() or 'mangrove' in sn.lower()), xls_lidar.sheet_names[0])
            sheet_name = input(f"      ↳ Pilih nama sheet [{suggested_sheet}]: ").strip() or suggested_sheet
            df_lidar = pd.read_excel(xls_lidar, sheet_name=sheet_name, header=None)
        
        # Deteksi baris header dan indeks kolom untuk parameter DBH & Tinggi secara cerdas
        col_dbh_idx = None
        col_height_idx = None
        header_row = 0
        
        for r_idx in range(min(15, len(df_lidar))):
            row_vals = df_lidar.iloc[r_idx].astype(str).tolist()
            for c_idx, val in enumerate(row_vals):
                val_clean = val.lower().strip()
                if "dbh" in val_clean or ("diameter" in val_clean and "keliling" not in val_clean):
                    col_dbh_idx = c_idx
                    header_row = r_idx
                elif "tinggi" in val_clean or "height" in val_clean:
                    col_height_idx = c_idx
                    header_row = r_idx
            if col_dbh_idx is not None and col_height_idx is not None:
                break
        
        # Ekstraksi dan kalkulasi rata-rata DBH dengan Smart Unit Detection
        if col_dbh_idx is not None:
            dbh_values = pd.to_numeric(df_lidar.iloc[header_row + 1:, col_dbh_idx], errors='coerce').dropna()
            if len(dbh_values) > 0:
                avg_dbh_val = dbh_values.mean()
                if avg_dbh_val > 1.0:  # Berarti terukur dalam satuan cm (misal 5.5 cm)
                    avg_dbh_m = avg_dbh_val / 100.0
                else:                  # Berarti sudah terukur dalam satuan m
                    avg_dbh_m = avg_dbh_val
                print(f"      ✅ Sukses mendeteksi kolom DBH (Kolom: {col_dbh_idx})")
                print(f"         ├ Jumlah Sampel DBH      : {len(dbh_values)} pohon")
                print(f"         ├ Rata-rata DBH Mentah   : {avg_dbh_val:.3f}")
                print(f"         └ DBH Konversi (Meter)   : {avg_dbh_m:.5f} m")
        
        # Ekstraksi dan kalkulasi rata-rata Tinggi tanaman dengan Smart Unit Detection
        if col_height_idx is not None:
            height_values = pd.to_numeric(df_lidar.iloc[header_row + 1:, col_height_idx], errors='coerce').dropna()
            if len(height_values) > 0:
                avg_height_val = height_values.mean()
                if avg_height_val > 30.0:  # Berarti terukur dalam satuan cm (misal 368.5 cm)
                    avg_height_m = avg_height_val / 100.0
                else:                      # Berarti sudah terukur dalam m
                    avg_height_m = avg_height_val
                print(f"      ✅ Sukses mendeteksi kolom Tinggi (Kolom: {col_height_idx})")
                print(f"         ├ Jumlah Sampel Tinggi   : {len(height_values)} pohon")
                print(f"         ├ Rata-rata Tinggi Mentah: {avg_height_val:.3f}")
                print(f"         └ Tinggi Konversi (Meter): {avg_height_m:.5f} m")
                
    except Exception as e_lidar:
        print(f"      ⚠️ Gagal membaca data LiDAR: {e_lidar}. Menggunakan default fallback fisis.")
else:
    print(f"      ⚠️ File {lidar_path} tidak ditemukan. Menggunakan default fallback fisis.")

# =========================================================================
# FASE 2: PROYEKSI DAN BUFFER GPS SEAGRASS (EPSG:4326 -> EPSG:32749)
# =========================================================================
print("\n🌔 [FASE 2] PROSES GPS TITIK SAMPEL PADANG LAMUN (SEAGRASS)")

# Koordinat GPS hasil survei lapangan dari user (Lat, Lon)
coords_wgs84 = [
    [-8.441863777777783, 112.66851969444443],
    [-8.441860888888911, 112.66851847222222],
    [-8.441858777777796, 112.66851788888887],
    [-8.441858777777796, 112.6685167777778],
    [-8.441871277777778, 112.66851358333336]
]

# Transformasi koordinat GPS ke UTM 49S
target_epsg = "32749"
crs_str = f"EPSG:{target_epsg}"
transformer = Transformer.from_crs("EPSG:4326", crs_str, always_xy=True)

pts_utm = []
for lat, lon in coords_wgs84:
    x_utm, y_utm = transformer.transform(lon, lat)
    pts_utm.append(Point(x_utm, y_utm))

# Membangun poligon sebaran lamun via Convex Hull
from shapely.ops import unary_union
multi_point = unary_union(pts_utm)
seagrass_base_poly = multi_point.convex_hull

# Terapkan buffer 15 meter untuk meng-clip sel grid model secara presisi
seagrass_poly_buffered = seagrass_base_poly.buffer(15.0)
print(f"   ✅ Sukses memproses {len(coords_wgs84)} koordinat GPS Lamun!")
print(f"      ├ Convex Hull Area : {seagrass_base_poly.area:.2f} m^2")
print(f"      └ Buffered Area (15m): {seagrass_poly_buffered.area:.2f} m^2")

# =========================================================================
# FASE 3: MEMUAT JARING HIDRODINAMIKA D-FLOW FM
# =========================================================================
print("\n🌐 [FASE 3] MEMUAT JARING HIDRODINAMIKA D-FLOW FM")
default_regional_mesh = "Apex_Clipped_Preserved_Mesh_net.nc"
mesh_path = input(f"   📂 Path file NetCDF D-Flow FM Regional [{default_regional_mesh}]: ").strip().strip('\'"') or default_regional_mesh

if not os.path.exists(mesh_path):
    raise FileNotFoundError(f"❌ File jaring tidak ditemukan di folder kerja: {mesh_path}")

try:
    print(f"   ⏳ Mengekstrak topologi jaring dari {mesh_path}...")
    uds = xu.open_dataset(mesh_path)
    grid = uds.ugrid.grid if hasattr(uds, 'ugrid') else uds.grid
    node_x = np.ascontiguousarray(np.asarray(grid.node_x), dtype=np.double)
    node_y = np.ascontiguousarray(np.asarray(grid.node_y), dtype=np.double)
    
    face_nodes_raw = np.asarray(grid.face_node_connectivity)
    valid_mask = face_nodes_raw != -1
    nodes_per_face = np.ascontiguousarray(valid_mask.sum(axis=1), dtype=np.int32)
    face_nodes = np.ascontiguousarray(face_nodes_raw[valid_mask], dtype=np.int32)
    
    # Ekstraksi koordinat FLOW LINKS (xu, yu) di D-Flow FM (titik tengah edge jaring)
    xu_coords = np.ascontiguousarray(np.asarray(grid.edge_x), dtype=np.double)
    yu_coords = np.ascontiguousarray(np.asarray(grid.edge_y), dtype=np.double)
    
    print(f"   ✅ Jaring regional hidrodinamika berhasil dimuat:")
    print(f"      ├ Total Grid Nodes : {len(node_x):,} nodes")
    print(f"      └ Total Flow Links : {len(xu_coords):,} links (edge centers)")
except Exception as e:
    print(f"   ❌ Gagal membaca jaring: {e}")
    sys.exit(1)

# =========================================================================
# FASE 4: SETUP PARAMETER BIO-FISIK VEGETASI (KONSOLIDASI MANGROVE & LAMUN)
# =========================================================================
print("\n🌿 [FASE 4] KONFIGURASI PARAMETER BIO-FISIK VEGETASI (MALANG SELATAN)")

# Parameter Bio-Fisik untuk model Baptist (Formula 153) - Mangrove tunggal & Lamun
veg_params = {
    "Mangrove": {
        "id": 101,            # Trachytope ID
        "formula": 153,       # Baptist Formula ID
        "height": avg_height_m, # Menggunakan hasil kalkulasi Tinggi otomatis
        "diameter": avg_dbh_m,# Menggunakan hasil kalkulasi DBH otomatis
        "density": 1.25,      # Kerapatan tegakan rata-rata fisis (1.25 pohon/m^2) untuk mencegah over-damping
        "Cd": 1.5,            # Drag coefficient (high swell Samudra Hindia)
        "Cb": 40.0,           # Basin base Chezy murni (m^0.5/s)
        "color": "#15803d"    # Hijau tua
    },
    "Seagrass": {
        "id": 102,            # Trachytope ID
        "formula": 153,       # Baptist Formula ID
        "height": 0.40,       # Tinggi tanaman h_v (meter) - Twomey et al. 2020
        "diameter": 0.01,     # Diameter helai lamun (meter)
        "density": 150.0,     # Kerapatan helai N (daun/m^2)
        "Cd": 1.0,            # Drag coefficient
        "Cb": 45.0,           # Kekasaran dasar Chezy pasir (m^0.5/s)
        "color": "#22c55e"    # Hijau muda
    },
    "Coral": {
        "manning_n": coral_manning, # Koefisien Manning dinamis hasil input user
        "color": "#f43f5e"    # Coral/Merah muda
    }
}

# Hitung parameter kerapatan spasial ekuivalen: n = N * D (Sintaks resmi DDFM Appendix C.8.2.5)
for key in ["Mangrove", "Seagrass"]:
    veg_params[key]["n_equiv"] = veg_params[key]["density"] * veg_params[key]["diameter"]
    print(f"      ├ Kerapatan Spasial Ekuivalen {key:<8} (n = N * D) : {veg_params[key]['n_equiv']:.5f} 1/m")

# Membuat poligon spasial teoretis untuk Mangrove jika file SHP absen
x_mid, y_mid = np.mean(node_x), np.mean(node_y)

# Area Mangrove utuh gabungan di teluk Clungup
mangrove_poly = Polygon([
    (x_mid - 400, y_mid - 200), (x_mid - 100, y_mid - 200),
    (x_mid - 100, y_mid + 100), (x_mid - 400, y_mid + 100)
])

coral_poly = Polygon([
    (x_mid + 200, y_mid - 600), (x_mid + 500, y_mid - 600),
    (x_mid + 500, y_mid - 300), (x_mid + 200, y_mid - 300)
])

# =========================================================================
# FASE 5: AUTOMATION OF 4 SCENARIOS (BATCH SYSTEM)
# =========================================================================
print("\n🎬 [FASE 5] MENGEKSEKUSI PEMBUATAN 4 FOLDER SKENARIO SECARA BATCH")

# Definisi Matrix Skenario
scenarios_config = {
    "01_Skenario_Lengkap_CMC": {
        "mangrove": True,
        "seagrass": True,
        "coral": True,
        "desc": "Semua ekosistem aktif: Mangrove (101), Seagrass (102), dan Coral Flat (0.050)."
    },
    "02_Skenario_Tanpa_Vegetasi": {
        "mangrove": False,
        "seagrass": False,
        "coral": True,
        "desc": "Hanya Terumbu Karang yang aktif sebagai peredam lepas pantai. Mangrove & Seagrass non-aktif."
    },
    "03_Skenario_Tanpa_Karang": {
        "mangrove": True,
        "seagrass": True,
        "coral": False,
        "desc": "Hanya vegetasi pantai yang aktif: Mangrove & Seagrass. Terumbu Karang flat di-override pasir."
    },
    "04_Skenario_Baseline_Pasir": {
        "mangrove": False,
        "seagrass": False,
        "coral": False,
        "desc": "Kondisi terdegradasi tanpa pertahanan ekosistem: Hanya pasir Kriging background yang aktif."
    }
}

for s_name, config in scenarios_config.items():
    print(f"\n🚀 Memproses Skenario: '{s_name}'")
    print(f"   ↳ Deskripsi: {config['desc']}")
    
    # 1. Buat Sub-folder skenario khusus
    s_path = os.path.join(target_dir, s_name)
    os.makedirs(s_path, exist_ok=True)
    
    # 2. Hitung Interseksi Spasial Link Grid Berdasarkan Status Aktif Skenario
    link_trachy_id = np.full(len(xu_coords), 100)  # Default Background = ID 100 (Pasir)
    link_fraction = np.zeros(len(xu_coords))
    
    # Array penunjang parameter disipasi gelombang SWAN (.veg)
    link_height = np.zeros(len(xu_coords))
    link_diameter = np.zeros(len(xu_coords))
    link_density = np.zeros(len(xu_coords))
    link_Cd = np.zeros(len(xu_coords))
    
    for idx, (xu_val, yu_val) in enumerate(zip(xu_coords, yu_coords)):
        p = Point(xu_val, yu_val)
        
        # Cek interseksi spasial secara dinamis mengikuti status aktif skenario
        if config["mangrove"] and mangrove_poly.contains(p):
            link_trachy_id[idx] = veg_params["Mangrove"]["id"]
            link_fraction[idx] = 1.0
            link_height[idx] = veg_params["Mangrove"]["height"]
            link_diameter[idx] = veg_params["Mangrove"]["diameter"]
            link_density[idx] = veg_params["Mangrove"]["density"]
            link_Cd[idx] = veg_params["Mangrove"]["Cd"]
            
        elif config["seagrass"] and seagrass_poly_buffered.contains(p):
            link_trachy_id[idx] = veg_params["Seagrass"]["id"]
            link_fraction[idx] = 1.0
            link_height[idx] = veg_params["Seagrass"]["height"]
            link_diameter[idx] = veg_params["Seagrass"]["diameter"]
            link_density[idx] = veg_params["Seagrass"]["density"]
            link_Cd[idx] = veg_params["Seagrass"]["Cd"]

    valid_mask = link_fraction > 0.0
    valid_xu = xu_coords[valid_mask]
    valid_yu = yu_coords[valid_mask]
    valid_trachy = link_trachy_id[valid_mask]
    valid_frac = link_fraction[valid_mask]
    
    # 3. Ekspor vegetation.ttd
    ttd_file = os.path.join(s_path, "vegetation.ttd")
    try:
        with open(ttd_file, 'w') as f:
            f.write("* File: vegetation.ttd\n")
            f.write(f"* Katalog Definisi Trachytope untuk Skenario: {s_name}\n")
            f.write("* Format: TrachytopeNr   FormulaNr   hv      n_equiv   Cd      Cb\n")
            f.write("* -------------------------------------------------------------------------\n")
            
            if config["mangrove"]:
                m = veg_params["Mangrove"]
                f.write(f"{m['id']:<15} {m['formula']:<11} {m['height']:<7.3f} {m['n_equiv']:<9.5f} {m['Cd']:<7.2f} {m['Cb']:<.1f}   * Mangrove Clungup\n")
            
            if config["seagrass"]:
                s = veg_params["Seagrass"]
                f.write(f"{s['id']:<15} {s['formula']:<11} {s['height']:<7.3f} {s['n_equiv']:<9.5f} {s['Cd']:<7.2f} {s['Cb']:<.1f}   * Seagrass Lamun\n")
        print(f"      ├ Sukses mengeksor: {os.path.basename(ttd_file)}")
    except Exception as e:
        print(f"      ⚠️ Gagal mengekspor file .ttd: {e}")

    # 4. Ekspor vegetation.arl
    arl_file = os.path.join(s_path, "vegetation.arl")
    try:
        with open(arl_file, 'w') as f:
            f.write("* File: vegetation.arl\n")
            f.write(f"* Sebaran Spasial Trachytope Gabungan Skenario: {s_name}\n")
            f.write("* Format: xu                 yu                 zu_dummy  Trachytope_ID  Fraction\n")
            f.write("* ---------------------------------------------------------------------------------\n")
            for x, y, tr_id, fr in zip(valid_xu, valid_yu, valid_trachy, valid_frac):
                f.write(f"{x:<18.4f} {y:<18.4f} 0.0        {int(tr_id):<14} {fr:.2f}\n")
        print(f"      ├ Sukses mengeksor: {os.path.basename(arl_file)} ({len(valid_xu)} links)")
    except Exception as e:
        print(f"      ⚠️ Gagal mengekspor file .arl: {e}")

    # 5. Ekspor area_karang.pol (Jika Coral aktif dalam skenario)
    coral_pol_file = os.path.join(s_path, "area_karang.pol")
    if config["coral"]:
        try:
            x_coords, y_coords = coral_poly.exterior.coords.xy
            n_points = len(x_coords)
            with open(coral_pol_file, 'w') as f:
                f.write("coral_boundary_clungup\n")
                f.write(f"{n_points:<6} 2\n")
                for x, y in zip(x_coords, y_coords):
                    f.write(f" {x:<16.4f} {y:<16.4f}\n")
            print(f"      ├ Sukses mengeksor: {os.path.basename(coral_pol_file)}")
        except Exception as e:
            print(f"      ⚠️ Gagal mengekspor file .pol Coral: {e}")

    # 6. Ekspor friction_fields.ini
    friction_ini_file = os.path.join(s_path, "friction_fields.ini")
    try:
        with open(friction_ini_file, 'w') as f:
            f.write("[General]\n")
            f.write("fileVersion         = 2.02\n")
            f.write("fileType            = iniField\n\n")
            
            f.write("# 1. Background Friction dari Pasir Hasil Kriging (Gelar pertama)\n")
            f.write("[Parameter]\n")
            f.write("quantity            = frictionCoefficient\n")
            f.write(f"dataFile            = {os.path.basename(bg_xyz_path)}\n")
            f.write("dataFileType        = sample\n")
            f.write("interpolationMethod = triangulation\n")
            f.write("operand             = override\n")
            f.write("frictionType        = Manning\n")
            
            if config["coral"]:
                f.write("\n# 2. Ditimpa (override) oleh poligon Karang di area spesifik (CMC reef flat)\n")
                f.write("[Parameter]\n")
                f.write("quantity            = frictionCoefficient\n")
                f.write(f"dataFile            = {os.path.basename(coral_pol_file)}\n")
                f.write("dataFileType        = polygon\n")
                f.write("interpolationMethod = constant\n")
                f.write(f"value               = {veg_params['Coral']['manning_n']:.4f}\n")
                f.write("operand             = override\n")
                f.write("frictionType        = Manning\n")
        print(f"      ├ Sukses mengeksor: {os.path.basename(friction_ini_file)}")
    except Exception as e:
        print(f"      ⚠️ Gagal mengekspor berkas .ini terpadu: {e}")

    # 7. Ekspor DWaves_Ecosystem_Properties.veg untuk D-Waves SWAN
    swan_veg_file = os.path.join(s_path, "DWaves_Ecosystem_Properties.veg")
    try:
        veg_link_mask = link_trachy_id > 100
        veg_xu = xu_coords[veg_link_mask]
        veg_yu = yu_coords[veg_link_mask]
        veg_h = link_height[veg_link_mask]
        veg_d = link_diameter[veg_link_mask]
        veg_n = link_density[veg_link_mask]
        veg_cd = link_Cd[veg_link_mask]
        
        with open(swan_veg_file, 'w') as f:
            f.write("* SWAN VEGETATION SPECS FILE\n")
            f.write("* Generated automatically via APEX Vegetation Coupler\n")
            f.write(f"VEGETATION {len(veg_xu)}\n")
            for x, y, h, d, n, cd in zip(veg_xu, veg_yu, veg_h, veg_d, veg_n, veg_cd):
                f.write(f"{h:.3f} {d:.4f} {n:.1f} {cd:.2f}\n")
        print(f"      └ Sukses mengeksor: {os.path.basename(swan_veg_file)} ({len(veg_xu)} links)")
    except Exception as e:
        print(f"      ⚠️ Gagal mengekspor file .veg SWAN: {e}")

# =========================================================================
# FASE 8: VISUALISASI INTEGRATIF GABUNGAN SKENARIO
# =========================================================================
print("\n🎨 [FASE 8] MERENDER GRAFIK SEBARAN SPASIAL EKOSISTEM KOMPLET")
try:
    plt.close('all')
    
    triangles_list = []
    idx_p = 0
    for n in nodes_per_face:
        poly_nodes = face_nodes[idx_p: idx_p + n]
        idx_p += n
        for i in range(1, n - 1):
            triangles_list.append([poly_nodes[0], poly_nodes[i], poly_nodes[i + 1]])
    triang_full = mtri.Triangulation(node_x, node_y, np.asarray(triangles_list))

    fig, ax = plt.subplots(figsize=(12, 10), dpi=150)
    ax.set_aspect('equal', adjustable='box')
    ax.set_box_aspect(1)
    ax.set_facecolor('#b0d2ec')  # Warna air laut lepas

    # Plot Jaring dasar hidrodinamika terwarnai berdasarkan Skenario Lengkap (ID 101, 102, 103)
    node_combined_plot = np.full(len(node_x), 100)
    for idx, (x, y) in enumerate(zip(node_x, node_y)):
        p = Point(x, y)
        if mangrove_poly.contains(p):
            node_combined_plot[idx] = 101
        elif seagrass_poly_buffered.contains(p):
            node_combined_plot[idx] = 102
        elif coral_poly.contains(p):
            node_combined_plot[idx] = 103

    cf = ax.tripcolor(triang_full, node_combined_plot, cmap=plt.cm.Accent, alpha=0.85, zorder=2)
    cbar = plt.colorbar(cf, ax=ax, label="ID Kelas Tata Guna Lahan / Ekosistem Spasial (CMC Clungup)")
    cbar.set_ticks([100, 101, 102, 103])
    cbar.set_ticklabels([
        "100: Background (Pasir)", 
        "101: Mangrove (Trachytope)", 
        "102: Seagrass Lamun (Trachytope)",
        "103: Coral Flat (Constant Manning Friction Override)"
    ])

    # Plot Poligon Batas Ekosistem
    gpd.GeoSeries([mangrove_poly]).boundary.plot(ax=ax, color=veg_params["Mangrove"]["color"], linewidth=2.2, zorder=5)
    gpd.GeoSeries([seagrass_poly_buffered]).boundary.plot(ax=ax, color=veg_params["Seagrass"]["color"], linewidth=2.2, zorder=5)
    gpd.GeoSeries([coral_poly]).boundary.plot(ax=ax, color=veg_params["Coral"]["color"], linewidth=2.2, zorder=5)

    ax.set_title("Ecosystem-based Coastal Defense Configuration (CMC Clungup)\nPeta Sebaran Lokasi Skenario Lengkap (Komparasi Batch 4 Skenario Sukses)", fontweight='bold', fontsize=12, pad=12)
    ax.set_xlabel("Easting Proyeksi (meter UTM-49S)", fontsize=10)
    ax.set_ylabel("Northing Proyeksi (meter UTM-49S)", fontsize=10)
    ax.grid(True, linestyle=':', alpha=0.5)

    legend_elements = [
        mlines.Line2D([], [], color=veg_params["Mangrove"]["color"], lw=2.0, label=f'Mangrove (ID 101) - h={avg_height_m:.3f}m, D={avg_dbh_m:.4f}m, N={veg_params["Mangrove"]["density"]}pohon/m2'),
        mlines.Line2D([], [], color=veg_params["Seagrass"]["color"], lw=2.0, label=f'Seagrass Lamun (ID 102) - h={veg_params["Seagrass"]["height"]}m, buffer=15m'),
        mlines.Line2D([], [], color=veg_params["Coral"]["color"], lw=2.0, label=f'Coral Reef Flat (Constant Override n = {veg_params["Coral"]["manning_n"]:.3f})'),
    ]
    ax.legend(handles=legend_elements, loc='upper right', framealpha=0.95, edgecolor='gray', fontsize=9)


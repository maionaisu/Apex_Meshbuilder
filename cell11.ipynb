def export_ttd(out_path: str,
               mang_params: dict, sea_params: dict,
               has_mang: bool, has_sea: bool,
               mang_id: int = 101, sea_id: int = 102) -> str:
    """
    Generate vegetation_def.ttd — HANYA katalog sifat fisik vegetasi.
    TIDAK ada koordinat (X, Y) di dalam file ini.

    Format Baptist 2007 Formula 154:
        TrachytopeNr  FormulaCode  h_v  N×D  C_D  C_b

    Keterangan parameter:
        h_v   = tinggi vegetasi (m)
        N×D   = stem density (1/m²) × stem diameter (m) = projected area per unit area (1/m)
        C_D   = drag coefficient (-)
        C_b   = Chezy bed roughness (m^0.5/s)
    """
    filename = "vegetation_def.ttd"
    filepath = os.path.join(out_path, filename)

    with open(filepath, 'w') as f:
        f.write("* vegetation_def.ttd\n")
        f.write("* Katalog Definisi Trachytope Vegetasi — Baptist Formula 154 (2007)\n")
        f.write("* Format: TrachytopeNr  FormulaCode  h_v  N*D  C_D  C_b\n")
        f.write("*         (TIDAK ada koordinat di file ini — lihat .arl untuk distribusi spasial)\n")
        f.write("* ─────────────────────────────────────────────────────────────────────────\n")

        if has_mang:
            nd_mang = mang_params['N'] * mang_params['D']   # N/m² × m = 1/m
            f.write(
                f"{mang_id:<8} 154    "
                f"{mang_params['h_v']:<8.3f} "
                f"{nd_mang:<10.5f} "
                f"{mang_params['C_D']:<6.2f} "
                f"{mang_params['C_b']:<6.1f}"
                f"  * Mangrove Forest (ID {mang_id})\n"
            )

        if has_sea:
            nd_sea = sea_params['N'] * sea_params['D']
            f.write(
                f"{sea_id:<8} 154    "
                f"{sea_params['h_v']:<8.3f} "
                f"{nd_sea:<10.5f} "
                f"{sea_params['C_D']:<6.2f} "
                f"{sea_params['C_b']:<6.1f}"
                f"  * Seagrass/Lamun (ID {sea_id})\n"
            )

    logger.info(f"[TTD] Ditulis: {filename}")
    return filename


def export_arl(out_path: str,
               edge_x: np.ndarray, edge_y: np.ndarray,
               mang_polygon, sea_polygon,
               has_mang: bool, has_sea: bool,
               mang_id: int = 101, sea_id: int = 102) -> tuple:
    """
    Generate vegetation_map.arl — Peta distribusi spasial vegetasi pada EDGE/LINK.

    Proses:
    1. PIP (Point-in-Polygon) antara edge midpoints dan polygon mangrove → ID 101
    2. PIP antara edge midpoints dan polygon lamun → ID 102
    3. Overlay: mangrove prioritas jika ada overlap dengan lamun

    Format per baris: edge_x  edge_y  0.0  TrachytopeNr  Fraction

    Returns:
        (filename, n_mang_edges, n_sea_edges)
    """
    filename = "vegetation_map.arl"
    filepath = os.path.join(out_path, filename)

    # PIP untuk setiap vegetasi class
    mask_mang = edges_in_polygon_fast(edge_x, edge_y, mang_polygon) if has_mang else np.zeros(len(edge_x), dtype=bool)
    mask_sea  = edges_in_polygon_fast(edge_x, edge_y, sea_polygon)  if has_sea  else np.zeros(len(edge_x), dtype=bool)

    # Resolve overlap: mangrove prioritas (ekosistem dominan)
    mask_sea = mask_sea & ~mask_mang

    n_mang = int(mask_mang.sum())
    n_sea  = int(mask_sea.sum())
    total  = n_mang + n_sea

    with open(filepath, 'w') as f:
        f.write("* vegetation_map.arl\n")
        f.write("* Distribusi Spasial Trachytope Vegetasi pada Edge/Link Jaring D-Flow FM\n")
        f.write("* KOORDINAT = titik tengah edge/netlink (bukan node, bukan cell center)\n")
        f.write(f"* Total edges bervegetasi: {total} "
                f"(Mangrove={n_mang}, Lamun={n_sea})\n")
        f.write("* Format: edge_x           edge_y           edge_z  TrachytopeNr  Fraction\n")
        f.write("* ─────────────────────────────────────────────────────────────────────────\n")

        if has_mang and n_mang > 0:
            for x, y in zip(edge_x[mask_mang], edge_y[mask_mang]):
                f.write(f"{x:<18.4f} {y:<18.4f} 0.0  {mang_id:<5} 1.00\n")

        if has_sea and n_sea > 0:
            for x, y in zip(edge_x[mask_sea], edge_y[mask_sea]):
                f.write(f"{x:<18.4f} {y:<18.4f} 0.0  {sea_id:<5} 1.00\n")

    logger.info(f"[ARL] Ditulis: {filename} | Mangrove={n_mang}, Lamun={n_sea} edges")
    return filename, n_mang, n_sea


def export_xyz(out_path: str,
               edge_x: np.ndarray, edge_y: np.ndarray,
               manning_val: float,
               downsample: int = 5) -> str:
    """
    Generate sediment_manning.xyz — Titik sample kekasaran Manning background (pasir).

    Menggunakan koordinat edge sebagai sample points distribusi spasial.
    D-Flow FM akan melakukan triangulation interpolasi dari titik-titik ini.

    Jika Cell 9 menghasilkan variabel val_node_final di globals(), nilai tsb
    digunakan sebagai D50 → Manning (Manning-Strickler: n = D50^(1/6) / 21.1).
    Jika tidak ada, gunakan nilai uniform dari slider.

    Downsample: tiap N edge diambil 1 untuk mengurangi ukuran file .xyz.
    """
    filename = "sediment_manning.xyz"
    filepath = os.path.join(out_path, filename)

    # Cek apakah Cell 9 menyediakan data D50 terinterpolasi
    val_node = globals().get('val_node_final', None)
    node_x_g = globals().get('node_x', None)
    node_y_g = globals().get('node_y', None)

    if val_node is not None and node_x_g is not None:
        # Konversi D50 (mm) → Manning n via Manning-Strickler
        # n = D50_m^(1/6) / 21.1 dimana D50_m dalam meter
        # val_node dalam mm → /1000 → meter
        d50_meter = np.where(val_node > 0, val_node / 1000.0, 1e-4)
        manning_arr = d50_meter ** (1.0 / 6.0) / 21.1

        # Subsample untuk efisiensi penulisan file
        idx_s = np.arange(0, len(node_x_g), downsample)
        with open(filepath, 'w') as f:
            for i in idx_s:
                f.write(f"{node_x_g[i]:.4f}    {node_y_g[i]:.4f}    {manning_arr[i]:.6f}\n")
        logger.info(f"[XYZ] Manning dari Cell 9 D50 data: {len(idx_s)} sample points")
    else:
        # Fallback: nilai uniform dari slider dengan distribusi spasial edge mesh
        idx_s = np.arange(0, len(edge_x), downsample)
        with open(filepath, 'w') as f:
            for x, y in zip(edge_x[idx_s], edge_y[idx_s]):
                f.write(f"{x:.4f}    {y:.4f}    {manning_val:.6f}\n")
        logger.info(f"[XYZ] Manning uniform {manning_val:.4f} ({len(idx_s)} sample points)")

    return filename


def export_pol(out_path: str, coral_polygon, polygon_name: str = "coral_flat") -> str:
    """
    Generate area_karang.pol — Polygon batas terumbu karang (Delft3D .pol format).

    Format Delft3D polygon:
        polygon_name
        n_points  2
        x1  y1
        x2  y2
        ...
    """
    filename = "area_karang.pol"
    filepath = os.path.join(out_path, filename)

    if coral_polygon is None or coral_polygon.is_empty:
        # Tulis file kosong dengan comment jika tidak ada data karang
        with open(filepath, 'w') as f:
            f.write("* area_karang.pol\n")
            f.write("* Tidak ada data terumbu karang yang ditentukan\n")
        logger.warning("[POL] Polygon karang kosong — file .pol ditulis tanpa data.")
        return filename

    # Handle MultiPolygon: ambil semua sub-polygon
    polys = list(coral_polygon.geoms) if hasattr(coral_polygon, 'geoms') else [coral_polygon]

    with open(filepath, 'w') as f:
        f.write(f"* area_karang.pol — Batas Terumbu Karang (Lyzenga Classification)\n")
        for pidx, poly in enumerate(polys):
            coords = list(poly.exterior.coords)
            name = polygon_name if len(polys) == 1 else f"{polygon_name}_{pidx+1}"
            f.write(f"{name}\n")
            f.write(f"{len(coords)} 2\n")
            for x, y in coords:
                f.write(f" {x:<16.4f} {y:<16.4f}\n")

    logger.info(f"[POL] Ditulis: {filename} ({len(polys)} polygon(s))")
    return filename


def export_ini(out_path: str,
               xyz_filename: str, pol_filename: str,
               coral_manning: float,
               has_sand: bool, has_coral: bool) -> str:
    """
    Generate kekasaran_spasial.ini — IniFieldFile untuk D-Flow FM.

    Logika layering:
    1. Blok 1 (base layer): sedimen pasir dari .xyz via triangulation → seluruh domain
    2. Blok 2 (override): terumbu karang dari .pol via constant → menimpa zona karang

    Catatan: IniFieldFile ini dipanggil di MDU [geometry] → IniFieldFile = ...
    TERPISAH dari [trachytopes] — vegetasi dan kekasaran dasar adalah dua sistem berbeda.
    """
    filename = "kekasaran_spasial.ini"
    filepath = os.path.join(out_path, filename)

    with open(filepath, 'w') as f:
        f.write("[General]\n")
        f.write("    fileVersion         = 2.02\n")
        f.write("    fileType            = iniField\n\n")

        if has_sand:
            f.write("# ── BASE LAYER: Manning Sedimen Pasir (Triangulation dari .xyz) ──────\n")
            f.write("[Parameter]\n")
            f.write("    quantity            = frictionCoefficient\n")
            f.write(f"    dataFile            = {xyz_filename}\n")
            f.write("    dataFileType        = sample\n")
            f.write("    interpolationMethod = triangulation\n")
            f.write("    operand             = override\n")
            f.write("    frictionType        = Manning\n\n")

        if has_coral:
            f.write("# ── OVERRIDE LAYER: Manning Terumbu Karang (Constant dari .pol) ──────\n")
            f.write("[Parameter]\n")
            f.write("    quantity            = frictionCoefficient\n")
            f.write(f"    dataFile            = {pol_filename}\n")
            f.write("    dataFileType        = polygon\n")
            f.write("    interpolationMethod = constant\n")
            f.write(f"    value               = {coral_manning:.4f}\n")
            f.write("    operand             = override\n")
            f.write("    frictionType        = Manning\n")

    logger.info(f"[INI] Ditulis: {filename}")
    return filename



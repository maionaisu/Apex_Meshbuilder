def patch_mdu(dfm_dir: str, scenario_name: str,
              grid_fn: str, ini_fn: str, ttd_fn: str, arl_fn: str,
              ref_date_yyyymmdd: str, sim_duration_s: int,
              ext_bnd_fn: str, has_veg: bool) -> str:
    """Tulis flow_model.mdu dengan template yang sudah dikoreksi."""
    mdu_path = os.path.join(dfm_dir, "flow_model.mdu")
    content = MDU_TEMPLATE.format(
        grid_filename       = grid_fn,
        ini_field_filename  = ini_fn,
        trt_rou_flag        = "Y" if has_veg else "N",
        trt_def_filename    = ttd_fn if has_veg else "",
        trt_map_filename    = arl_fn if has_veg else "",
        ref_date_yyyymmdd   = ref_date_yyyymmdd,
        sim_duration_seconds= sim_duration_s,
        ext_bnd_filename    = ext_bnd_fn,
    )
    with open(mdu_path, 'w') as f:
        f.write(content)
    logger.info("[MDU] flow_model.mdu di-patch.")
    return "flow_model.mdu"


def patch_mdw(wave_dir: str, scenario_name: str,
              ref_date_yyyy_mm_dd: str,
              wave_grid: str, wave_dep: str,
              veg_file: str, tpar_ref: str,
              bound_coords_utm: list) -> str:
    """
    Tulis wave_model.mdw.
    bound_coords_utm: [[x1,y1], [x2,y2], ...] dalam UTM
    """
    mdw_path = os.path.join(wave_dir, "wave_model.mdw")

    x_utm = [c[0] for c in bound_coords_utm]
    y_utm = [c[1] for c in bound_coords_utm]

    # Build CondSpecAtDist lines (kumulatif jarak antar support nodes)
    cond_lines = []
    accum = 0.0
    for i in range(len(x_utm)):
        if i > 0:
            accum += np.hypot(x_utm[i] - x_utm[i-1], y_utm[i] - y_utm[i-1])
        cond_lines.append(f"    CondSpecAtDist = {accum:.2f}")

    content = MDW_TEMPLATE.format(
        scenario_name       = scenario_name,
        ref_date_yyyy_mm_dd = ref_date_yyyy_mm_dd,
        boundary_tpar_ref   = tpar_ref,
        wave_grid_filename  = wave_grid,
        wave_dep_filename   = wave_dep,
        veg_file            = veg_file,
        bound_start_x       = x_utm[0],
        bound_start_y       = y_utm[0],
        bound_end_x         = x_utm[-1],
        bound_end_y         = y_utm[-1],
        cond_spec_lines     = "\n".join(cond_lines),
    )
    with open(mdw_path, 'w') as f:
        f.write(content)
    logger.info("[MDW] wave_model.mdw di-patch.")
    return "wave_model.mdw"


def write_dimr(base_dir: str, sim_duration_s: int) -> str:
    """Tulis dimr_config.xml ke root skenario."""
    dimr_path = os.path.join(base_dir, "dimr_config.xml")
    content = DIMR_TEMPLATE.format(
        creation_date_iso    = datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
        sim_duration_seconds = sim_duration_s,
    )
    with open(dimr_path, 'w') as f:
        f.write(content)
    logger.info("[DIMR] dimr_config.xml ditulis.")
    return "dimr_config.xml"


def write_bat(base_dir: str, scenario_name: str) -> str:
    """Tulis run_dimr.bat ke root skenario."""
    bat_path = os.path.join(base_dir, "run_dimr.bat")
    bat = (
        "@echo off\n"
        "echo ============================================================\n"
        "echo   APEX NEXUS MODEL RUNNER\n"
        f"echo   Skenario: {scenario_name}\n"
        "echo   Module  : D-Flow FM + D-Waves (Coupled DIMR)\n"
        "echo ============================================================\n\n"
        "set OMP_NUM_THREADS=4\n"
        "set OMP_NUM_THREADS_SWAN=4\n\n"
        'call "C:\\Program Files\\Deltares\\D-HYDRO Suite 2023.02 1D2D\\x64\\bin\\run_dimr.bat" dimr_config.xml\n\n'
        "echo.\necho Simulasi Selesai!\npause\n"
    )
    with open(bat_path, 'w') as f:
        f.write(bat)
    logger.info("[BAT] run_dimr.bat ditulis.")
    return "run_dimr.bat"



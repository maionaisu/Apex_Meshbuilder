    print(f"   ├ Skenario 2         : [No Vegetation] ─► {os.path.join(target_dir, '02_Skenario_Tanpa_Vegetasi')}")
    print(f"   ├ Skenario 3         : [No Coral Reef] ─► {os.path.join(target_dir, '03_Skenario_Tanpa_Karang')}")
    print(f"   └ Skenario 4         : [Baseline Sand] ─► {os.path.join(target_dir, '04_Skenario_Baseline_Pasir')}")

def _normalize_path(raw: str, fallback_dir: str = "") -> str:
    """Strip quotes/whitespace dari path input. Cek fallback_dir jika tidak ada."""
    p = raw.strip().strip('"\'')
    if not p:
        return os.getcwd()
    if not os.path.exists(p) and fallback_dir:
        fb = os.path.join(fallback_dir, os.path.basename(p))
        if os.path.exists(fb):
            return fb
    return p


def load_mesh_edges_from_nc(net_nc_path: str, epsg_code: str) -> tuple:
    """
    Ekstrak koordinat titik tengah EDGE (link/netlink) dari _net.nc Delft3D-FM.

    Urutan prioritas:
    1. xugrid grid.edge_x / grid.edge_y (paling akurat, sudah midpoint)
    2. xarray: NetLink_nodes/mesh2d_edge_nodes → hitung midpoint manual
    
    PENTING: .arl membutuhkan koordinat EDGE (titik tengah penghubung antar sel),
    bukan cell center (FlowElem_x/y) ataupun node. Ini yang membedakan Cell 11
    dari pendekatan lain yang memakai node/cell center.

    Returns:
        edge_x (np.ndarray): koordinat X UTM titik tengah edge
        edge_y (np.ndarray): koordinat Y UTM titik tengah edge  
        n_edges (int): jumlah edge
    """
    if not os.path.exists(net_nc_path):
        raise FileNotFoundError(f"File _net.nc tidak ditemukan: {net_nc_path}")

    # ── Attempt 1: xugrid ─────────────────────────────────────────────
    if HAS_XUGRID:
        try:
            uds = xu.open_dataset(net_nc_path)
            grid = uds.ugrid.grid if hasattr(uds, 'ugrid') else uds.grids[0]
            edge_x = np.ascontiguousarray(np.asarray(grid.edge_x), dtype=np.float64)
            edge_y = np.ascontiguousarray(np.asarray(grid.edge_y), dtype=np.float64)
            n_e = len(edge_x)
            logger.info(f"[MESH] xugrid: {n_e:,} edge midpoints berhasil diekstrak.")
            return edge_x, edge_y, n_e
        except Exception as e_xu:
            logger.warning(f"[MESH] xugrid gagal ({e_xu}), lanjut ke xarray fallback...")

    # ── Attempt 2: xarray manual midpoint ────────────────────────────
    ds = xr.open_dataset(net_nc_path)

    # Deteksi koordinat node
    X_KEYS = ["NetNode_x", "mesh2d_node_x", "node_x", "FlowElem_xcc"]
    Y_KEYS = ["NetNode_y", "mesh2d_node_y", "node_y", "FlowElem_ycc"]
    node_x = next((ds[k].values.astype(np.float64) for k in X_KEYS if k in ds.variables), None)
    node_y = next((ds[k].values.astype(np.float64) for k in Y_KEYS if k in ds.variables), None)

    if node_x is None or node_y is None:
        raise KeyError(
            f"Variabel koordinat node tidak ditemukan.\n"
            f"Tersedia: {list(ds.variables.keys())}"
        )

    # Deteksi edge/link connectivity
    LINK_KEYS = ["NetLink_nodes", "mesh2d_edge_nodes", "mesh2d_link_nodes", "NetLink"]
    link_var = next((k for k in LINK_KEYS if k in ds.variables), None)

    if link_var is None:
        raise KeyError(
            f"Variabel konektivitas edge/link tidak ditemukan.\n"
            f"Tersedia: {list(ds.variables.keys())}"
        )

    link_nodes  = ds[link_var].values
    start_index = int(ds[link_var].attrs.get("start_index", 1))

    # Hitung midpoints: edge_i = 0.5 × (node[link[0]-si] + node[link[1]-si])
    n0 = link_nodes[:, 0].astype(int) - start_index
    n1 = link_nodes[:, 1].astype(int) - start_index

    # Guard: cegah out-of-bounds index
    valid = (n0 >= 0) & (n1 >= 0) & (n0 < len(node_x)) & (n1 < len(node_x))
    n0, n1 = n0[valid], n1[valid]

    edge_x = 0.5 * (node_x[n0] + node_x[n1])
    edge_y = 0.5 * (node_y[n0] + node_y[n1])
    n_e    = len(edge_x)

    logger.info(f"[MESH] xarray fallback: {n_e:,} edge midpoints dihitung ({valid.sum()}/{len(link_nodes)} valid).")
    return edge_x, edge_y, n_e


def parse_seagrass_points(text: str, epsg_code: str) -> Polygon:
    """
    Parse teks koordinat Lat/Lon titik batas padang lamun menjadi Shapely Polygon (UTM).

    Mendukung berbagai format:
      - "lat, lon\\nLat, Lon\\n..." (satu pasangan per baris)
      - "[[lat, lon], [lat, lon]]" (JSON array-like)
      - Campuran separator koma/spasi/newline

    Deteksi otomatis urutan Lat/Lon vs Lon/Lat berdasarkan rentang geografis Indonesia.
    Jika < 4 titik → ConvexHull. Jika ≥ 4 → Polygon langsung, fallback ConvexHull jika invalid.

    Returns: shapely.geometry.Polygon dalam CRS epsg_code (UTM meter)
    """
    # Ekstrak semua angka float dari teks
    numbers = [float(x) for x in re.findall(
        r'[-+]?\d+\.?\d*(?:[eE][-+]?\d+)?', text
    )]

    if len(numbers) < 6:
        raise ValueError(
            f"Titik lamun terlalu sedikit ({len(numbers)//2} pasang). "
            f"Butuh minimal 3 titik untuk membentuk polygon."
        )

    if len(numbers) % 2 != 0:
        numbers = numbers[:-1]

    pairs = [(numbers[i], numbers[i + 1]) for i in range(0, len(numbers), 2)]

    # Auto-deteksi urutan: nilai lat Indonesia ≈ -6 s/d -11, lon ≈ 95 s/d 141
    col0 = [p[0] for p in pairs]
    col1 = [p[1] for p in pairs]

    if all(-90 <= v <= 90 for v in col0) and all(90 <= v <= 180 for v in col1):
        # Format: (lat, lon)
        lat_lon_pairs = pairs
    elif all(-90 <= v <= 90 for v in col1) and all(90 <= v <= 180 for v in col0):
        # Format: (lon, lat) — swap
        lat_lon_pairs = [(p[1], p[0]) for p in pairs]
    else:
        # Default: anggap (lat, lon)
        lat_lon_pairs = pairs
        logger.warning("[SEAGRASS] Format koordinat ambigu, mengasumsikan (lat, lon).")

    transformer = Transformer.from_crs("EPSG:4326", epsg_code, always_xy=True)
    utm_pts = [transformer.transform(lon, lat) for lat, lon in lat_lon_pairs]

    if len(utm_pts) < 4:
        poly = MultiPoint(utm_pts).convex_hull
    else:
        try:
            poly = Polygon(utm_pts)
            if not poly.is_valid:
                poly = MultiPoint(utm_pts).convex_hull
        except Exception:
            poly = MultiPoint(utm_pts).convex_hull

    area_m2 = poly.area
    logger.info(f"[SEAGRASS] Polygon UTM terbentuk: {len(utm_pts)} titik, area={area_m2:.1f} m²")
    return poly


def load_mangrove_polygon(shp_path: str, epsg_code: str):
    """
    Load mangrove polygon dari .shp, reproject ke epsg_code, return unary_union.
    Returns: shapely.geometry (Polygon/MultiPolygon) atau None jika gagal.
    """
    if not shp_path or not os.path.exists(shp_path):
        logger.warning(f"[MANGROVE] File .shp tidak ditemukan: {shp_path}")
        return None

    try:
        gdf = gpd.read_file(shp_path)
        if gdf.crs is not None and str(gdf.crs).upper() != epsg_code.upper():
            gdf = gdf.to_crs(epsg_code)
        union = unary_union(gdf.geometry.values)
        logger.info(f"[MANGROVE] .shp dimuat: {len(gdf)} feature, union area={union.area:.1f} m²")
        return union
    except Exception as e:
        logger.error(f"[MANGROVE] Gagal load .shp: {e}")
        return None


def edges_in_polygon(edge_x: np.ndarray, edge_y: np.ndarray,
                     polygon) -> np.ndarray:
    """
    Vectorized Point-in-Polygon menggunakan shapely STRtree.
    Returns boolean mask: True jika edge berada di dalam polygon.
    O(E log P) untuk STRtree query.
    """
    if polygon is None or polygon.is_empty:
        return np.zeros(len(edge_x), dtype=bool)

    # Build STRtree dari polygon (untuk query efisien)
    tree = STRtree([polygon])

    # Buat array Point dari edge coordinates
    pts = [Point(x, y) for x, y in zip(edge_x, edge_y)]

    mask = np.zeros(len(pts), dtype=bool)
    for i, pt in enumerate(pts):
        result = tree.query(pt, predicate='within')
        if len(result) > 0:
            mask[i] = True

    return mask


def edges_in_polygon_fast(edge_x: np.ndarray, edge_y: np.ndarray,
                          polygon) -> np.ndarray:
    """
    Faster bulk PIP via STRtree.query_bulk (shapely >= 1.8).
    Falls back to element-wise if unavailable.
    """
    if polygon is None or polygon.is_empty:
        return np.zeros(len(edge_x), dtype=bool)

    try:
        # shapely >= 2.0: vectorized approach
        from shapely import points, contains_xy
        result = contains_xy(polygon, edge_x, edge_y)
        return result.astype(bool)
    except (ImportError, AttributeError):
        pass

    # shapely < 2.0: STRtree
    tree = STRtree([Point(x, y) for x, y in zip(edge_x, edge_y)])
    idxs = tree.query(polygon, predicate='contains')
    mask = np.zeros(len(edge_x), dtype=bool)
    mask[idxs] = True
    return mask



def _set_mesh_status(msg: str, color: str = '#64748b') -> None:
    html_mesh_status.value = f'<b style="color:{color};font-size:12px">{msg}</b>'

def _set_build_status(msg: str, color: str = '#64748b') -> None:
    html_build_status.value = f'<b style="color:{color};font-size:12px">{msg}</b>'


def on_load_mesh_clicked(b):
    """
    STEP 1: Load _net.nc, ekstrak edge midpoints, tampilkan statistik.
    Setelah sukses → aktifkan btn_build.
    """
    btn_load_mesh.disabled = True
    btn_load_mesh.description = '⏳  Memuat _net.nc...'
    btn_build.disabled = True
    _set_mesh_status('⏳  Membaca topologi jaring dari _net.nc...', '#f59e0b')

    STATE['mesh_loaded'] = False

    with out_mesh_log:
        clear_output(wait=True)
        try:
            net_nc_path = _normalize_path(w_netnc.value, _normalize_path(w_outdir.value))
            epsg_code   = w_epsg.value.strip() or DEFAULT_EPSG

            if not os.path.exists(net_nc_path):
                raise FileNotFoundError(f"File _net.nc tidak ditemukan:\n  {net_nc_path}")

            print(f"⏳ Membaca: {os.path.basename(net_nc_path)}")
            print(f"   CRS: {epsg_code}")
            print(f"   Method: {'xugrid' if HAS_XUGRID else 'xarray (manual midpoint)'}")

            edge_x, edge_y, n_e = load_mesh_edges_from_nc(net_nc_path, epsg_code)

            STATE['edge_x']      = edge_x
            STATE['edge_y']      = edge_y
            STATE['n_edges']     = n_e
            STATE['mesh_loaded'] = True

            print(f"\n✅ Mesh berhasil dimuat:")
            print(f"   Edge midpoints (link centers): {n_e:,}")
            print(f"   X range: [{edge_x.min():.1f}, {edge_x.max():.1f}] m")
            print(f"   Y range: [{edge_y.min():.1f}, {edge_y.max():.1f}] m")
            print(f"\n   → Koordinat ini yang akan digunakan untuk file .arl (bukan node/cell center)")

            btn_load_mesh.description = f'✅  Mesh Dimuat ({n_e:,} edges)'
            btn_build.disabled        = False
            _set_mesh_status(f'✅  {n_e:,} edge midpoints diekstrak. Klik STEP 2 untuk build.', '#16a34a')

        except Exception as e:
            _set_mesh_status(f'❌ Error load mesh: {e}', '#dc2626')
            print(f"\n❌ ERROR:\n{e}")
            traceback.print_exc()
            btn_load_mesh.disabled    = False
            btn_load_mesh.description = '▶  STEP 1: Load _net.nc & Ekstrak Edge Midpoints (Coba Lagi)'


btn_load_mesh.on_click(on_load_mesh_clicked)


def on_build_clicked(b):
    """
    STEP 2: Build complete scenario.
    Urutan: polygon prep → PIP → .ttd → .arl → .xyz → .pol → .ini → .mdu → .mdw → DIMR → .bat
    """
    btn_build.disabled = True
    btn_build.description = '⏳  Building scenario...'
    btn_load_mesh.disabled = True
    _set_build_status('⏳  Membangun skenario lengkap...', '#f59e0b')

    with out_build_log:
        clear_output(wait=True)
        try:
            if not STATE['mesh_loaded'] or STATE['edge_x'] is None:
                raise RuntimeError("Mesh belum dimuat — klik STEP 1 terlebih dahulu.")

            edge_x   = STATE['edge_x']
            edge_y   = STATE['edge_y']
            epsg_code = w_epsg.value.strip() or DEFAULT_EPSG
            out_base  = _normalize_path(w_outdir.value)
            scenario  = w_scenario.value.strip().replace(" ", "_") or "Scenario_01"

            # ── Direktori ─────────────────────────────────────────────
            scen_dir = os.path.join(out_base, "scenarios", scenario)
            dfm_dir  = os.path.join(scen_dir, "dflowfm")
            wave_dir = os.path.join(scen_dir, "waves")
            for d in [dfm_dir, wave_dir]:
                os.makedirs(d, exist_ok=True)
            print(f"📁 Direktori skenario: {scen_dir}\n")

            # ── Parse tanggal ─────────────────────────────────────────
            try:
                t_start = datetime.strptime(w_t_start.value.strip(), "%Y-%m-%d")
                t_end   = datetime.strptime(w_t_end.value.strip(), "%Y-%m-%d") \
                              .replace(hour=23, minute=59, second=59)
                sim_dur_s         = int((t_end - t_start).total_seconds())
                ref_date_yyyymmdd = t_start.strftime("%Y%m%d")
                ref_date_str      = t_start.strftime("%Y-%m-%d")
            except ValueError as e_t:
                raise ValueError(f"Format tanggal salah (YYYY-MM-DD): {e_t}")

            # ─────────────────────────────────────────────────────────
            print("=" * 68)
            print("  MODUL 1: PERSIAPAN POLYGON VEGETASI")
            print("=" * 68)

            # Seagrass polygon dari textarea
            STATE['sea_polygon'] = None
            if chk_sea.value:
                sea_text = w_seagrass_pts.value.strip()
                if sea_text:
                    try:
                        STATE['sea_polygon'] = parse_seagrass_points(sea_text, epsg_code)
                        print(f"✅ Polygon Lamun: {len(sea_text.strip().splitlines())} titik input, "
                              f"area={STATE['sea_polygon'].area:.1f} m²")
                    except Exception as e_sea:
                        print(f"⚠️  Polygon lamun gagal dibuat: {e_sea}")
                        STATE['sea_polygon'] = None
                else:
                    print("⚠️  Titik lamun kosong — lamun dilewati.")

            # Mangrove polygon dari .shp
            STATE['mang_polygon'] = None
            if chk_mang.value:
                mang_shp_path = _normalize_path(w_mang_shp.value, out_base)
                if mang_shp_path and os.path.exists(mang_shp_path):
                    STATE['mang_polygon'] = load_mangrove_polygon(mang_shp_path, epsg_code)
                    if STATE['mang_polygon'] is not None:
                        print(f"✅ Polygon Mangrove dari .shp: area={STATE['mang_polygon'].area:.1f} m²")
                    else:
                        print(f"⚠️  Gagal load .shp mangrove: {mang_shp_path}")
                else:
                    print("⚠️  Path mangrove .shp kosong atau tidak ditemukan — mangrove dilewati.")

            # Coral polygon
            STATE['coral_polygon'] = MOCK_CORAL_POLYGON
            coral_shp = _normalize_path(w_coral_shp.value, out_base)
            if coral_shp and os.path.exists(coral_shp):
                try:
                    gdf_c = gpd.read_file(coral_shp).to_crs(epsg_code)
                    STATE['coral_polygon'] = unary_union(gdf_c.geometry.values)
                    print(f"✅ Polygon Karang dari .shp: area={STATE['coral_polygon'].area:.1f} m²")
                except Exception as e_cor:
                    print(f"⚠️  Gagal load coral .shp ({e_cor}) — menggunakan mock polygon.")
            else:
                print(f"ℹ️  Coral .shp tidak disediakan — menggunakan mock polygon Clungup.")

            has_mang  = chk_mang.value and (STATE['mang_polygon'] is not None)
            has_sea   = chk_sea.value  and (STATE['sea_polygon']  is not None)
            has_veg   = has_mang or has_sea
            has_sand  = chk_sand.value
            has_coral = chk_coral.value and (STATE['coral_polygon'] is not None)

            # ─────────────────────────────────────────────────────────
            print(f"\n{'=' * 68}")
            print("  MODUL 2: VEGETASI TRACHYTOPES (.TTD + .ARL)")
            print("=" * 68)
            print("  ℹ️  .ttd = sifat fisik saja | .arl = distribusi spasial edge | INDEPENDEN")

            mang_params = {
                'h_v': sl_mang_h.value, 'N': sl_mang_N.value,
                'D': sl_mang_D.value,   'C_D': sl_mang_CD.value, 'C_b': sl_mang_Cb.value
            }
            sea_params = {
                'h_v': sl_sea_h.value,  'N': sl_sea_N.value,
                'D': sl_sea_D.value,    'C_D': sl_sea_CD.value,  'C_b': sl_sea_Cb.value
            }

            ttd_fn = export_ttd(dfm_dir, mang_params, sea_params, has_mang, has_sea)
            print(f"  ✅ {ttd_fn} — katalog fisik ditulis")

            arl_fn, n_mang_e, n_sea_e = export_arl(
                dfm_dir, edge_x, edge_y,
                STATE['mang_polygon'], STATE['sea_polygon'],
                has_mang, has_sea
            )
            print(f"  ✅ {arl_fn} — {n_mang_e} mangrove + {n_sea_e} lamun edges")
            if (has_mang and n_mang_e == 0):
                print("  ⚠️  PERHATIAN: 0 edges dalam polygon mangrove — polygon mungkin terlalu kecil vs resolusi mesh.")
            if (has_sea and n_sea_e == 0):
                print("  ⚠️  PERHATIAN: 0 edges dalam polygon lamun — polygon mungkin terlalu kecil vs resolusi mesh.")

            # Export .veg untuk SWAN
            veg_filename = "DWaves_Ecosystem_Properties.veg"
            veg_path = os.path.join(wave_dir, veg_filename)
            with open(veg_path, 'w') as fv:
                fv.write("* SWAN VEGETATION FILE — Generated by APEX NEXUS\n")
                if has_mang:
                    fv.write(f"VEGETATION {n_mang_e}\n")
                    for _ in range(n_mang_e):
                        fv.write(f"{mang_params['h_v']:.3f} {mang_params['D']:.4f} "
                                 f"{mang_params['N']:.1f} {mang_params['C_D']:.2f}\n")
                if has_sea:
                    fv.write(f"VEGETATION {n_sea_e}\n")
                    for _ in range(n_sea_e):
                        fv.write(f"{sea_params['h_v']:.3f} {sea_params['D']:.4f} "
                                 f"{sea_params['N']:.1f} {sea_params['C_D']:.2f}\n")
            print(f"  ✅ {veg_filename} — SWAN vegetation file ditulis")

            # ─────────────────────────────────────────────────────────
            print(f"\n{'=' * 68}")
            print("  MODUL 3: BED ROUGHNESS INIFIELD (.XYZ + .POL + .INI)")
            print("=" * 68)

            xyz_fn = export_xyz(dfm_dir, edge_x, edge_y, sl_sand_n.value)
            print(f"  ✅ {xyz_fn} — kekasaran Manning sedimen")

            pol_fn = export_pol(dfm_dir, STATE['coral_polygon'])
            print(f"  ✅ {pol_fn} — polygon batas karang")

            ini_fn = export_ini(
                dfm_dir, xyz_fn, pol_fn,
                sl_coral_n.value, has_sand, has_coral
            )
            print(f"  ✅ {ini_fn} — IniFieldFile (sedimen + karang overlay)")

            # ─────────────────────────────────────────────────────────
            print(f"\n{'=' * 68}")
            print("  MODUL 4: PATCH MDU / MDW / DIMR")
            print("=" * 68)

            dfm_grid_fn = w_net_nc_dfm.value.strip() or "Apex_Orthogonalized_ARGH_net.nc"
            ext_bnd_fn  = "DWaves_Macro_Boundary.ext"

            mdu_fn = patch_mdu(
                dfm_dir, scenario, dfm_grid_fn,
                ini_fn, ttd_fn, arl_fn,
                ref_date_yyyymmdd, sim_dur_s,
                ext_bnd_fn, has_veg
            )
            print(f"  ✅ {mdu_fn} — MDU dikonfigurasi (IniFieldFile + Trachytopes)")

            # Ambil koordinat boundary dari Cell 10 STATE jika tersedia
            bnd_coords_raw = globals().get('STATE', {}).get('boundary_coords', [])
            if not bnd_coords_raw:
                # Fallback: bounding box domain selatan (Malang Selatan)
                bnd_coords_raw = [[112.117, -8.317], [112.120, -8.970],
                                   [113.125, -8.966], [113.122, -8.291]]
                print("  ℹ️  Koordinat boundary diambil dari fallback (Cell 10 STATE tidak tersedia).")

            transformer_utm = Transformer.from_crs("EPSG:4326", epsg_code, always_xy=True)
            bnd_utm = [transformer_utm.transform(c[0], c[1]) for c in bnd_coords_raw]

            mdw_fn = patch_mdw(
                wave_dir, scenario, ref_date_str,
                w_macro_grd.value.strip(), w_macro_dep.value.strip(),
                veg_filename, "DWaves_Macro_Boundary.tpar",
                bnd_utm
            )
            print(f"  ✅ {mdw_fn} — MDW dikonfigurasi (vegetasi + boundary)")

            dimr_fn = write_dimr(scen_dir, sim_dur_s)
            print(f"  ✅ {dimr_fn}")

            bat_fn = write_bat(scen_dir, scenario)
            print(f"  ✅ {bat_fn}")

            # ─────────────────────────────────────────────────────────
            STATE['build_done'] = True
            _set_build_status(
                f'🚀 SELESAI — Skenario "{scenario}" berhasil dibangun di: {scen_dir}',
                '#16a34a'
            )
            btn_load_mesh.disabled = False
            btn_build.disabled     = False
            btn_build.description  = '⚙️  Build Complete Scenario & Generate All Files'

            print(f"\n{'=' * 68}")
            print(f"🚀 TAHAP 11 SELESAI — Skenario: {scenario}")
            print(f"   dflowfm/: {ttd_fn}, {arl_fn}, {xyz_fn}, {pol_fn}, {ini_fn}, {mdu_fn}")
            print(f"   waves/  : {mdw_fn}, {veg_filename}")
            print(f"   root/   : {dimr_fn}, {bat_fn}")
            print(f"   Dir     : {scen_dir}")
            print("=" * 68)
            print("\n📋 RINGKASAN HIERARKI FILE DFM:")
            print("  flow_model.mdu")
            print(f"    [geometry]     IniFieldFile → {ini_fn}")
            print(f"      {ini_fn} → {xyz_fn} (base Manning, triangulation)")
            print(f"                    → {pol_fn}  (karang override)")
            print(f"    [trachytopes]  TrtDef → {ttd_fn} (physical properties)")
            print(f"                   TrtL   → {arl_fn}  (spatial distribution)")
            print(f"    [ext forcing]  ExtForceFileNew → {ext_bnd_fn}")

        except Exception as e:
            _set_build_status(f'❌ Error build: {e}', '#dc2626')
            print(f"\n❌ ERROR:\n{e}")
            traceback.print_exc()
            btn_load_mesh.disabled = False
            btn_build.disabled     = False
            btn_build.description  = '⚙️  Build (Coba Lagi)'


btn_build.on_click(on_build_clicked)



# [Code Cell 6.5] - SURGICAL HYBRID MESH RECOVERY (AGGRESSIVE TRENCH & FILL)
import os
import numpy as np
import matplotlib.pyplot as plt
import geopandas as gpd
from shapely.geometry import Polygon, box, MultiPolygon, LineString, GeometryCollection
from shapely.geometry.polygon import orient
from pyproj import Transformer
from meshkernel import GeometryList, OrthogonalizationParameters, ProjectToLandBoundaryOption, DeleteMeshOption
import dfm_tools as dfmt

print("🎯 [TAHAP 6.5] SURGICAL HYBRID MESH (AGGRESSIVE TRENCH & FILL)")

# =========================================================================
# 1. STATE VALIDATION & PARAMETER NANO-AOI
# =========================================================================
mk = globals().get('mk')
if mk is None:
    raise RuntimeError("❌ [FATAL] MeshKernel (mk) tidak ditemukan! Harap jalankan Cell 6 terlebih dahulu.")

target_res = globals().get('target_res', 20.0)
target_crs = globals().get('target_epsg', '32749')

print("\n📍 Menentukan Batas Eksterior Operasi (Surgical Nano-AOI)...")
print("   [Opsi 1]: Masukkan file Shapefile (.shp) dari area garis merah Anda.")
print("   [Opsi 2]: Kosongkan untuk menggunakan Bounding Box manual (Input WGS84).")

shp_path = input("   Path file Shapefile Area Fokus (Kosongkan jika manual): ").strip().strip('\'"').replace('"', '')

if shp_path and os.path.exists(shp_path):
    print("   -> Membaca Shapefile Custom Zone...")
    gdf_focus = gpd.read_file(shp_path)
    if gdf_focus.crs is None or gdf_focus.crs.to_epsg() != int(target_crs):
        gdf_focus = gdf_focus.to_crs(f"EPSG:{target_crs}")
    nano_aoi = gdf_focus.unary_union
else:
    print("   -> Menggunakan Bounding Box Manual (Koordinat Geografis - WGS84).")
    try:
        n_val = float(input("   N (North/Utara)  [Contoh: -8.432044] : ") or -8.432044)
        s_val = float(input("   S (South/Selatan) [Contoh: -8.448676] : ") or -8.448676)
        e_val = float(input("   E (East/Timur)    [Contoh: 112.679882] : ") or 112.679882)
        w_val = float(input("   W (West/Barat)    [Contoh: 112.656971] : ") or 112.656971)
        
        print(f"   ⏳ Mengonversi koordinat WGS84 ke EPSG:{target_crs}...")
        transformer = Transformer.from_crs("EPSG:4326", f"EPSG:{target_crs}", always_xy=True)
        minx_utm, miny_utm = transformer.transform(w_val, s_val)
        maxx_utm, maxy_utm = transformer.transform(e_val, n_val)
        
        nano_aoi = box(minx_utm, miny_utm, maxx_utm, maxy_utm)
        print(f"   ✅ Konversi berhasil: Bounding Box diproyeksikan ke skala meter.")
    except Exception as e:
        print(f"   ⚠️ Input manual gagal ({e}). Fallback ke area Micro AOI utama.")
        nano_aoi = globals().get('micro_poly_utm')
        if nano_aoi is None:
            raise RuntimeError("❌ micro_poly_utm tidak ditemukan di memori!")

skirt_width = float(input("\n   Berapa meter ketebalan Triangular Skirt dari coastline? [30.0]: ") or 30.0)

# =========================================================================
# 2. GEOMETRY PREPARATION (GLOBAL TRENCH & OVERLAP FILL ZONES)
# =========================================================================
print(f"\n🪄 Menyiapkan Kanvas Geometri Skirt (Ketebalan {skirt_width}m)...")
gdf_coast = globals().get('gdf_coast')
if gdf_coast is None or gdf_coast.empty:
    raise RuntimeError("❌ gdf_coast (Garis Pantai) tidak ditemukan di memori!")

land_union = gdf_coast.unary_union

# 1. Skirt Zone Murni (Untuk menggali parit secara AGRESIF)
skirt_zone_global = land_union.buffer(skirt_width).difference(land_union)
skirt_zone_aoi = skirt_zone_global.intersection(nano_aoi)

# 2. Fill Zone (Di-buffer 1.5x Resolusi untuk memastikan tumpahan segitiga menutup lubang parit agresif)
fill_zone_aoi = skirt_zone_aoi.buffer(target_res * 1.5, join_style=1)

def extract_polygons(geom):
    polys = []
    if geom.geom_type == 'Polygon': polys.append(geom)
    elif geom.geom_type == 'MultiPolygon': polys.extend(list(geom.geoms))
    elif geom.geom_type == 'GeometryCollection':
        for g in geom.geoms: polys.extend(extract_polygons(g))
    return polys

# [ENTERPRISE FIX]: EKSTRAKSI MURNI
def create_safe_geom_list(poly):
    if poly is None or poly.is_empty: return None
    
    p_clean = poly.buffer(0).simplify(0.5, preserve_topology=True)
    if p_clean.geom_type in ['MultiPolygon', 'GeometryCollection']:
        polys = [g for g in p_clean.geoms if g.geom_type == 'Polygon']
        if not polys: return None
        p_clean = max(polys, key=lambda a: a.area)
        
    p_safe = orient(p_clean, sign=1.0)
    x_coords, y_coords = p_safe.exterior.coords.xy
    
    clean_x, clean_y = [x_coords[0]], [y_coords[0]]
    for i in range(1, len(x_coords)):
        if np.hypot(x_coords[i] - clean_x[-1], y_coords[i] - clean_y[-1]) > 0.1:
            clean_x.append(x_coords[i])
            clean_y.append(y_coords[i])
            
    if np.hypot(clean_x[-1] - clean_x[0], clean_y[-1] - clean_y[0]) > 0.1:
        clean_x.append(clean_x[0])
        clean_y.append(clean_y[0])
    else:
        clean_x[-1] = clean_x[0]
        clean_y[-1] = clean_y[0]

    return GeometryList(np.ascontiguousarray(clean_x, dtype=np.double), 
                        np.ascontiguousarray(clean_y, dtype=np.double))

# =========================================================================
# 3. MESH INJECTION (PURE NATIVE INJECTION)
# =========================================================================
print(f"\n🏗️ TAHAP 1: Trenching (Menggali parit pesisir secara AGRESIF)...")
del_count = 0
for p in extract_polygons(skirt_zone_aoi):
    if p.area < 25.0: continue
    gl_del = create_safe_geom_list(p)
    if gl_del:
        try:
            # [CRITICAL FIX]: Memaksa penggunaan INSIDE_AND_INTERSECTED agar Quads benar-benar musnah!
            del_opt = 1 
            if hasattr(DeleteMeshOption, 'INSIDE_AND_INTERSECTED'):
                del_opt = DeleteMeshOption.INSIDE_AND_INTERSECTED
            mk.mesh2d_delete(geometry_list=gl_del, delete_option=del_opt, invert_deletion=False)
            del_count += 1
        except Exception: pass
print(f"   ✅ Parit pesisir selesai digali di {del_count} zona utama.")

print(f"\n🏗️ TAHAP 2: Concrete Pouring (Mengecor Segitiga Delaunay Murni)...")
fill_count = 0
for p in extract_polygons(fill_zone_aoi):
    if p.area < 25.0: continue
    gl_fill = create_safe_geom_list(p)
    if gl_fill:
        try:
            mk.mesh2d_make_triangular_mesh_from_polygon(gl_fill)
            fill_count += 1
        except Exception as e:
            print(f"   ⚠️ Warning pada cetakan: {e}")
print(f"   ✅ Segitiga Skirt berhasil dicor di {fill_count} zona utama.")

# =========================================================================
# 4. OVERLAP STITCHING & RELAXATION
# =========================================================================
print("\n🧘 TAHAP 3: Menjahit Overlap (Triangles ke Quads) & Deep Relaxation...")

# Jarak jahit 0.6x Resolusi: Cukup kuat untuk menyatukan overlap tepian, 
# tapi tidak akan merusak integritas segitiga di bagian dalam.
merge_dist = target_res * 0.6  

try:
    minx, miny, maxx, maxy = nano_aoi.bounds
    pad = target_res * 5.0
    
    x_merge = np.ascontiguousarray([minx-pad, maxx+pad, maxx+pad, minx-pad, minx-pad], dtype=np.double)
    y_merge = np.ascontiguousarray([miny-pad, miny-pad, maxy+pad, maxy+pad, miny-pad], dtype=np.double)
    gl_merge = GeometryList(x_merge, y_merge)
    
    if hasattr(mk, 'mesh2d_merge_nodes_with_merging_distance'):
        mk.mesh2d_merge_nodes_with_merging_distance(gl_merge, merge_dist)
    else:
        try: mk.mesh2d_merge_nodes(geometry_list=gl_merge, merging_distance=merge_dist)
        except TypeError: mk.mesh2d_merge_nodes(gl_merge, merge_dist)
except Exception as e:
    print(f"   ⚠️ Stitching warning: {e}")

# RELAXATION CASCADE
print("   -> Menjalankan Deep Relaxation (Anti-Bug Signature)...")
ortho_params = OrthogonalizationParameters()
ortho_params.number_of_iterations = 500

empty_x = np.ascontiguousarray([], dtype=np.double)
empty_y = np.ascontiguousarray([], dtype=np.double)
empty_gl = GeometryList(empty_x, empty_y)

success_relax = False

if not success_relax:
    try:
        mk.mesh2d_compute_orthogonalization(
            project_to_land_boundary_option=ProjectToLandBoundaryOption.DO_NOT_PROJECT_TO_LANDBOUNDARY,
            orthogonalization_parameters=ortho_params,
            geometry_list_polygon=empty_gl
        )
        success_relax = True
    except Exception: pass

if not success_relax:
    try:
        mk.mesh2d_compute_orthogonalization(ortho_params, empty_gl)
        success_relax = True
    except Exception: pass

if not success_relax:
    try:
        mk.mesh2d_compute_orthogonalization(ortho_params)
        success_relax = True
    except Exception: pass

if success_relax:
    print("   ✅ Deep Relaxation berhasil diterapkan secara sempurna.")
else:
    print("   ⚠️ [WARNING] Minor relaxation bypass: Silakan abaikan, Cell 7 akan melakukan healing final.")

# =========================================================================
# 5. SURGICAL DIAGNOSTICS VISUALIZATION
# =========================================================================
print("\n🎨 Memvisualisasikan Hasil Transisi (The Triangular Skirt)...")
try:
    plt.figure(figsize=(12, 10))
    ax = plt.gca()
    ax.set_aspect('equal')

    mesh2d = mk.mesh2d_get()
    
    if mesh2d.node_x.size > 0:
        mesh2d.plot_edges(ax=ax, color='#3B82F6', linewidth=0.3, label='Mesh Topology')
    else:
        print("   ⚠️ [ERROR] Mesh kosong! Generasi gagal di tingkat C++.")

    gpd.GeoSeries([nano_aoi]).boundary.plot(ax=ax, color='red', linestyle='--', linewidth=2.0, label='Surgical Limit (Red Line)')
    
    if not skirt_zone_aoi.is_empty:
        gpd.GeoSeries([skirt_zone_aoi]).plot(ax=ax, color='#F59E0B', alpha=0.3, label=f'{skirt_width}m Triangular Skirt')
    
    if gdf_coast is not None:
        if any(gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])):
            gdf_coast.boundary.plot(ax=ax, color='#16A34A', linewidth=1.5, label='Actual Coastline')
        else:
            gdf_coast.plot(ax=ax, color='#16A34A', linewidth=1.5, label='Actual Coastline')

    bounds = nano_aoi.bounds
    ax.set_xlim(bounds[0]-1500, bounds[2]+1500)
    ax.set_ylim(bounds[1]-1500, bounds[3]+1500)

    plt.title(f"Zonal Hybrid Meshing (Aggressive Trench & Fill)\nCoastline -> {skirt_width}m Segitiga -> Quads Laut Lepas", fontweight='bold', pad=15)
    plt.legend(loc='upper right')
    plt.grid(True, linestyle=':', alpha=0.6)
    plt.show()
except Exception as e:
    print(f"⚠️ Render visualisasi ditunda: {e}")

globals()['mk'] = mk
print("✅ [CELL 6.5 SELESAI] Triangular Skirt Berhasil Ditenun. Lanjut ke Cell 7 (Gunakan Conservative Mode!).")

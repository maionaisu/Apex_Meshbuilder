import pandas as pd
import geopandas as gpd
import matplotlib.pyplot as plt
import matplotlib.lines as mlines
import rasterio
from rasterio.features import shapes
from shapely.ops import unary_union
from shapely.geometry import Point, Polygon, MultiPolygon, box, shape
from pyproj import Transformer
from scipy.spatial import cKDTree

print("🪸 [TAHAP 10.5 - v7.2] PURE LOCAL CPU LYZENGA VECTORIZER & EXT COUPLER")
print("=========================================================================")
print("Mengekstraksi terumbu karang dari Sentinel-2 Lokal menggunakan CPU Anda,")
print("mengasimilasi batimetri .xyz lokal raksasa secara stream-filtering,")
print("membangun poligon *.pol Delft3D, serta langsung menyuntikkan parameter")
print("kekasaran Manning terumbu karang ke dalam berkas .ext eksisting Anda.")
print("=========================================================================\n")

# =========================================================================
# FASE 0: INTERAKTIF CLI UNTUK SETUP DIREKTORI OUTPUT & FILE INPUT
# =========================================================================
print("📂 [FASE 0] SETUP FILE INPUT, OUTPUT, DAN SISTEM PROYEKSI")

# Input CLI untuk folder output target ekspor
target_dir = input("   📂 Tentukan folder output ekspor file [Default: direktori aktif]: ").strip().strip('\'"').replace('"', '')
if not target_dir:
    target_dir = os.getcwd()
os.makedirs(target_dir, exist_ok=True)

# Input CLI untuk file .ext eksisting yang akan dimodifikasi
default_ext = "pantai_selatan_jawir.ext"
existing_ext_path = input(f"   📂 Masukkan path berkas .ext eksisting Anda [{default_ext}]: ").strip().strip('\'"').replace('"', '') or default_ext

# Input CLI untuk EPSG Proyeksi UTM lokal (Misal: 32749 untuk UTM Zone 49S Malang Selatan)
default_epsg = 32749
epsg_input = input(f"   🌐 Masukkan EPSG Proyeksi UTM Target Proyeksi Anda [Default: {default_epsg}]: ").strip()
target_epsg = int(epsg_input) if epsg_input else default_epsg

# Input CITRA SENTINEL-2 LOKAL (.tif)
default_s2_file = "sentinel2_clungup.tif"
s2_path = input(f"   🛰️  Masukkan path file Citra Sentinel-2 Lokal (.tif) [{default_s2_file}]: ").strip().strip('\'"').replace('"', '') or default_s2_file

# Band Mapping di Citra .tif Lokal (Masukkan nomor band, 1-based index)
print("      Konfigurasi nomor band di dalam file GeoTIFF Anda:")
band_blue = int(input("      ├ Nomor Band Biru (Blue) [Default: 1] : ") or 1)
band_green = int(input("      ├ Nomor Band Hijau (Green) [Default: 2] : ") or 2)
band_nir = int(input("      ├ Nomor Band Inframerah Dekat (NIR) [Default: 3] : ") or 3)

# Input Batimetri Lokal (.xyz)
default_bathy_file = "batimetri.xyz"
bathy_path = input(f"   📂 Masukkan path file Batimetri Lokal (.xyz) [{default_bathy_file}]: ").strip().strip('\'"').replace('"', '') or default_bathy_file

# Tanya pengguna apakah ingin menerapkan filter spasial atau meloloskan poligon asli utuh
print("\n🎛️  [KONTROL FILTER SPASIAL DAN AKURASI GEOMETRIS]")
apply_filter_morfologi = input("   ❓ Terapkan penggabungan piksel morfologi (Morphological Clustering)? [y/N]: ").strip().lower() == 'y'
apply_coast_clipping = input("   ❓ Terapkan pemotongan & offset batas garis pantai (Coastline Clipping)? [y/N]: ").strip().lower() == 'y'
apply_area_filter = input("   ❓ Terapkan penyaring luas poligon minimum (Minimum Area Filter)? [y/N]: ").strip().lower() == 'y'

# Input baru untuk pembatasan spasial wilayah dekat pantai (Nearshore Limit)
apply_nearshore_limit = input("   ❓ Batasi terumbu karang hanya di zona dekat pantai (Nearshore Limit)? [Y/n]: ").strip().lower() != 'n'

# Muat parameter input jika filter tertentu diaktifkan
coastline_path = ""
coastline_offset = 0.0
nearshore_distance = 500.0

if apply_coast_clipping or apply_nearshore_limit:
    coastline_path = input(f"   🌊 Masukkan path berkas GIS Garis Pantai (.shp) [pantai_selatan_jawir_coast.shp]: ").strip().strip('\'"').replace('"', '') or "pantai_selatan_jawir_coast.shp"

if apply_coast_clipping:
    offset_input = input(f"   📏 Tentukan jarak aman minimal karang menjauhi garis pantai (meter) [Default: 2.0 m]: ").strip()
    coastline_offset = float(offset_input) if offset_input else 2.0

if apply_nearshore_limit:
    nearshore_dist_input = input(f"   📏 Tentukan lebar zona nearshore dari pantai (meter) [Default: 500.0 m]: ").strip()
    nearshore_distance = float(nearshore_dist_input) if nearshore_dist_input else 500.0

min_area_limit = 0.0
if apply_area_filter:
    min_area_input = input(f"   📐 Batas minimum luas poligon karang yang dipertahankan (m^2) [Default: 10.0]: ").strip()
    min_area_limit = float(min_area_input) if min_area_input else 10.0

jarak_cluster = 2.0
if apply_filter_morfologi:
    cluster_input = input(f"   🔗 Jarak penggabungan toleransi piksel bersebelahan (meter) [Default: 2.0]: ").strip()
    jarak_cluster = float(cluster_input) if cluster_input else 2.0

# Default batas koordinat Clungup jika file citra tidak ada/gagal dimuat
d_n = -8.414480; d_s = -8.470305; d_e = 112.717001; d_w = 112.618484
n_val, s_val, e_val, w_val = d_n, d_s, d_e, d_w
lat_center = (n_val + s_val) / 2.0
lon_center = (e_val + w_val) / 2.0
# =========================================================================
# FASE 1: AUTO-DOWNLOAD CITRA SENTINEL-2 (IF MISSING) & MEMUAT GEOTIFF LOKAL
# =========================================================================
print("\n🛰️ [FASE 1] MEMBACA & VALIDASI DATA CITRA SENTINEL-2")

# [BUGBUSTER SPECIAL v7.1] - AUTO-DOWNLOADER DARI GEE JIKA BERKAS TIDAK ADA
if not os.path.exists(s2_path):
    print(f"   ⚠️ Berkas citra lokal '{os.path.basename(s2_path)}' tidak ditemukan!")
    auto_download = input("   ❓ Apakah Anda ingin mengunduh citra Sentinel-2 otomatis dari GEE untuk AOI Clungup? [Y/n]: ").strip().lower() != 'n'
    if auto_download:
        print("   ⏳ Menghubungkan ke Google Earth Engine secara otomatis...")
        try:
            import ee
            import geemap
            
            # Inisialisasi/Autentikasi GEE otomatis
            try:
                ee.Initialize(project='gee-maionaisu')
            except Exception:
                print("      ├ Autentikasi GEE diperlukan di komputer Anda...")
                ee.Authenticate()
                ee.Initialize(project='gee-maionaisu')
                
            print("   ✅ Sukses terhubung ke GEE dengan Project: 'gee-maionaisu'")
            print("   ⏳ Membangun komposit citra median bebas awan pesisir Clungup (2023-2026)...")
            
            # Mendefinisikan area kueri (Bounding Box) kartesian planar
            bbox_ee = ee.Geometry.Rectangle([w_val, s_val, e_val, n_val], 'EPSG:4326', False)
            
            def mask_s2_clouds_ee(image_ee):
                qa = image_ee.select('QA60')
                mask = qa.bitwiseAnd(1 << 10).eq(0).And(qa.bitwiseAnd(1 << 11).eq(0))
                return image_ee.updateMask(mask).divide(10000)

            # Query koleksi Sentinel-2
            s2_collection = (ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
                             .filterBounds(bbox_ee)
                             .filterDate('2023-01-01', '2026-05-28')
                             .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 30))
                             .map(mask_s2_clouds_ee))
            
            image_composite = s2_collection.median().select(['B2', 'B3', 'B8']).clip(bbox_ee)
            
            print(f"   ⏳ Memulai pengunduhan grid spasial 10m ke: {os.path.basename(s2_path)}...")
            geemap.ee_export_image(
                image_composite,
                filename=s2_path,
                scale=10,
                region=bbox_ee,
                file_per_band=False
            )
            print(f"   ✅ Sukses mengunduh dan mengonfigurasi citra satelit lokal Anda!")
        except Exception as e_dl:
            print(f"   ❌ Gagal mengunduh otomatis dari GEE: {e_dl}")
            print("      Program akan dialihkan menggunakan data sintetis fallback.")

s2_loaded = False
if os.path.exists(s2_path):
    try:
        src_s2 = rasterio.open(s2_path)
        print(f"   ✅ Berkas GeoTIFF lokal sukses dimuat: {os.path.basename(s2_path)}")
        print(f"      ├ Dimensi Citra  : {src_s2.width} x {src_s2.height} piksel")
        print(f"      ├ Jumlah Band    : {src_s2.count}")
        print(f"      └ Sistem Proyeksi: {src_s2.crs}")
        
        # Ekstrak bounding box citra secara otomatis dalam format geografis (WGS84)
        bounds = src_s2.bounds
        if src_s2.crs and src_s2.crs.to_epsg() != 4326:
            transformer_bounds = Transformer.from_crs(src_s2.crs, "EPSG:4326", always_xy=True)
            w_val, s_val = transformer_bounds.transform(bounds.left, bounds.bottom)
            e_val, n_val = transformer_bounds.transform(bounds.right, bounds.top)
        else:
            w_val, s_val, e_val, n_val = bounds.left, bounds.bottom, bounds.right, bounds.top
            
        lat_center = (n_val + s_val) / 2.0
        lon_center = (e_val + w_val) / 2.0
        print(f"   ℹ️  Bounding Box Spasial Citra Terdeteksi otomatis:")
        print(f"      [W: {w_val:.6f}, S: {s_val:.6f}, E: {e_val:.6f}, N: {n_val:.6f}]")
        s2_loaded = True
    except Exception as e_s2_load:
        print(f"   ⚠️ Gagal memuat file citra lokal: {e_s2_load}.")
        s2_loaded = False

# Fallback batas koordinat Clungup jika file citra tidak ada/gagal dimuat
if not s2_loaded:
    print("   ⚠️ Mengaktifkan fallback koordinat default Clungup...")
    w_val, s_val, e_val, n_val = d_w, d_s, d_e, d_n
    lat_center = (n_val + s_val) / 2.0
    lon_center = (e_val + w_val) / 2.0
# =========================================================================
# FASE 1.5: INGESTIKASI & INTERPOLASI BATIMETRI LOKAL (.XYZ) SECARA LOKAL PADA CPU
# =========================================================================
print("\n📊 [FASE 1.5] PROSES INTERPOLASI BATIMETRI LOKAL SECARA Vektor-CPU")

df_bathy_filtered = pd.DataFrame()
if os.path.exists(bathy_path):
    try:
        print(f"   ⏳ Mendeteksi sistem koordinat & format pemisah berkas batimetri {os.path.basename(bathy_path)}...")
        is_bathy_geom_geographic = True
        sample_pts = []
        sep_detected = r'\s+'  # Default jika berformat spasi atau tab
        
        # [BUGFIX SOLVED v7.2] - DETEKSI SEPARATOR DINAMIS UNTUK C-ENGINE PANDAS
        # C-engine tidak menerima regex komposit, jadi kita membaca baris pertama secara eksplisit
        # untuk menentukan pemisah kolom tunggal (koma, tab, atau spasi murni).
        with open(bathy_path, 'r') as f_detect:
            first_line = f_detect.readline()
            if ',' in first_line:
                sep_detected = ','
                print("      ├ Tipe pemisah kolom terdeteksi: KOMA (,)")
            elif '\t' in first_line:
                sep_detected = '\t'
                print("      ├ Tipe pemisah kolom terdeteksi: TAB (\\t)")
            else:
                sep_detected = r'\s+'
                print("      ├ Tipe pemisah kolom terdeteksi: SPASI / WHITE SPACE (\\s+)")
            
            # Kembalikan pointer pembacaan ke baris awal (0)
            f_detect.seek(0)
            for line in f_detect:
                line_clean = line.replace(',', ' ').strip()
                parts = line_clean.split()
                if len(parts) >= 3:
                    try:
                        x_sample = float(parts[0])
                        y_sample = float(parts[1])
                        sample_pts.append((x_sample, y_sample))
                        if len(sample_pts) >= 10: break
                    except ValueError: continue
        
        if sample_pts:
            mean_x = np.mean([p[0] for p in sample_pts])
            mean_y = np.mean([p[1] for p in sample_pts])
            if abs(mean_x) > 180 or abs(mean_y) > 90:
                is_bathy_geom_geographic = False
                print("   🌐 Batimetri terdeteksi menggunakan koordinat terproyeksi meter (UTM).")
            else:
                print("   🌐 Batimetri terdeteksi menggunakan koordinat geografis (WGS84).")

        transformer_fwd = Transformer.from_crs("EPSG:4326", f"EPSG:{target_epsg}", always_xy=True)
        utm_w, utm_s = transformer_fwd.transform(w_val, s_val)
        utm_e, utm_n = transformer_fwd.transform(e_val, n_val)
        utm_xmin, utm_xmax = min(utm_w, utm_e), max(utm_w, utm_e)
        utm_ymin, utm_ymax = min(utm_s, utm_n), max(utm_s, utm_n)

        # Membaca data menggunakan chunk-engine 'c' Pandas yang super cepat dan kompatibel
        print("   ⏳ Menjalankan high-speed C-engine stream chunking & vectorized masking...")
        filtered_chunks = []
        chunksize = 5000000
        line_count = 0
        
        reader = pd.read_csv(
            bathy_path, sep=sep_detected, header=None, names=['X', 'Y', 'Z'],
            dtype={'X': np.float64, 'Y': np.float64, 'Z': np.float64},
            chunksize=chunksize, engine='c'
        )
        
        for chunk in reader:
            x_arr = chunk['X'].values
            y_arr = chunk['Y'].values
            if not is_bathy_geom_geographic:
                mask = (x_arr >= utm_xmin) & (x_arr <= utm_xmax) & (y_arr >= utm_ymin) & (y_arr <= utm_ymax)
            else:
                mask = (x_arr >= w_val) & (x_arr <= e_val) & (y_arr >= s_val) & (y_arr <= n_val)
            
            filtered_chunk = chunk[mask]
            if not filtered_chunk.empty:
                filtered_chunks.append(filtered_chunk)
            line_count += len(chunk)
            if line_count % 20000000 == 0:
                print(f"      ├ Berhasil memproses {line_count:,} baris titik data...")

        print(f"   ✅ Penyaringan selesai! Total data diperiksa: {line_count:,} baris.")
        
        if filtered_chunks:
            df_bathy_filtered = pd.concat(filtered_chunks, ignore_index=True)
            print(f"   ✅ Ditemukan {len(df_bathy_filtered):,} titik batimetri berada di dalam wilayah kajian.")
            
            if not is_bathy_geom_geographic:
                print("   ⏳ Mengonversi koordinat batimetri tersaring dari UTM ke WGS84...")
                transformer_rev = Transformer.from_crs(f"EPSG:{target_epsg}", "EPSG:4326", always_xy=True)
                lon_b, lat_b = transformer_rev.transform(df_bathy_filtered['X'].values, df_bathy_filtered['Y'].values)
                df_bathy_filtered['X'] = lon_b
                df_bathy_filtered['Y'] = lat_b
        else:
            print("   ⚠️ Tidak ada titik batimetri yang lolos filter. Menggunakan fallback sintetis.")
            
    except Exception as e_bathy:
        print(f"   ⚠️ Interpolasi batimetri lokal gagal: {e_bathy}. Menggunakan model batimetri sintetis.")
else:
    print(f"   ℹ️ File batimetri {bathy_path} tidak ditemukan. Menggunakan model batimetri sintetis.")
# =========================================================================
# FASE 2: PROSES ALGORITMA LYZENGA REGIONAL (100% PURE CPU LOCAL)
# =========================================================================
print("\n🛰️ [FASE 2] PROSES SPECTRAL LYZENGA ALGORITHM PADA CPU")

# Mempersiapkan variabel data pixel aktif hasil ekstraksi satelit
df_pixels = pd.DataFrame()

if s2_loaded:
    try:
        print("   ⏳ Membaca band spektral asli (Blue, Green, NIR) GeoTIFF...")
        img_blue = src_s2.read(band_blue).astype(np.float32)
        img_green = src_s2.read(band_green).astype(np.float32)
        img_nir = src_s2.read(band_nir).astype(np.float32)
        
        # Scaling reflektansi Sentinel-2 jika citra dalam format digital number (DN > 1.0)
        if img_blue.max() > 10.0:
            print("      ℹ️  Deteksi data Digital Number (DN). Melakukan pembagian skala otomatis 1/10000...")
            img_blue /= 10000.0
            img_green /= 10000.0
            img_nir /= 10000.0

        H_img, W_img = img_blue.shape
        
        # Menghitung koordinat spasial WGS84 per pixel citra menggunakan transformasi Affine asli GeoTIFF
        print("   ⏳ Mengonversi koordinat pixel grid citra ke sistem geospasial...")
        cols, rows_indices = np.meshgrid(np.arange(W_img), np.arange(H_img))
        xs_img, ys_img = rasterio.transform.xy(src_s2.transform, rows_indices, cols)
        
        lons_flat = np.array(xs_img).flatten()
        lats_flat = np.array(ys_img).flatten()
        b2_flat = img_blue.flatten()
        b3_flat = img_green.flatten()
        b8_flat = img_nir.flatten()
        
        # Saring awal: Hilangkan pixel daratan rimbun (NIR > 0.25) dan area no-data (B2 == 0)
        # Trik ini memotong waktu komputasi CPU lokal Anda secara ekstrim!
        mask_valid = (b8_flat < 0.25) & (b2_flat > 0.001) & (b2_flat < 1.0)
        
        df_pixels = pd.DataFrame({
            'lon': lons_flat[mask_valid],
            'lat': lats_flat[mask_valid],
            'B2': b2_flat[mask_valid],
            'B3': b3_flat[mask_valid],
            'B8': b8_flat[mask_valid]
        })
        print(f"   ✅ Sukses mengekstrak {len(df_pixels):,} pixel perairan aktif dari Citra GeoTIFF.")
    except Exception as e_s2_proc:
        print(f"   ❌ Gagal memproses citra spektral: {e_s2_proc}. Beralih ke fallback sintetis.")
        s2_loaded = False

# Fallback pembuatan data pixel sintetis jika citra .tif tidak tersedia (Agar skrip tidak pernah crash!)
if not s2_loaded or df_pixels.empty:
    print("   ⚠️ Membuat data perairan sintetis di Teluk Clungup untuk pengujian pipeline...")
    np.random.seed(42)
    lons_synth = np.random.uniform(w_val, e_val, 15000)
    lats_synth = np.random.uniform(s_val, n_val, 15000)
    # Membuat gradasi warna air dari pantai utara (terang) ke lepas pantai selatan (gelap)
    y_norm = (lats_synth - s_val) / (n_val - s_val)
    b2_synth = 0.05 + 0.15 * y_norm + np.random.normal(0, 0.005, 15000)
    b3_synth = 0.03 + 0.11 * y_norm + np.random.normal(0, 0.004, 15000)
    b8_synth = 0.01 + 0.02 * y_norm
    
    df_pixels = pd.DataFrame({
        'lon': lons_synth, 'lat': lats_synth,
        'B2': b2_synth, 'B3': b3_synth, 'B8': b8_synth
    })
    print(f"   ✅ Sukses merakit {len(df_pixels):,} pixel sintetis.")
# =========================================================================
# FASE 2.5: PROSES INTERPOLASI BATIMETRI LOKAL PADA TINGKAT PIXEL (CPU ONLY)
# =========================================================================
print("\n📊 [FASE 2.5] PROSES IDW INTERPOLASI BATIMETRI LOKAL DI CPU")

if not df_bathy_filtered.empty:
    try:
        print("   ⏳ Membangun pohon spasial cKDTree dari koordinat batimetri lokal...")
        sample_xy = np.c_[df_bathy_filtered['X'].values, df_bathy_filtered['Y'].values]
        sample_z = df_bathy_filtered['Z'].values
        
        # Batasi sampling representatif untuk mencegah degradasi RAM CPU (maksimal 100.000 sampel acak)
        if len(sample_xy) > 100000:
            np.random.seed(42)
            sel_idx = np.random.choice(len(sample_xy), 100000, replace=False)
            sample_xy = sample_xy[sel_idx]
            sample_z = sample_z[sel_idx]
            
        tree_bathy = cKDTree(sample_xy)
        
        pixel_xy = np.c_[df_pixels['lon'].values, df_pixels['lat'].values]
        print(f"   ⏳ Melakukan interpolasi IDW spasial lokal ke {len(pixel_xy):,} pixel citra...")
        
        # K-NN Query untuk pencarian tetangga tercepat
        dists, indices = tree_bathy.query(pixel_xy, k=10)
        dists = np.where(dists < 1e-10, 1e-10, dists)
        weights = 1.0 / (dists ** 2)
        interpolated_depths = np.sum(weights * np.abs(sample_z[indices]), axis=1) / np.sum(weights, axis=1)
        
        df_pixels['depth'] = interpolated_depths
        print("   ✅ Interpolasi IDW batimetri lokal selesai sukses di tingkat pixel.")
    except Exception as e_bathy_idw:
        print(f"   ⚠️ Interpolasi IDW lokal gagal: {e_bathy_idw}. Mengaktifkan fallback sintetis.")
        df_pixels['depth'] = np.nan

# Jika batimetri tidak tersedia atau gagal terinterpolasi, buat model kedalaman landai ke arah selatan
if 'depth' not in df_pixels.columns or df_pixels['depth'].isnull().all():
    print("   ⏳ Membangun batimetri sintetis landai (Utara dangkal -> Selatan dalam)...")
    y_norm = (df_pixels['lat'].values - s_val) / (n_val - s_val)
    df_pixels['depth'] = (1.0 - y_norm) * 30.0
    print("   ✅ Batimetri sintetis landai berhasil dikomputasikan.")
# =========================================================================
# FASE 3: LYZENGA COVARIANCE & DII CALCULATION (100% CPU VECTORIZED)
# =========================================================================
print("\n⚙️  [FASE 3] REKONSTRUKSI MATRIKS KOVARIANS & DETAIL ATENUASI REGIONAL")

# A. Auto-Kalibrasi Nilai Reflektansi Laut Dalam (R_deep)
# Diturunkan dari persentil 5% tergelap dari pixel air dalam (kedalaman > 15m)
df_deep = df_pixels[df_pixels['depth'] > 15.0]
if len(df_deep) > 10:
    r_blue_deep = np.percentile(df_deep['B2'].values, 5)
    r_green_deep = np.percentile(df_deep['B3'].values, 5)
else:
    r_blue_deep = np.percentile(df_pixels['B2'].values, 5)
    r_green_deep = np.percentile(df_pixels['B3'].values, 5)

print(f"   ✅ Auto-kalibrasi R_deep Selesai. R_Blue_Deep: {r_blue_deep:.4f}, R_Green_Deep: {r_green_deep:.4f}")

# B. Saring air dangkal murni (B2 > R_deep dan kedalaman di bawah 15m)
mask_dangkal = (df_pixels['B2'] > r_blue_deep) & (df_pixels['depth'] > 0.1) & (df_pixels['depth'] <= 15.0)
df_active = df_pixels[mask_dangkal].copy().reset_index(drop=True)

if df_active.empty:
    print("   ⚠️ Peringatan: Tidak ada pixel yang melampaui saringan air dangkal aktif.")
    print("      Melonggarkan saringan air dangkal secara otomatis...")
    df_active = df_pixels.copy().reset_index(drop=True)

# C. Hitung Logaritma Natural Kolom Air Terkoreksi: X_i = ln(R_i - R_deep)
df_active['X_blue'] = np.log(np.maximum(df_active['B2'].values - r_blue_deep, 1e-4))
df_active['X_green'] = np.log(np.maximum(df_active['B3'].values - r_green_deep, 1e-4))

# D. Zonasi Spasial Dinamis Berdasarkan Kedalaman (Muchlisin Arief, 2013)
max_depth = df_active['depth'].max()
thresh_dangkal = min(max_depth * 0.25, 5.0)
thresh_dalam = min(max_depth * 0.75, 12.0)

mask_sangat_dangkal = df_active['depth'] <= thresh_dangkal
mask_agak_dangkal = (df_active['depth'] > thresh_dangkal) & (df_active['depth'] <= thresh_dalam)
mask_dalam = df_active['depth'] > thresh_dalam

def hitung_ki_kj_lokal(df_sub):
    """Menghitung rasio atenuasi dinamis berbasis kovarians NumPy lokal."""
    if len(df_sub) < 5:
        return 1.12
    try:
        cov_mat = np.cov(df_sub['X_blue'].values, df_sub['X_green'].values)
        sigma_ii = cov_mat[0, 0] # Variansi Blue
        sigma_jj = cov_mat[1, 1] # Variansi Green
        sigma_ij = cov_mat[0, 1] # Kovarians Blue-Green
        
        if abs(sigma_ij) < 1e-9:
            return 1.12
            
        term1 = sigma_ii - sigma_jj
        term2 = np.sqrt(term1**2 + 4 * (sigma_ij**2))
        ratio = (term1 + term2) / (2 * sigma_ij)
        
        if 0.5 <= ratio <= 2.5:
            return ratio
    except:
        pass
    return 1.12

# Hitung rasio ki/kj dinamis tiap zona kedalaman perairan dangkal
ratio_sangat_dangkal = hitung_ki_kj_lokal(df_active[mask_sangat_dangkal])
ratio_agak_dangkal = hitung_ki_kj_lokal(df_active[mask_agak_dangkal])

print(f"      ├ Limitasi Zonasi Kedalaman Maks  : {max_depth:.2f} meter")
print(f"      ├ Ambang Batas Zona Laut Dalam    : {thresh_dalam:.2f} meter")
print(f"      ├ Rasio ki/kj Zona Sangat Dangkal (0-5m) : {ratio_sangat_dangkal:.4f}")
print(f"      └ Rasio ki/kj Zona Agak Dangkal (5-15m)  : {ratio_agak_dangkal:.4f}")

# E. Hitung nilai Depth Invariant Index (DII) Lyzenga
dii_vals = np.zeros(len(df_active))
if np.any(mask_sangat_dangkal):
    dii_vals[mask_sangat_dangkal] = df_active.loc[mask_sangat_dangkal, 'X_blue'] - ratio_sangat_dangkal * df_active.loc[mask_sangat_dangkal, 'X_green']
if np.any(mask_agak_dangkal):
    dii_vals[mask_agak_dangkal] = df_active.loc[mask_agak_dangkal, 'X_blue'] - ratio_agak_dangkal * df_active.loc[mask_agak_dangkal, 'X_green']
if np.any(mask_dalam):
    dii_vals[mask_dalam] = df_active.loc[mask_dalam, 'X_blue'] - 1.12 * df_active.loc[mask_dalam, 'X_green']

df_active['lyzenga'] = dii_vals

# Thresholding untuk mengisolasi piksel terumbu karang dangkal
# Rentang nilai indeks Lyzenga umumnya berada pada kisaran negatif mendekati nol
default_ambang = -0.15
ambang_karang = float(input(f"   ↳ Masukkan ambang batas indeks Lyzenga Karang [Default: {default_ambang}]: ") or default_ambang)
df_coral = df_active[df_active['lyzenga'] > ambang_karang].reset_index(drop=True)
total_pixels = len(df_coral)

print(f"   ✅ Berkas piksel aktif berhasil diklasifikasi: {total_pixels:,} titik terumbu karang.")

# Membangun box poligon spasial dari koordinat aktif ke sistem UTM kustom Anda
transformer_utm = Transformer.from_crs("EPSG:4326", f"EPSG:{target_epsg}", always_xy=True)

local_boxes_utm = []
safe_scale = 10.0 # Resolusi native Sentinel-2 (meter)
half_scale = safe_scale / 2.0

if total_pixels > 0:
    print("   ⏳ Mengonversi koordinat piksel aktif ke objek geometri UTM lokal...")
    xs_utm, ys_utm = transformer_utm.transform(df_coral['lon'].values, df_coral['lat'].values)
    
    for x_utm, y_utm in zip(xs_utm, ys_utm):
        pixel_box = box(x_utm - half_scale, y_utm - half_scale, x_utm + half_scale, y_utm + half_scale)
        local_boxes_utm.append(pixel_box)
    
    gdf_raw_utm = gpd.GeoDataFrame(geometry=local_boxes_utm, crs=f"EPSG:{target_epsg}")
else:
    print("   ⚠️ Peringatan: Tidak ada pixel karang lolos threshold. Mengaktifkan fallback karang sintetis.")
    poly_fallback = Polygon([
        (112.656971, -8.448676), (112.679882, -8.448676),
        (112.679882, -8.444211), (112.656971, -8.444211)
    ])
    gdf_fallback_wgs = gpd.GeoDataFrame(geometry=[poly_fallback], crs="EPSG:4326")
    gdf_raw_utm = gdf_fallback_wgs.to_crs(epsg=target_epsg)
# =========================================================================
# FASE 4: MORPHOLOGICAL FILTERING & CLEANING (SHAPELY LOKAL)
# =========================================================================
if apply_filter_morfologi:
    print("\n🪸 [FASE 4] MENJALANKAN MORPHOLOGICAL CLOSING & CLUSTERING")
    buffer_piksel = gdf_raw_utm.geometry.buffer(jarak_cluster)
    poligon_bersatu = unary_union(buffer_piksel)
    poligon_clean = poligon_bersatu.buffer(-jarak_cluster)

    gdf_hasil = gpd.GeoDataFrame(geometry=[poligon_clean], crs=f"EPSG:{target_epsg}")
    gdf_hasil = gdf_hasil.explode(index_parts=False).reset_index(drop=True)
else:
    print("\n🪸 [FASE 4] MELOMPATI FILTER MORFOLOGI (Mempertahankan Detail Asli)")
    gdf_hasil = gdf_raw_utm.copy()

if apply_area_filter:
    gdf_hasil = gdf_hasil[gdf_hasil.geometry.area > min_area_limit].reset_index(drop=True)
    print(f"   ✅ Sukses menyaring luasan! Sisa poligon: {len(gdf_hasil)} buah.")
# =========================================================================
# FASE 4.5: GEOMETRIC COASTLINE CLIPPING & NEARSHORE LIMIT (CPU ONLY)
# =========================================================================
gdf_coast = None
if (apply_coast_clipping or apply_nearshore_limit) and coastline_path and os.path.exists(coastline_path):
    print("\n🌊 [FASE 4.5] MEMPROSES GEOMETRI GRIS PANTAI (OFFSET & NEARSHORE LIMIT)")
    try:
        gdf_coast = gpd.read_file(coastline_path)
        if gdf_coast.crs is None:
            gdf_coast = gdf_coast.set_crs(epsg=4326)
            
        gdf_coast_utm = gdf_coast.to_crs(target_epsg)
        coast_union = unary_union(gdf_coast_utm.geometry)
        
        # A. Penerapan Nearshore Limit (Batasi karang hanya tumbuh maks X meter dari pantai)
        if apply_nearshore_limit:
            print(f"   ⏳ Membatasi terumbu karang hanya tumbuh dalam radius {nearshore_distance} m dari pantai...")
            nearshore_zone = coast_union.buffer(nearshore_distance)
            
            new_geoms = []
            for idx, row in gdf_hasil.iterrows():
                intersect_geom = row.geometry.intersection(nearshore_zone)
                if not intersect_geom.is_empty:
                    if intersect_geom.geom_type in ['Polygon', 'MultiPolygon']:
                        new_geoms.append(intersect_geom)
            
            if new_geoms:
                gdf_hasil = gpd.GeoDataFrame(geometry=new_geoms, crs=f"EPSG:{target_epsg}")
                gdf_hasil = gdf_hasil.explode(index_parts=False).reset_index(drop=True)
                print(f"   ✅ Sukses mereduksi area lepas pantai! Sisa poligon di zona nearshore: {len(gdf_hasil)} buah.")
            else:
                print("   ⚠️ Peringatan: Tidak ada poligon karang yang berada di dalam zona nearshore!")
        
        # B. Penerapan Coastline Safe Offset (Memotong area tumpang tindih sedekat Y meter dari pantai)
        if apply_coast_clipping:
            coast_buffered = coast_union.buffer(coastline_offset)
            print(f"   ⏳ Memotong area tumpang tindih & memberikan offset {coastline_offset} m dari pantai...")
            
            new_geoms = []
            for idx, row in gdf_hasil.iterrows():
                diff_geom = row.geometry.difference(coast_buffered)
                if not diff_geom.is_empty:
                    if diff_geom.geom_type in ['Polygon', 'MultiPolygon']:
                        new_geoms.append(diff_geom)
                        
            if new_geoms:
                gdf_hasil = gpd.GeoDataFrame(geometry=new_geoms, crs=f"EPSG:{target_epsg}")
                gdf_hasil = gdf_hasil.explode(index_parts=False).reset_index(drop=True)
                print(f"   ✅ Sukses memberikan offset tepi pantai! Sisa poligon: {len(gdf_hasil)} buah.")
                
        if apply_area_filter:
            gdf_hasil = gdf_hasil[gdf_hasil.geometry.area > min_area_limit].reset_index(drop=True)
            
    except Exception as e_coast:
        print(f"   ⚠️ Gagal memproses pemotongan garis pantai: {e_coast}. Melompati reduksi.")
else:
    print("\n🌊 [FASE 4.5] MELOMPATI PEMOTONGAN GARIS PANTAI (Mempertahankan Karang Tepi Pantai)")
    if coastline_path and os.path.exists(coastline_path):
        try:
            gdf_coast = gpd.read_file(coastline_path)
            if gdf_coast.crs is None:
                gdf_coast = gdf_coast.set_crs(epsg=4326)
        except: pass

# Kembalikan koordinat ke format Geografis (WGS84) agar terbaca langsung oleh Delft3D-FM
gdf_final = gdf_hasil.to_crs(epsg=4326)
# =========================================================================
# FASE 5: PEMBUATAN FILE ASCII .POL (DELFT3D COMPATIBLE)
# =========================================================================
print("\n📝 [FASE 5] MENULIS FILE area_karang.pol FORMAT KAKU DELFT3D")
nama_file_pol = os.path.join(target_dir, "area_karang.pol")

try:
    with open(nama_file_pol, 'w') as f:
        f.write("* File poligon terumbu karang hasil ekstraksi Algoritma Lyzenga Regional (Sentinel-2)\n")
        f.write(f"* Dirancang otomatis untuk CMC Clungup, Malang Selatan [Micro AOI: N:{n_val:.4f}, S:{s_val:.4f}]\n")
        f.write("* PROSES: 100% Komputasi CPU Lokal Berperforma Tinggi (v7.2)\n")
        if apply_coast_clipping and coastline_path:
            f.write(f"* Dipotong & offset aman {coastline_offset} m menjauh dari garis pantai: {os.path.basename(coastline_path)}\n")
        if apply_nearshore_limit:
            f.write(f"* Dibatasi geometris hanya tumbuh maks {nearshore_distance} m dari pantai.\n")
        
        counter_poly = 1
        for idx, row in gdf_final.iterrows():
            geom = row.geometry
            
            def write_polygon_coords(polygon_obj, poly_idx):
                coords = list(polygon_obj.exterior.coords)
                if coords[0] != coords[-1]:
                    coords.append(coords[0])
                num_points = len(coords)
                f.write(f"karang_{poly_idx}\n")
                f.write(f"     1         {num_points}\n")
                for lon_val, lat_val in coords:
                    f.write(f"   {lon_val:.6f}   {lat_val:.6f}\n")

            if geom.geom_type == 'Polygon':
                write_polygon_coords(geom, counter_poly)
                counter_poly += 1
            elif geom.geom_type == 'MultiPolygon':
                for sub_geom in geom.geoms:
                    write_polygon_coords(sub_geom, counter_poly)
                    counter_poly += 1

    print(f"   ✅ [DELFT3D SUCCESS] Berkas jaring .pol berhasil dibuat: {os.path.basename(nama_file_pol)} ({counter_poly - 1} Poligon)")
except Exception as e_pol:
    print(f"   ❌ Gagal menulis berkas .pol: {e_pol}")
# =========================================================================
# FASE 6: INJEKSI / MODIFIKASI LANGSUNG PADA BERKAS .EXT EKSISTING
# =========================================================================
print("\n📝 [FASE 6] MODIFIKASI BERKAS .EXT & INJEKSI BLOK ROUGHNESS KARANG")

default_manning_karang = 0.05
manning_karang = float(input(f"   ↳ Tentukan nilai Manning (n) Terumbu Karang [Default: {default_manning_karang:.2f} s/m^(1/3)]: ") or default_manning_karang)

roughness_block = f"""
# =========================================================================
# INTEGRASI PENYEKAT GEOMETRIS TERUMBU KARANG (ALGORITMA LYZENGA REGIONAL)
# =========================================================================
[Roughness]
id                              = CoralReefs
quantity                        = frictioncoefficient
type                            = manning
value                           = {manning_karang:.2f}
file                            = {os.path.basename(nama_file_pol)}
"""

if os.path.exists(existing_ext_path):
    try:
        target_ext_path = os.path.join(target_dir, os.path.basename(existing_ext_path))
        if os.path.abspath(existing_ext_path) != os.path.abspath(target_ext_path):
            import shutil
            shutil.copy2(existing_ext_path, target_ext_path)
            print(f"   ⏳ Menyalin berkas {os.path.basename(existing_ext_path)} ke folder tujuan ekspor...")
        
        with open(target_ext_path, 'r') as f_read:
            ext_content = f_read.read()
        
        if "id                              = CoralReefs" in ext_content:
            print("   ℹ️ Blok Roughness CoralReefs sudah ada di dalam file .ext. Melakukan update nilai...")
            content_lines = ext_content.split('\n')
            new_lines = []
            skip = False
            for line in content_lines:
                if "[Roughness]" in line and "CoralReefs" in ext_content:
                    skip = True
                if skip and line.strip() == "" and len(new_lines) > 0 and new_lines[-1].strip() == "":
                    skip = False
                    continue
                if not skip:
                    new_lines.append(line)
            ext_content = '\n'.join(new_lines)

        with open(target_ext_path, 'a') as f_append:
            f_append.write(roughness_block)
        
        print(f"   ✅ [DELFT3D SUCCESS] Sukses menyuntikkan kekasaran karang langsung ke: {os.path.basename(target_ext_path)}")
        
    except Exception as e_ext:
        print(f"   ❌ Gagal memodifikasi berkas .ext: {e_ext}")
else:
    target_ext_path = os.path.join(target_dir, os.path.basename(existing_ext_path))
    print(f"   ⚠️ Berkas {existing_ext_path} tidak ditemukan. Membuat berkas .ext baru di: {target_ext_path}")
    try:
        with open(target_ext_path, 'w') as f_new:
            f_new.write("### D-Flow FM External Forcing Data File\n")
            f_new.write("### Created automatically via Lyzenga Coral Processor Pipeline\n")
            f_new.write(roughness_block)
        print(f"   ✅ Berkas .ext baru berhasil diinisialisasi.")
    except Exception as e_new:
        print(f"   ❌ Gagal membuat berkas .ext baru: {e_new}")
# =========================================================================
# FASE 7: VISUALISASI HASIL POLIGON TERUMBU KARANG OVERLAY (Micro AOI)
# =========================================================================
try:
    print("\n🎨 [FASE 7] RENDERING GRAFIK KONTUR OVERLAY TERUMBU KARANG...")
    plt.close('all')
    fig, ax = plt.subplots(figsize=(10, 10), dpi=150)
    ax.set_aspect('equal', adjustable='box')
    ax.set_box_aspect(1)
    ax.set_facecolor('#b0d2ec')

    # Penggambaran garis batas poligon terumbu karang hasil Lyzenga
    gdf_final.plot(ax=ax, color='#f43f5e', edgecolor='#be123c', linewidth=1.5, alpha=0.7, zorder=5, label="Terumbu Karang (Lyzenga)")
    
    # Plot batas kotak Micro AOI
    rect_aoi = plt.Rectangle((w_val, s_val), e_val - w_val, n_val - s_val,
                             lw=2.0, edgecolor='#7c3aed', facecolor='none', ls='--', zorder=6,
                             label='Batas Wilayah Citra')
    ax.add_patch(rect_aoi)
    
    # Plot garis pantai pemotong wajib dimunculkan secara eksplisit pada gambar
    if gdf_coast is not None:
        print("   🌊 Memplot data spasial Garis Pantai (Coastline) ke dalam sumbu visualisasi...")
        gdf_coast.plot(ax=ax, color='#e5d5b7', edgecolor='#166534', linewidth=1.2, zorder=4, alpha=0.9, label="Garis Pantai")
    
    # Plot titik pusat koordinat studi
    ax.scatter(lon_center, lat_center, color='yellow', edgecolor='black', s=50, zorder=10, label="Pusat Studi Clungup")

    ax.set_title("Peta Sebaran Terumbu Karang Hasil Ekstraksi Algoritma Lyzenga Regional\nClungup Mangrove Conservation (CMC), Malang Selatan", fontweight='bold', fontsize=12, pad=12)
    ax.set_xlabel("Longitude (deg)", fontsize=10)
    ax.set_ylabel("Latitude (deg)", fontsize=10)
    ax.grid(True, linestyle=':', alpha=0.5)

    # Batasi tampilan gambar plot secara ketat hanya pada lingkup Micro AOI + sedikit buffer margin
    pad_lon = (e_val - w_val) * 0.1
    pad_lat = (n_val - s_val) * 0.1
    ax.set_xlim(w_val - pad_lon, e_val + pad_lon)
    ax.set_ylim(s_val - pad_lat, n_val + pad_lat)

    legend_elements = [
        mlines.Line2D([], [], color='#f43f5e', marker='s', markersize=10, label=f'Terumbu Karang (Manning n = {manning_karang:.2f})'),
        mlines.Line2D([], [], color='#7c3aed', ls='--', lw=2.0, label='Batas Wilayah Kajian Citra'),
        mlines.Line2D([], [], color='none', marker='o', markerfacecolor='yellow', markeredgecolor='black', markersize=8, label='Pusat Studi Clungup')
    ]
    if gdf_coast is not None:
        legend_elements.insert(1, mlines.Line2D([], [], color='#e5d5b7', marker='s', markersize=10, markeredgecolor='#166534', label='Garis Pantai (Daratan)'))
        
    ax.legend(handles=legend_elements, loc='upper right', framealpha=0.95, edgecolor='gray', fontsize=9)

    plt.tight_layout()
    out_fig = os.path.join(target_dir, "Clungup_Lyzenga_Coral_Reef_Map.png")
    plt.savefig(out_fig, dpi=180, bbox_inches='tight')
    plt.show()

    print("\n" + "=" * 80)
    print("🚀 PIPELINE SELESAI — Berkas .pol sukses dibuat dan disuntikkan ke berkas .ext secara lokal!")
    print(f"   Output Folder : {target_dir}")
    print(f"   Output Berkas : {os.path.basename(target_ext_path)} (Modifikasi .ext)")
    print(f"   Output Poligon: {os.path.basename(nama_file_pol)} (Geometri .pol)")
    print(f"   Output Peta   : {os.path.basename(out_fig)}")
    print("=" * 80)

except Exception as e_plot:
    print(f"⚠️ Kegagalan plot visualisasi: {e_plot}")
    import traceback
    traceback.print_exc()

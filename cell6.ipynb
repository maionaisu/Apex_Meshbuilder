# [Code Cell]
import numpy as np
import matplotlib.pyplot as plt
import geopandas as gpd
import xarray as xr
import pandas as pd
import os
from pyproj import Transformer
from scipy.stats import binned_statistic_2d
import scipy.ndimage as ndimage

# Toleransi import Deltares dependencies
try:
    import dfm_tools as dfmt
    import xugrid as xu
    from meshkernel import GeometryList, DeleteMeshOption
except ImportError:
    print("❌ [FATAL] Library 'dfm_tools', 'xugrid', atau 'meshkernel' tidak ditemukan. Jalankan: pip install dfm_tools xugrid meshkernel")
    dfmt = None
    xu = None

print("🧩 [TAHAP 5] DELFTARES MODELBUILDER: ENTERPRISE ADAPTIVE MESH REFINEMENT")

# =========================================================================
# STATE VALIDATION & AUTO-SYNC
# =========================================================================
required_states = {
    'doc_depth': "Limit Depth of Closure (Tahap 3)",
    'micro_poly_utm': "Bounding Box AOI Mikro di EPSG Metrik (Tahap 4)",
    'mk': "Objek Base Grid / Mesh Kernel (Tahap 4)",
    'target_epsg': "Sistem Proyeksi (Tahap 3/4)"
}

missing_states = [key for key in required_states.keys() if key not in globals()]
if missing_states:
    print(f"❌ [FATAL ERROR] State memori mutlak hilang: {missing_states}")
    print("Harap jalankan kembali eksekusi Tahap 3 dan Tahap 4.")
    raise RuntimeError("Memori terputus. Pipeline dihentikan.")

# [ENTERPRISE FAILSAFE]: Mencegah Crash akibat Mesh Kernel yang sudah rusak dari eksekusi sebelumnya
if mk.mesh2d_get().node_x.size == 0:
    print("❌ [FATAL ERROR] MeshKernel (mk) terdeteksi KOSONG atau RUSAK akibat error pada Run sebelumnya.")
    raise RuntimeError("Anda WAJIB me-run ulang Tahap 4 untuk mereset Base Grid sebelum mengulangi Tahap 5.")

crs_str = f"EPSG:{target_epsg}"

# AUTO-RECOVERY UNTUK POINT CLOUD BATIMETRI
if 'df_bathy' not in globals():
    print("⚠️ [INFO] Memuat ulang df_bathy ke memori (Pembersihan RAM Tahap 3)...")
    bathy_path_mem = globals().get('bathy_path', '')
    if not bathy_path_mem or not os.path.exists(bathy_path_mem):
        bathy_path_mem = input("📂 Masukkan kembali path file Batimetri (.xyz): ").strip().strip('\'"').replace('"', '').replace("'", "")
        
    with open(bathy_path_mem, 'r', encoding='utf-8', errors='ignore') as f:
        df_bathy = pd.read_csv(f, delim_whitespace=True, header=None, names=['x','y','z'], dtype=np.float32)
        
    is_wgs84 = df_bathy['x'].abs().max() <= 180 and df_bathy['y'].abs().max() <= 90
    if is_wgs84:
        print(f"🔄 Mengonversi ulang WGS84 ke UTM {crs_str} via Chunking (RAM Optimized)...")
        tr = Transformer.from_crs("EPSG:4326", crs_str, always_xy=True)
        
        x_vals = df_bathy['x'].values
        y_vals = df_bathy['y'].values
        total_pts = len(x_vals)
        chunk_size = 5_000_000 
        
        for i in range(0, total_pts, chunk_size):
            end_idx = min(i + chunk_size, total_pts)
            tx, ty = tr.transform(x_vals[i:end_idx], y_vals[i:end_idx])
            x_vals[i:end_idx] = tx
            y_vals[i:end_idx] = ty
            
        import gc
        gc.collect()

target_res = float(input("📐 Masukkan Resolusi Jaring Halus Pesisir/Inner (m) [20.0]: ") or 20.0)

try:
    # =========================================================================
    # PHASE 1: MACRO-GUIDED RASTERIZATION (PETA PEMANDU UTUH)
    # =========================================================================
    print("\n⏳ [PHASE 1] Membangun Macro-Guided Rasterization (Peta Pemandu O(N))...")
    
    min_x_mac, max_x_mac = df_bathy['x'].min(), df_bathy['x'].max()
    min_y_mac, max_y_mac = df_bathy['y'].min(), df_bathy['y'].max()
    
    grid_spacing = target_res / 2.0  
    gx = np.arange(min_x_mac, max_x_mac, grid_spacing)
    gy = np.arange(min_y_mac, max_y_mac, grid_spacing)
    
    x_vals = df_bathy['x'].values
    y_vals = df_bathy['y'].values
    z_vals = df_bathy['z'].values
    
    total_points = len(x_vals)
    
    if 'df_bathy' in globals():
        del globals()['df_bathy'] 
        
    import gc
    gc.collect()
    
    print(f"   ├ Melakukan binning spasial via Chunking ({total_points:,} titik)...")
    
    count = np.zeros((len(gx)-1, len(gy)-1), dtype=np.float32)
    z_sum = np.zeros((len(gx)-1, len(gy)-1), dtype=np.float32)
    
    chunk_size = 5_000_000 
    for i in range(0, total_points, chunk_size):
        end_idx = min(i + chunk_size, total_points)
        c_chunk, _, _ = np.histogram2d(x_vals[i:end_idx], y_vals[i:end_idx], bins=[gx, gy])
        z_chunk, _, _ = np.histogram2d(x_vals[i:end_idx], y_vals[i:end_idx], bins=[gx, gy], weights=z_vals[i:end_idx])
        count += c_chunk
        z_sum += z_chunk
    
    del x_vals, y_vals, z_vals
    gc.collect()
    
    with np.errstate(divide='ignore', invalid='ignore'):
        grid_z_raw = np.true_divide(z_sum, count)
        grid_z_raw[count == 0] = np.nan
        
    grid_z = grid_z_raw.T 

    mask = np.isnan(grid_z)
    if mask.any():
        ind = ndimage.distance_transform_edt(mask, return_distances=False, return_indices=True)
        grid_z = grid_z[tuple(ind)]

    gx_mid = gx[:-1] + np.diff(gx)/2
    gy_mid = gy[:-1] + np.diff(gy)/2
    
    data_bathy_macro = xr.DataArray(data=grid_z, coords={"lat": gy_mid, "lon": gx_mid}, dims=("lat", "lon"))
    
    # =========================================================================
    # PHASE 2: DoC TARGETED REFINEMENT PADA KERNEL
    # =========================================================================
    print(f"⚓ [PHASE 2] Mengaplikasikan Limit DoC ({doc_depth:.2f} m) pada Peta Pemandu...")
    bathy_da_active = data_bathy_macro.where(data_bathy_macro >= doc_depth, other=999.0)

    print(f"⚙️ Memicu Courant Refinement ({target_res}m) pada Kernel C++...")
    dfmt.refine_basegrid(mk=mk, data_bathy_sel=bathy_da_active, min_edge_size=target_res)

    # =========================================================================
    # PHASE 3: LANDWARD CLIPPING DUAL-MODE DENGAN OVERLAP TOLERANCE
    # =========================================================================
    print("\n✂️ [PHASE 3] Eksekusi Landward Clipping (Custom Boundary)...")
    print("   [PILIHAN MODE PEMOTONGAN DARATAN]")
    print("   [1] Conservative (Default) : Mempertahankan sel air yang berpotongan (Overlap murni ke darat).")
    print("   [2] Aggressive             : Menghapus mutlak seluruh sel yang bersentuhan dengan darat (Tanpa Overlap).")
    clip_mode = input("   Pilih mode pemotongan [1/2]: ").strip()
    
    buffer_tol_m = 0.0
    if clip_mode == '2':
        delete_opt_val = DeleteMeshOption.INSIDE_AND_INTERSECTED if hasattr(DeleteMeshOption, 'INSIDE_AND_INTERSECTED') else 1
        print("   -> Mode AGGRESSIVE diaktifkan. Jaring akan lebih rapi di area laut.")
        tol_input = input("   Berapa meter toleransi overlap jaring ke darat? (contoh: 5.0) [0.0]: ").strip()
        if tol_input:
            try:
                buffer_tol_m = -abs(float(tol_input))
                print(f"   -> Toleransi {abs(buffer_tol_m)}m diaplikasikan ke mesin pemotong C++.")
            except ValueError:
                print("   -> Input tidak valid. Toleransi diatur ke 0.0m.")
    else:
        delete_opt_val = DeleteMeshOption.INSIDE_NOT_INTERSECTED if hasattr(DeleteMeshOption, 'INSIDE_NOT_INTERSECTED') else 0
        print("   -> Mode CONSERVATIVE diaktifkan. Mengutamakan preservasi volume laut.")

    clipped_success = False

    if 'gdf_coast' in globals() and gdf_coast is not None:
        print("⏳ Memotong grid menggunakan batas vektor (gdf_coast)...")
        try:
            poly_count = 0
            islands_saved = 0
            
            def extract_rings(geom):
                coords_list = []
                if geom.geom_type == 'Polygon':
                    coords_list.append(list(geom.exterior.coords))
                elif geom.geom_type == 'MultiPolygon':
                    for p in geom.geoms:
                        coords_list.append(list(p.exterior.coords))
                return coords_list

            # 1. Flatten all geometries menjadi Polygon individual
            raw_polygons = []
            for geom in gdf_coast.geometry:
                if geom is None or geom.is_empty: continue
                if geom.geom_type == 'Polygon':
                    raw_polygons.append(geom)
                elif geom.geom_type == 'MultiPolygon':
                    raw_polygons.extend(list(geom.geoms))
                elif geom.geom_type in ['LineString', 'MultiLineString']:
                    lines = [geom] if geom.geom_type == 'LineString' else list(geom.geoms)
                    for line in lines:
                        if len(line.coords) >= 3:
                            try:
                                p = Polygon(line.coords)
                                raw_polygons.append(p if p.is_valid else p.buffer(0))
                            except: pass

            # 2. Iterasi pemotongan dengan Scale-Aware Logic
            for poly in raw_polygons:
                pisau_potong = poly
                
                # [ENTERPRISE FIX]: Scale-Aware Island Preservation
                if buffer_tol_m != 0.0:
                    try:
                        pisau_coba = poly.buffer(buffer_tol_m)
                        if pisau_coba.is_empty:
                            # Failsafe: Jika pulau hancur karena disusutkan, pertahankan ukuran aslinya!
                            pisau_potong = poly
                            islands_saved += 1
                        else:
                            pisau_potong = pisau_coba
                    except: pass
                
                rings = extract_rings(pisau_potong)
                
                for ring in rings:
                    if len(ring) < 3: continue
                    x, y = zip(*ring)
                    x, y = list(x), list(y)
                        
                    if x[0] != x[-1] or y[0] != y[-1]:
                        x.append(x[0])
                        y.append(y[0])
                    
                    land_geom = GeometryList(np.array(x, dtype=np.double), np.array(y, dtype=np.double))
                    mk.mesh2d_delete(geometry_list=land_geom, delete_option=delete_opt_val, invert_deletion=False)
                    poly_count += 1
            
            if poly_count > 0:
                print(f"✅ Pemotongan presisi berhasil dieksekusi ({poly_count} poligon/pulau diproses).")
                if islands_saved > 0:
                    print(f"   🛡️ [AUTO-HEALER] {islands_saved} pulau kecil berhasil diselamatkan dari kepunahan toleransi buffer.")
                clipped_success = True
            else:
                print("⚠️ Tidak ada poligon valid yang ditemukan untuk dipotong.")
                
        except Exception as e:
            print(f"⚠️ Potong manual gagal: {e}. Mengeksekusi Auto fallback...")

    if not clipped_success:
        print("⏳ Mengeksekusi GSHHS auto-coastline clipping sebagai fallback...")
        try:
            dfmt.meshkernel_delete_withcoastlines(mk=mk, res='f')
            print("✅ Pemotongan GSHHS berhasil.")
        except Exception as e:
            print(f"⚠️ GSHHS Clip failed: {e}")

    # =========================================================================
    # KUALITAS MESH & AUDIT STABILITAS COURANT
    # =========================================================================
    print("\n📊 [AUDIT KUALITAS MESH & STABILITAS]")
    try:
        ortho = mk.mesh2d_get_orthogonality().values
        smooth = mk.mesh2d_get_smoothness().values
        
        ortho = ortho[~np.isnan(ortho)]
        smooth = smooth[~np.isnan(smooth)]
        
        print("   ├ Orthogonality (Toleransi Delft3D < 0.1 | Sempurna = 0.0):")
        if len(ortho) > 0:
            max_ortho = np.max(ortho)
            print(f"   │  - Mean : {np.mean(ortho):.4f}")
            print(f"   │  - Max  : {max_ortho:.4f} {'⚠️ (Rawan Instabilitas)' if max_ortho > 0.1 else '✅ (Sangat Baik)'}")
        
        print("   ├ Smoothness / Rasio Ukuran Sel (Maksimal < 1.4 | Sempurna = 1.0):")
        if len(smooth) > 0:
            max_smooth = np.max(smooth)
            print(f"   │  - Mean : {np.mean(smooth):.4f}")
            print(f"   │  - Max  : {max_smooth:.4f} {'⚠️ (Transisi Terlalu Kasar)' if max_smooth > 1.4 else '✅ (Gradasi Halus)'}")

        illegalcells_gdf = dfmt.meshkernel_get_illegalcells(mk=mk)
        if not illegalcells_gdf.empty:
            print(f"   ├ Sel Terlipat (Illegal Cells) : {len(illegalcells_gdf)} sel. ⚠️ Perlu direparasi via RGFGRID.")
        else:
            print("   ├ Sel Terlipat (Illegal Cells) : 0 sel. ✅ Jaring 100% sehat.")
            
    except Exception as e:
        print(f"   ⚠️ Gagal menghitung statistik mesh: {e}")

    # =========================================================================
    # PHASE 4: NETWORK CONVERSION & ABSOLUTE INTERPOLATION
    # =========================================================================
    print("\n🔄 [PHASE 4] Konversi struktur ke UgridDataset (XUGrid)...")
    xu_grid_uds = dfmt.meshkernel_to_UgridDataset(mk=mk, crs=crs_str)

    print("⚓ Menginterpolasi Batimetri Absolut ke Jaringan XUGrid (mesh2d_node_z)...")
    data_bathy_interp = data_bathy_macro.interp(lon=xu_grid_uds.obj.mesh2d_node_x, lat=xu_grid_uds.obj.mesh2d_node_y)
    
    xu_grid_uds['mesh2d_node_z'] = data_bathy_interp.clip(max=10)

    # =========================================================================
    # PHASE 5: EXPORT & VISUALIZATION
    # =========================================================================
    print("💾 [PHASE 5] Finalisasi & Ekspor Model...")
    xu_grid_uds['mesh2d_node_z'] = xu_grid_uds['mesh2d_node_z'].fillna(-50.0)
    xu_grid_uds.obj.mesh2d_node_z.encoding["_FillValue"] = 1e20
    
    netfile = os.path.join(os.getcwd(), f'Refined_Model_net.nc')
    xu_grid_uds.ugrid.to_netcdf(netfile)
    print(f"✅ NetCDF tersimpan di: {netfile}")

except Exception as e:
    print(f"\n❌ [FATAL ERROR] Proses eksekusi spasial gagal!")
    print(f"Detail Kegagalan: {e}")

# =========================================================================
# RENDER VISUAL (Diblok tersendiri agar kegagalan grafik tidak memicu Fatal Error)
# =========================================================================
try:
    plt.close('all') 
    
    fig, ax = plt.subplots(figsize=(10, 8))
    ax.set_aspect('equal', adjustable='datalim')
    
    xu_grid_uds.grid.plot(ax=ax, linewidth=0.5, color='#3B82F6', zorder=1)
    
    if 'gdf_coast' in globals() and gdf_coast is not None:
        if any(gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])):
            gdf_coast.boundary.plot(ax=ax, color='#16A34A', linewidth=2.0, label="Clip Boundary", zorder=3)
        else:
            gdf_coast.plot(ax=ax, color='#16A34A', linewidth=2.0, label="Clip Boundary", zorder=3)
    
    gpd.GeoSeries([micro_poly_utm]).boundary.plot(ax=ax, color='magenta', linestyle='--', linewidth=2.5, label="AOI Mikro (DoC Zone)", zorder=4)

    ax.set_title(f"Clipped XUGrid Topology (Wireframe Mode)\nRefinement Base: {target_res}m", fontweight='bold', pad=15)
    ax.set_xlabel(f"Easting ({crs_str})")
    ax.set_ylabel(f"Northing ({crs_str})")
    
    min_x_aoi, min_y_aoi, max_x_aoi, max_y_aoi = micro_poly_utm.bounds
    view_margin = 2000
    ax.set_xlim(min_x_aoi - view_margin, max_x_aoi + view_margin)
    ax.set_ylim(min_y_aoi - view_margin, max_y_aoi + view_margin)
    ax.grid(True, linestyle=':', alpha=0.6, color='gray')
    
    import matplotlib.lines as mlines
    legend_elements = [
        mlines.Line2D([], [], color='#3B82F6', linewidth=1.5, label=f'Mesh Wireframe'),
        mlines.Line2D([], [], color='magenta', linewidth=2.5, linestyle='--', label='Micro AOI')
    ]
    if 'gdf_coast' in globals() and gdf_coast is not None:
        legend_elements.insert(1, mlines.Line2D([], [], color='#16A34A', linewidth=2.0, label='Clip Boundary (Asli)'))
        
    ax.legend(handles=legend_elements, loc='upper right', framealpha=0.9, edgecolor='black')

    plt.tight_layout()
    plt.show()
except Exception as e:
    print(f"⚠️ [WARNING] Proses render plot visual diabaikan karena peringatan Matplotlib: {e}")

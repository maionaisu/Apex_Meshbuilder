# [Code Cell 6] - ADAPTIVE REFINEMENT, DEEP RELAXATION & TOPOLOGY AUDIT
import os
import gc
import numpy as np
import pandas as pd
import xarray as xr
import geopandas as gpd
import matplotlib.pyplot as plt
import scipy.ndimage as ndimage
from pyproj import Transformer
import dfm_tools as dfmt
from meshkernel import MeshKernel, OrthogonalizationParameters, ProjectToLandBoundaryOption, GeometryList
import matplotlib.lines as mlines

print("🧩 [TAHAP 5] ADAPTIVE MESH REFINEMENT & STRICT TOPOLOGY AUDIT")

# =========================================================================
# 1. STATE VALIDATION & MEMORY SYNC
# =========================================================================
required_states = ['mk', 'target_epsg', 'micro_poly_utm']
missing_states = [k for k in required_states if k not in globals()]
if missing_states:
    raise RuntimeError(f"❌ [FATAL] State memori hilang: {missing_states}. Harap re-run Tahap 4.")

mk = globals()['mk']
target_epsg = globals()['target_epsg']
crs_str = f"EPSG:{target_epsg}"
micro_poly_utm = globals()['micro_poly_utm']
gdf_coast = globals().get('gdf_coast', None)

# Sinkronisasi parameter dari Tahap 3 & 4 (ERA5 & DoC)
doc_depth = globals().get('doc_depth', -5.0)
target_res = float(input("📐 Masukkan Resolusi Jaring Halus Pesisir/Inner (m) [20.0]: ") or 20.0)

# =========================================================================
# 2. RAM-SAFE DISK-STREAMING (FULL MACRO GRID CONTEXT)
# =========================================================================
data_bathy_macro = globals().get('data_bathy_macro')

if data_bathy_macro is None:
    print("\n⏳ [PHASE 1] Membangun Peta Pemandu Refinement (Full Domain - RAM Safe)...")
    bathy_path = globals().get('bathy_path', '')
    if not bathy_path or not os.path.exists(bathy_path):
        bathy_path = input("📂 Masukkan path file Batimetri Tergabung (.xyz): ").strip().strip('\'"').replace('"', '')
    
    print("   ├ Mengekstrak Bounding Box dari Topologi Makro...")
    mesh_geom = mk.mesh2d_get()
    min_x, max_x = np.min(mesh_geom.node_x), np.max(mesh_geom.node_x)
    min_y, max_y = np.min(mesh_geom.node_y), np.max(mesh_geom.node_y)
    
    grid_spacing = target_res / 2.0  
    gx = np.arange(min_x, max_x + grid_spacing, grid_spacing)
    gy = np.arange(min_y, max_y + grid_spacing, grid_spacing)
    
    count = np.zeros((len(gx)-1, len(gy)-1), dtype=np.float32)
    z_sum = np.zeros((len(gx)-1, len(gy)-1), dtype=np.float32)
    
    print("   ├ Membaca XYZ secara Streaming (Mencegah RAM Overflow)...")
    tr = Transformer.from_crs("EPSG:4326", crs_str, always_xy=True)
    chunk_size = 5_000_000
    is_wgs84 = None
    
    for chunk_idx, chunk in enumerate(pd.read_csv(bathy_path, delim_whitespace=True, header=None, names=['x','y','z'], dtype=np.float32, chunksize=chunk_size)):
        if is_wgs84 is None:
            is_wgs84 = chunk['x'].abs().max() <= 180 and chunk['y'].abs().max() <= 90
            if is_wgs84:
                print(f"   ├ Mengonversi WGS84 ke {crs_str} on-the-fly...")
                
        if is_wgs84:
            tx, ty = tr.transform(chunk['x'].values, chunk['y'].values)
        else:
            tx, ty = chunk['x'].values, chunk['y'].values
            
        tz = chunk['z'].values
        
        # Filter titik yang berada di dalam Full Domain Makro
        valid_mask = (tx >= min_x) & (tx <= max_x) & (ty >= min_y) & (ty <= max_y)
        tx, ty, tz = tx[valid_mask], ty[valid_mask], tz[valid_mask]
        
        if len(tx) > 0:
            c_chunk, _, _ = np.histogram2d(tx, ty, bins=[gx, gy])
            z_chunk, _, _ = np.histogram2d(tx, ty, bins=[gx, gy], weights=tz)
            count += c_chunk
            z_sum += z_chunk
            print(f"   │  └ Chunk {chunk_idx+1}: {len(tx):,} titik diekstrak ke dalam Pemandu Makro.")
        else:
             print(f"   │  └ Chunk {chunk_idx+1}: Diabaikan (di luar domain).")
        
    gc.collect()
    
    print("   ├ Menyelesaikan Interpolasi Pemandu Eksterior...")
    with np.errstate(divide='ignore', invalid='ignore'):
        grid_z_raw = np.true_divide(z_sum, count)
        grid_z_raw[count == 0] = np.nan
        
    grid_z = grid_z_raw.T 
    mask = np.isnan(grid_z)
    if mask.any():
        ind = ndimage.distance_transform_edt(mask, return_distances=False, return_indices=True)
        grid_z = grid_z[tuple(ind)]

    gx_mid, gy_mid = gx[:-1] + np.diff(gx)/2, gy[:-1] + np.diff(gy)/2
    data_bathy_macro = xr.DataArray(data=grid_z, coords={"lat": gy_mid, "lon": gx_mid}, dims=("lat", "lon"))
    globals()['data_bathy_macro'] = data_bathy_macro
    print("✅ Peta Pemandu berhasil diamankan di memori.")

# =========================================================================
# 3. COURANT TARGETED REFINEMENT (SURF ZONE ONLY)
# =========================================================================
print(f"\n⚙️ [PHASE 2] Memicu Courant Refinement ({target_res}m) via Deltares Kernel...")
print(f"   ├ Membatasi area komputasi absolut pada Surf Zone Limit (DoC: {doc_depth:.2f}m).")

# [ENTERPRISE FIX]: Menggunakan -9999.0 bukan 999.0!
# Dalam algoritma Courant Deltares, elevasi tinggi (999.0) dianggap laut super dangkal (h=1), 
# yang memicu MeshKernel crash karena mencoba me-refine seluruh samudra!
# Dengan -9999.0 (kedalaman 10km), Kernel akan MENGABAIKAN area offshore secara total.
data_bathy_filled = data_bathy_macro.fillna(-9999.0)
bathy_da_active = data_bathy_filled.where(data_bathy_filled >= doc_depth, other=-9999.0)

# Eksekusi Meshing C++
dfmt.refine_basegrid(mk=mk, data_bathy_sel=bathy_da_active, min_edge_size=target_res)

# =========================================================================
# 4. SECONDARY DEEP RELAXATION (CRITICAL FIX FOR D-FLOW FM < 0.1 ORTHO)
# =========================================================================
print("\n🧘 [PHASE 3] Eksekusi Secondary Deep Relaxation (Post-Refinement)...")
print("   ├ Menghaluskan transisi rasio ukuran sel (Smoothness).")
print("   ├ Memaksa Ortogonalitas kembali di bawah ambang batas < 0.1.")

ortho_params = OrthogonalizationParameters()
ortho_params.number_of_iterations = 500 # Hardened untuk precision D-Waves
empty_boundary = GeometryList(np.empty(0, dtype=np.double), np.empty(0, dtype=np.double))

try:
    mk.mesh2d_compute_orthogonalization(
        ProjectToLandBoundaryOption.DO_NOT_PROJECT_TO_LANDBOUNDARY,
        ortho_params,
        empty_boundary
    )
    print("✅ Secondary Orthogonalization Selesai.")
except Exception as e:
    print(f"⚠️ [WARNING] Secondary relaxation warning: {e}")

# =========================================================================
# 5. ERROR HANDLING: ILLEGAL CELL PURGE
# =========================================================================
print("\n🔍 [PHASE 4] Mendeteksi dan Membakar Illegal Cells (Non-Convex Faces)...")
try:
    illegal_gdf = dfmt.meshkernel_get_illegalcells(mk=mk)
    if not illegal_gdf.empty:
        count_illegal = len(illegal_gdf)
        print(f"⚠️ Ditemukan {count_illegal} Illegal Cells! Menghapus index korup dari topologi...")
        for idx in illegal_gdf.index:
            try: mk.mesh2d_delete_face(idx)
            except: pass
        print("✅ Illegal cells berhasil direparasi.")
    else:
        print("✅ Jaring 100% sehat. Nol (0) Illegal Cells terdeteksi.")
except AttributeError:
    try:
        errors = mk.mesh2d_get_errors()
        if len(errors) > 0:
            print(f"⚠️ Ditemukan {len(errors)} error topology. Analisis lanjutan diperlukan.")
    except Exception as e:
        print(f"⚠️ Audit bypass: {e}")

# =========================================================================
# 6. D-FLOW FM & D-WAVES STRICT METRIC AUDIT
# =========================================================================
print("\n📊 [PHASE 5] AUDIT KUALITAS MESH & STABILITAS COURANT")
try:
    ortho = mk.mesh2d_get_orthogonality().values
    smooth = mk.mesh2d_get_smoothness().values
    
    ortho = ortho[(~np.isnan(ortho)) & (ortho != -999.0)]
    smooth = smooth[(~np.isnan(smooth)) & (smooth != -999.0)]
    
    print("   ├ Orthogonality (Toleransi D-Flow FM < 0.1 | Sempurna = 0.0):")
    if len(ortho) > 0:
        max_ortho = np.max(ortho)
        print(f"   │  - Mean : {np.mean(ortho):.4f}")
        print(f"   │  - Max  : {max_ortho:.4f} {'⚠️ (Rawan Instabilitas Momentum)' if max_ortho > 0.1 else '✅ (Memenuhi Standar)'}")
    
    print("   ├ Smoothness / Rasio Resolusi (Maksimal < 1.4 | Sempurna = 1.0):")
    if len(smooth) > 0:
        max_smooth = np.max(smooth)
        print(f"   │  - Mean : {np.mean(smooth):.4f}")
        print(f"   │  - Max  : {max_smooth:.4f} {'⚠️ (Rawan Refleksi D-Waves)' if max_smooth > 1.4 else '✅ (Gradasi Halus)'}")

except Exception as e:
    print(f"   ⚠️ Gagal menghitung statistik mesh: {e}")

# =========================================================================
# 7. ENTERPRISE VISUALIZATION (PRE-CLIP WIREFRAME)
# =========================================================================
print("\n🎨 [PHASE 6] Merender Pratinjau Arsitektur Refinement...")
try:
    plt.close('all') 
    fig, ax = plt.subplots(figsize=(12, 10))
    ax.set_aspect('equal')
    
    mk.mesh2d_get().plot_edges(ax, color='#3B82F6', linewidth=0.3, zorder=1)
    
    if gdf_coast is not None:
        if any(gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])):
            gdf_coast.boundary.plot(ax=ax, color='#16A34A', linewidth=2.0, label="Clip Boundary", zorder=3)
        else:
            gdf_coast.plot(ax=ax, color='#16A34A', linewidth=2.0, label="Clip Boundary", zorder=3)
            
    gpd.GeoSeries([micro_poly_utm]).boundary.plot(ax=ax, color='magenta', linestyle='--', linewidth=2.5, label="AOI Mikro", zorder=4)

    try:
        # Contour diplot menggunakan data_bathy_macro penuh agar garisnya sempurna melintasi grid
        cs = ax.contour(data_bathy_macro.lon, data_bathy_macro.lat, data_bathy_macro.values, 
                        levels=[doc_depth], colors='#EF4444', linestyles='dotted', linewidths=2.5, zorder=5)
        
        paths = cs.get_paths() if hasattr(cs, 'get_paths') else cs.collections[0].get_paths()
        
        min_x_aoi, min_y_aoi, max_x_aoi, max_y_aoi = micro_poly_utm.bounds
        for path in paths:
            v = path.vertices
            # Plot bintang hanya jika berada di sekitar area Micro AOI
            valid_v = v[(v[:,0] >= min_x_aoi-2000) & (v[:,0] <= max_x_aoi+2000) & (v[:,1] >= min_y_aoi-2000) & (v[:,1] <= max_y_aoi+2000)]
            if len(valid_v) > 0:
                ax.plot(valid_v[:, 0], valid_v[:, 1], marker='*', color='#EF4444', markersize=6, linestyle='None', zorder=6, markevery=15)
    except Exception as e:
        print(f"⚠️ [WARNING] Gagal mem-plot garis kontur Surf Zone: {e}")

    ax.set_title(f"Refined Spatial Topology (Pre-Clip State)\nSecondary Relaxation Applied | Target: {target_res}m", fontweight='bold', pad=15)
    ax.set_xlabel(f"Easting ({crs_str})")
    ax.set_ylabel(f"Northing ({crs_str})")
    
    view_margin = 1500
    ax.set_xlim(min_x_aoi - view_margin, max_x_aoi + view_margin)
    ax.set_ylim(min_y_aoi - view_margin, max_y_aoi + view_margin)
    ax.grid(True, linestyle=':', alpha=0.6, color='gray')
    
    legend_elements = [
        mlines.Line2D([], [], color='#3B82F6', linewidth=1.5, label=f'Refined Mesh Wireframe'),
        mlines.Line2D([], [], color='magenta', linewidth=2.5, linestyle='--', label='Micro AOI (Active Zone)'),
        mlines.Line2D([], [], color='#EF4444', marker='*', markersize=8, linestyle='dotted', linewidth=2.5, label=f'Surf Zone Limit (DoC: {doc_depth:.2f}m)')
    ]
    if gdf_coast is not None:
        legend_elements.insert(1, mlines.Line2D([], [], color='#16A34A', linewidth=2.0, label='Coastline (Future Clip)'))
        
    ax.legend(handles=legend_elements, loc='upper right', framealpha=0.9, edgecolor='black')

    plt.tight_layout()
    plt.show()

except Exception as e:
    print(f"⚠️ [WARNING] Proses render plot visual diabaikan: {e}")

globals()['mk'] = mk
print("✅ [TAHAP 5 SELESAI] Topology disiapkan untuk Landward Clipping (Tahap 6).")

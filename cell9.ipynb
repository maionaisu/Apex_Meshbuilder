# =========================================================================
# [Code Cell 5] - MESH CLIPPING & BRUTE-FORCE RELAXATION (NO REFINEMENT)
# =========================================================================
import os
import sys
import numpy as np
import matplotlib.pyplot as plt
import geopandas as gpd
import xarray as xr
import xugrid as xu
from pyproj import Transformer
from shapely.geometry import Polygon, LineString, MultiPolygon
from shapely.ops import unary_union
import dfm_tools as dfmt
from meshkernel import (
    MeshKernel, 
    Mesh2d,
    OrthogonalizationParameters, 
    ProjectToLandBoundaryOption, 
    GeometryList,
    DeleteMeshOption
)
import matplotlib.lines as mlines

print("🕸️ [TAHAP 4] MEGA AOI CLIPPING & BRUTE-FORCE ORTHOGONALIZATION")
print("=========================================================================")
print("Fokus: Memuat jaring eksisting (_net.nc), memotong berdasarkan AOI,")
print("       lalu memaksakan relaksasi hingga mencapai target Orthogonality < 0.1.")
print("=========================================================================\n")

# 1. STATE VALIDATION & CRS SYNC
target_epsg = globals().get('target_epsg', "32749")
crs_str = f"EPSG:{target_epsg}"

# =========================================================================
# [EXPERT FIX] - FUNGSI PENYEMBUH & EKSTRAKTOR POLIGON
# =========================================================================
def extract_clean_polygons(geom):
    """Menyembuhkan LineString tertutup dan mengekstrak Polygon murni dari berbagai bentuk Geometri."""
    polys = []
    if geom is None or geom.is_empty:
        return polys
    if geom.geom_type == 'Polygon':
        polys.append(geom)
    elif geom.geom_type == 'MultiPolygon':
        polys.extend(list(geom.geoms))
    elif geom.geom_type in ['LineString', 'LinearRing']:
        coords = list(geom.coords)
        if len(coords) >= 3:
            if coords[0] != coords[-1]:
                coords.append(coords[0])  # Tutup garis
            if len(coords) >= 4:
                polys.append(Polygon(coords))
    elif geom.geom_type == 'MultiLineString':
        for line in geom.geoms:
            coords = list(line.coords)
            if len(coords) >= 3:
                if coords[0] != coords[-1]:
                    coords.append(coords[0])
                if len(coords) >= 4:
                    polys.append(Polygon(coords))
    elif geom.geom_type == 'GeometryCollection':
        for g in geom.geoms:
            polys.extend(extract_clean_polygons(g))
    return polys

# 2. DYNAMIC MEGA AOI INGESTION (CLI USER INPUT)
print("🌍 --- [INPUT] MEGA AOI (Batas Potong Jaring) ---")
print("Pilih metode input batas Mega AOI:")
print("  [1] Koordinat Manual Bounding Box (Latitude/Longitude) - DEFAULT")
print("  [2] File Vektor Organik (.shp / .geojson / .kml)")

choice = input("Pilih metode (1(Koordinat Manual) atau 2(File)) [Default: 1]: ").strip() or "1"
mega_poly_wgs84 = None

if choice == "1":
    print("\n✍️ Masukkan koordinat batas Mega AOI (WGS84):")
    n_val = float(input("   N (North/Utara)   [default: -8.369127] : ") or -8.369127)
    s_val = float(input("   S (South/Selatan) [default: -8.654036] : ") or -8.654036)
    e_val = float(input("   E (East/Timur)    [default: 112.778455]: ") or 112.778455)
    w_val = float(input("   W (West/Barat)    [default: 112.555617]: ") or 112.555617)
    
    # Construct WGS84 Bounding Box
    mega_poly_wgs84 = Polygon([(w_val, s_val), (e_val, s_val), (e_val, n_val), (w_val, n_val)])
    print("✅ Batas koordinat manual (Bounding Box) berhasil dibuat.")
    
elif choice == "2":
    file_raw = input("\n📂 Masukkan path file vektor batas AOI (.shp/.geojson/.kml): ").strip().strip('\'"').replace('"', '').replace("'", "")
    if not os.path.exists(file_raw) or not file_raw:
        raise FileNotFoundError(f"❌ File tidak ditemukan pada path: {file_raw}")
    
    print(f"📖 Membaca dan menyehatkan file vektor dari: {os.path.basename(file_raw)}...")
    
    # Robust Parser
    if file_raw.lower().endswith('.kml'):
        try:
            gpd.io.file.fiona.drvsupport.supported_drivers['KML'] = 'rw'
            gdf_aoi = gpd.read_file(file_raw)
        except Exception as e:
            print("⚠️ Memicu XML parser fallback untuk KML...")
            import xml.etree.ElementTree as ET
            try:
                tree = ET.parse(file_raw)
                root = tree.getroot()
                namespaces = {'kml': 'http://www.opengis.net/kml/2.2'}
                coords_elements = root.findall('.//kml:coordinates', namespaces) or root.findall('.//coordinates')
                raw_polys = []
                for elem in coords_elements:
                    text = elem.text.strip()
                    coords_list = []
                    for line in text.split():
                        parts = line.split(',')
                        if len(parts) >= 2:
                            coords_list.append((float(parts[0]), float(parts[1])))
                    if len(coords_list) >= 3:
                        raw_polys.append(Polygon(coords_list))
                if raw_polys:
                    gdf_aoi = gpd.GeoDataFrame(geometry=[unary_union(raw_polys)], crs="EPSG:4326")
                else:
                    raise RuntimeError("Gagal mengekstrak geometri polygon KML.")
            except Exception as xml_err:
                raise RuntimeError(f"Gagal memproses file KML: {xml_err}")
    else:
        gdf_aoi = gpd.read_file(file_raw)
    
    if gdf_aoi.crs is None:
        gdf_aoi = gdf_aoi.set_crs(epsg=4326)
    elif gdf_aoi.crs.to_epsg() != 4326:
        gdf_aoi = gdf_aoi.to_crs(epsg=4326)
    
    # [EXPERT FIX] - Ekstraksi dan Penyembuhan Geometri
    mega_polygons_wgs84 = []
    for geom in gdf_aoi.geometry:
        mega_polygons_wgs84.extend(extract_clean_polygons(geom))
    
    if not mega_polygons_wgs84:
        raise ValueError("❌ Gagal mengekstrak bentuk poligon yang valid dari file input.")
    
    mega_poly_wgs84 = unary_union(mega_polygons_wgs84)
    print("✅ Bentuk vektor berhasil disembuhkan dan disatukan.")

else:
    raise ValueError("Pilihan metode tidak valid!")

# Transform Mega AOI to Target UTM
tr_bounds = Transformer.from_crs("EPSG:4326", crs_str, always_xy=True)
if mega_poly_wgs84.geom_type == 'Polygon':
    exterior_coords = [tr_bounds.transform(x, y) for x, y in mega_poly_wgs84.exterior.coords]
    mega_poly_utm = Polygon(exterior_coords)
elif mega_poly_wgs84.geom_type == 'MultiPolygon':
    polys = [Polygon([tr_bounds.transform(x, y) for x, y in poly.exterior.coords]) for poly in mega_poly_wgs84.geoms]
    mega_poly_utm = unary_union(polys)
else:
    mega_poly_utm = mega_poly_wgs84.convex_hull
globals()['mega_poly_utm'] = mega_poly_utm

# 3. LOAD EXISTING _NET.NC VIA XUGRID (ROBUST METHOD)
print("\n🌐 --- [INPUT] MEMUAT JARING EKSISTING ---")
mk = MeshKernel()
nc_raw = input("\n📂 Masukkan path file jaring eksisting (_net.nc) [default: Apex_Final_Model_1.8m_Mesh_net.nc]: ").strip().strip('\'"').replace('"', '').replace("'", "") or "Apex_Final_Model_1.8m_Mesh_net.nc"
if not os.path.exists(nc_raw):
    raise FileNotFoundError(f"❌ File jaring tidak ditemukan pada path: {nc_raw}")
print(f"📖 Membaca jaring eksisting dari: {os.path.basename(nc_raw)}...")

try:
    print("⏳ Membongkar UGRID NetCDF dan merekonstruksi arsitektur jaring...")
    uds = xu.open_dataset(nc_raw)
    grid = uds.ugrid.grid

    node_x = np.ascontiguousarray(np.asarray(grid.node_x), dtype=np.double)
    node_y = np.ascontiguousarray(np.asarray(grid.node_y), dtype=np.double)
    edge_nodes = np.ascontiguousarray(np.asarray(grid.edge_node_connectivity).ravel(), dtype=np.int32)
    
    # Menangani variabel sel poligon (Face Nodes) & Filtering UGRID Padding (-1 / NaN)
    face_nodes_raw = np.asarray(grid.face_node_connectivity)
    valid_node_mask = face_nodes_raw != -1
    nodes_per_face_raw = valid_node_mask.sum(axis=1)
    
    # [EXPERT FIX] - Saring polygon degenerat (Kurang dari 3 node valid)
    valid_face_mask = nodes_per_face_raw >= 3
    degenerate_count = len(nodes_per_face_raw) - np.sum(valid_face_mask)
    if degenerate_count > 0:
        print(f"   ⚠️ Membuang {degenerate_count} polygon rusak (degenerat) dari file asal.")
        
    healthy_face_nodes_raw = face_nodes_raw[valid_face_mask]
    healthy_valid_node_mask = valid_node_mask[valid_face_mask]

    nodes_per_face = np.ascontiguousarray(healthy_valid_node_mask.sum(axis=1), dtype=np.int32)
    face_nodes = np.ascontiguousarray(healthy_face_nodes_raw[healthy_valid_node_mask], dtype=np.int32)

    mesh2d = Mesh2d(
        node_x=node_x, node_y=node_y, edge_nodes=edge_nodes, 
        face_nodes=face_nodes, nodes_per_face=nodes_per_face
    )
    
    mk.mesh2d_set(mesh2d)
    
    # Bersihkan sisa-sisa node atau edge yang terputus akibat pembuangan polygon degenerat
    if hasattr(mk, 'mesh2d_delete_unconnected_nodes'):
        mk.mesh2d_delete_unconnected_nodes()
        
    nodes_count = mk.mesh2d_get().node_x.size
    print(f"✅ Berhasil memuat jaring eksisting ({nodes_count:,} nodes) ke dalam memori.")
except Exception as e:
    raise RuntimeError(f"❌ Gagal membaca atau merekonstruksi file NetCDF: {e}")

# 4. HIGH-SPEED GEOMETRIC MESH CLIPPING
print("\n✂️ Mengeksekusi Operasi Mesh Clipping berdasarkan AOI...")

if nodes_count == 0:
    raise RuntimeError("⚠️ [FATAL BYPASS] Jaring kosong. Proses clipping dihentikan.")

try:
    # Memastikan kita mengambil garis luar (exterior) dari poligon untuk memotong bagian LUAR
    if mega_poly_utm.geom_type == 'MultiPolygon':
        print("⚠️ AOI terdeteksi sebagai MultiPolygon. Mengambil luasan terluas sebagai batas utama.")
        clip_poly = max(mega_poly_utm.geoms, key=lambda p: p.area)
    else:
        clip_poly = mega_poly_utm
        
    clip_poly = clip_poly.simplify(0.5, preserve_topology=True)
    x_clip, y_clip = clip_poly.exterior.coords.xy
    
    gl = GeometryList(
        np.ascontiguousarray(x_clip, dtype=np.double),
        np.ascontiguousarray(y_clip, dtype=np.double)
    )
    
    # Enum yang aman sesuai standar C++ Backend
    del_opt = DeleteMeshOption.INSIDE_NOT_INTERSECTED if hasattr(DeleteMeshOption, 'INSIDE_NOT_INTERSECTED') else DeleteMeshOption(0)
    
    try:
        # invert_deletion=True: Hapus semua sel di LUAR poligon AOI
        mk.mesh2d_delete(geometry_list=gl, delete_option=del_opt, invert_deletion=True)
    except Exception as fallback_e:
        # Jika versi lama
        mk.mesh2d_delete_outside_polygon(gl, del_opt)
        
    if hasattr(mk, 'mesh2d_delete_unconnected_nodes'):
        mk.mesh2d_delete_unconnected_nodes()
    
    nodes_count_after = mk.mesh2d_get().node_x.size
    print(f"✅ Clipping Selesai. Sisa node jaring pasca pemotongan: {nodes_count_after:,}")
except Exception as e:
    print(f"⚠️ [WARNING] Gagal melakukan clipping: {e}")

# Evaluasi Pra-Relaksasi
raw_before = mk.mesh2d_get_orthogonality().values
ortho_before = raw_before[(~np.isnan(raw_before)) & (raw_before != -999.0)]
if len(ortho_before) > 0:
    print(f"\n📊 Evaluasi PRA-RELAKSASI (Setelah Clip): Max = {np.max(ortho_before):.4f} | Mean = {np.mean(ortho_before):.4f}")

# 5. BRUTE-FORCE POST-CLIP ORTHOGONALIZATION
print("\n⚙️ [BRUTE-FORCE] Mengeksekusi Global Post-Clip Orthogonalization...")
iters = int(input("   Berapa iterasi pemijatan paksa yang diinginkan? (Saran: 500 - 2000) [1000]: ") or 1000)
print(f"⏳ Memijat paksa jaring sebanyak {iters} iterasi untuk mengejar Orthogonality < 0.1...")

ortho_params = OrthogonalizationParameters()
ortho_params.number_of_iterations = iters
empty_boundary = GeometryList(np.empty(0, dtype=np.double), np.empty(0, dtype=np.double))

success = False
try:
    mk.mesh2d_compute_orthogonalization(ProjectToLandBoundaryOption.DO_NOT_PROJECT_TO_LANDBOUNDARY, ortho_params, empty_boundary, empty_boundary)
    success = True
except Exception as e1:
    try: 
        mk.mesh2d_compute_orthogonalization(ProjectToLandBoundaryOption.DO_NOT_PROJECT_TO_LANDBOUNDARY, ortho_params, empty_boundary)
        success = True
    except Exception as e2:
        try:
            mk.mesh2d_compute_orthogonalization(ortho_params, empty_boundary)
            success = True
        except Exception as e3:
            print(f"⚠️ Relaksasi gagal. Exception tree: {e1} | {e2} | {e3}")

if success:
    print("   ✅ Pemijatan Global Selesai.")

# 6. ILLEGAL CELL PURGE (MEMBAKAR SEL MATI KARENA OVER-RELAXATION)
print("\n🔍 Membersihkan sel-sel yang rusak (Illegal Cells) akibat relaksasi paksa...")
try:
    illegal_gdf = dfmt.meshkernel_get_illegalcells(mk=mk)
    if not illegal_gdf.empty:
        for idx in sorted(illegal_gdf.index, reverse=True):
            try: mk.mesh2d_delete_face(idx)
            except: pass
        if hasattr(mk, 'mesh2d_delete_unconnected_nodes'):
            mk.mesh2d_delete_unconnected_nodes()
        print(f"   ✅ {len(illegal_gdf)} sel rusak berhasil dibakar.")
    else:
        print("   ✅ Tidak ada sel rusak baru. Jaring sehat.")
except Exception as e:
    pass

# 7. EVALUASI AKHIR PASCA-RELAKSASI
raw_after = mk.mesh2d_get_orthogonality().values
ortho_after = raw_after[(~np.isnan(raw_after)) & (raw_after != -999.0)]

max_ortho = 0.0
if len(ortho_after) > 0:
    max_ortho = np.max(ortho_after)
    mean_ortho = np.mean(ortho_after)
    print(f"\n📊 Evaluasi PASCA-RELAKSASI: Max = {max_ortho:.4f} | Mean = {mean_ortho:.4f}")
    if max_ortho < 0.1:
        print("   ✅ [SUCCESS] Target Orthogonality ideal (< 0.1) TERCAPAI!")
    else:
        print("   ⚠️ [WARNING] Orthogonality maksimum masih > 0.1. Jaring dapat digunakan, namun untuk kesempurnaan tambah iterasi.")

# 8. EXPORT CLIPPED & RELAXED MESH
out_mesh = os.path.join(os.getcwd(), "Apex_Clipped_Relaxed_Mesh_net.nc")
tmp_mesh = out_mesh + ".tmp"
print(f"\n💾 Mengekspor jaring yang sudah dipotong dan direlaksasi ke: {os.path.basename(out_mesh)}")
try:
    xu_grid_uds = dfmt.meshkernel_to_UgridDataset(mk=mk, crs=crs_str)
    xu_grid_uds.ugrid.to_netcdf(tmp_mesh)
    if os.path.exists(out_mesh):
        try: os.remove(out_mesh)
        except: pass
    os.replace(tmp_mesh, out_mesh)
    print("   ✅ Ekspor NetCDF Selesai.")
except Exception as e:
    print(f"   ⚠️ Gagal mengekspor file NetCDF: {e}")

# 9. RENDERER
try:
    plt.close('all')
    fig, ax = plt.subplots(figsize=(12, 10))
    ax.set_aspect('equal')
    
    mk.mesh2d_get().plot_edges(ax, color='#64748B', linewidth=0.5, zorder=1, alpha=0.9)
    
    label_poly = "Vektor AOI Clip Boundary" if choice == "2" else "Manual AOI Clip Boundary"
    gpd.GeoSeries([mega_poly_utm]).boundary.plot(ax=ax, color='#3B82F6', linewidth=2.5, linestyle='-', label=label_poly, zorder=3)
        
    ax.set_title(f"Post-Clip Brute-Force Relaxed Architecture\nMax Orthogonality: {max_ortho:.4f} | CRS: {crs_str}", fontweight='bold', fontsize=14, pad=15)
    ax.set_xlabel("Easting (m)")
    ax.set_ylabel("Northing (m)")
    ax.grid(True, linestyle=':', alpha=0.5)
    
    legend_elements = [
        mlines.Line2D([], [], color='#64748B', linewidth=1, label=f'Relaxed Mesh'),
        mlines.Line2D([], [], color='#3B82F6', linewidth=2.5, label='AOI (Clip Domain)')
    ]
    ax.legend(handles=legend_elements, loc='upper right')
    plt.tight_layout()
    plt.show()
except Exception as e:
    print(f"⚠️ Visualisasi gagal: {e}")

globals()['mk'] = mk
print("\n✅ [TAHAP SELESAI] Jaring siap digunakan untuk tahap simulasi / input setup.")

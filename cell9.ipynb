# [Code Cell]
import os
import numpy as np
import pandas as pd
import xarray as xr
import matplotlib.pyplot as plt
import xugrid as xu
import geopandas as gpd
from pyproj import Transformer
from scipy.spatial.distance import cdist

# Toleransi engine Excel
try:
    import openpyxl
except ImportError:
    print("⚠️ [WARNING] Library 'openpyxl' tidak ditemukan. Jika membaca .xlsx gagal, jalankan: pip install openpyxl")

print("🏖️ [TAHAP 9] ENTERPRISE SPATIAL SEDIMENT INTERPOLATION (SMART CLI)")

# =========================================================================
# 1. MEMUAT MESH ARCHITECTURE
# =========================================================================
mesh_file = "Apex_Final_Model_Mesh.nc"
if not os.path.exists(mesh_file):
    raise FileNotFoundError(f"❌ File {mesh_file} tidak ditemukan! Harap selesaikan Tahap 6.")

print(f"⏳ Membaca topologi laut dari {mesh_file}...")
ds_mesh = xu.open_dataset(mesh_file)
node_x = ds_mesh.grid.node_x
node_y = ds_mesh.grid.node_y
crs_str = f"EPSG:{target_epsg}" if 'target_epsg' in globals() else "EPSG:32749"

# =========================================================================
# 2. INPUT COASTLINE UNTUK CLIPPING/OVERLAY VISUAL
# =========================================================================
print("\n🗺️ --- INPUT BATAS DARATAN (COASTLINE) ---")
coast_path = input("📂 Masukkan path file .shp Coastline [Kosongkan/Enter jika skip]: ").strip().strip('\'"').replace('"', '')

gdf_coast = None
if coast_path and os.path.exists(coast_path):
    try:
        gdf_coast = gpd.read_file(coast_path)
        print(f"✅ Berhasil memuat Coastline dari: {os.path.basename(coast_path)}")
        # Sinkronisasi CRS
        if gdf_coast.crs and gdf_coast.crs.to_epsg() != int(crs_str.split(':')[1]):
            gdf_coast = gdf_coast.to_crs(crs_str)
            
        # Simpan ke globals untuk Tahap 10 dsb
        globals()['gdf_coast'] = gdf_coast 
    except Exception as e:
        print(f"⚠️ Gagal memuat Coastline: {e}")

# =========================================================================
# 3. SMART EXCEL/CSV DATA LOADER
# =========================================================================
print("\n📊 --- INPUT DATA SEDIMEN (SMART EXTRACTOR) ---")
while True:
    sed_path = input("📂 Masukkan path file Excel (.xlsx) atau CSV (.csv): ").strip().strip('\'"').replace('"', '')
    if os.path.exists(sed_path):
        break
    print("❌ File tidak ditemukan. Silakan periksa kembali path-nya.")

df_raw = pd.DataFrame()
if sed_path.lower().endswith('.xlsx'):
    try:
        xls = pd.ExcelFile(sed_path)
        print(f"\n📄 File Excel terdeteksi. Ditemukan {len(xls.sheet_names)} Sheets:")
        sheet_dict = {str(i+1): s for i, s in enumerate(xls.sheet_names)}
        for k, v in sheet_dict.items(): 
            print(f"  [{k}] {v}")
            
        sel = input("👉 Pilih nomor Sheet yang ingin diload [1]: ").strip() or "1"
        sheet_name = sheet_dict.get(sel, xls.sheet_names[0])
        print(f"⏳ Memuat Sheet: '{sheet_name}'...")
        df_raw = pd.read_excel(sed_path, sheet_name=sheet_name, header=None)
    except Exception as e:
        raise RuntimeError(f"Gagal membaca Excel: {e}")
else:
    print("⏳ Memuat CSV...")
    df_raw = pd.read_csv(sed_path, header=None)

# --- AUTO-HEADER DETECTOR ---
print("🔍 Menjalankan algoritma pendeteksi Header otomatis...")
best_row = 0
max_matches = 0
# Kata kunci pencarian (Case Insensitive)
keywords = ['LON', 'LAT', 'X', 'Y', 'D50', 'D10', 'D90', 'PARAMETER', 'SEDIMEN']

for i in range(min(20, len(df_raw))):
    row_vals = [str(v).upper() for v in df_raw.iloc[i].values if pd.notna(v)]
    matches = sum(1 for k in keywords if any(k in rv for rv in row_vals))
    if matches > max_matches:
        max_matches = matches
        best_row = i

print(f"✅ Header dominan terdeteksi pada baris ke-{best_row+1} di dalam file.")
df_sed = df_raw.iloc[best_row+1:].copy()

# Set Header
raw_columns = [str(c).strip() for c in df_raw.iloc[best_row].values]
# Handle nama kolom duplikat (misal: "Unnamed")
df_sed.columns = [f"{c}_{i}" if raw_columns.count(c) > 1 else c for i, c in enumerate(raw_columns)]
df_sed = df_sed.dropna(axis=1, how='all') # Buang kolom yang isinya kosong semua

cols = df_sed.columns.tolist()
print(f"\n📋 Kolom yang tersedia: {cols}")

# --- SMART COLUMN SUGGESTION ---
guess_x = next((c for c in cols if 'LON' in c.upper() or 'X' in c.upper()), cols[0])
guess_y = next((c for c in cols if 'LAT' in c.upper() or 'Y' in c.upper()), cols[1] if len(cols)>1 else cols[0])
guess_val = next((c for c in cols if 'D50' in c.upper() or 'D90' in c.upper() or 'D10' in c.upper()), cols[2] if len(cols)>2 else cols[-1])

print("\n⚙️ Silakan verifikasi kolom yang akan digunakan (Tekan Enter jika saran benar):")
sel_x = input(f"   📍 Kolom Longitude/X [{guess_x}]: ").strip() or guess_x
sel_y = input(f"   📍 Kolom Latitude/Y  [{guess_y}]: ").strip() or guess_y
sel_val = input(f"   📏 Kolom Parameter (D50/D90) [{guess_val}]: ").strip() or guess_val

if not all(c in df_sed.columns for c in [sel_x, sel_y, sel_val]):
    raise ValueError("❌ Ada nama kolom yang tidak sesuai dengan daftar yang tersedia!")

# --- DATA CLEANING & EXTRACTION ---
# Konversi ke numerik secara paksa (string/teks error akan jadi NaN)
df_sed[sel_x] = pd.to_numeric(df_sed[sel_x], errors='coerce')
df_sed[sel_y] = pd.to_numeric(df_sed[sel_y], errors='coerce')
df_sed[sel_val] = pd.to_numeric(df_sed[sel_val], errors='coerce')

df_sed = df_sed.dropna(subset=[sel_x, sel_y, sel_val])
sample_lon = df_sed[sel_x].values
sample_lat = df_sed[sel_y].values
sample_val = df_sed[sel_val].values 

print(f"✅ Berhasil memurnikan {len(sample_val)} titik sampel untuk parameter '{sel_val}'.")

# =========================================================================
# 4. TRANSFORMASI CRS (WGS84 -> UTM)
# =========================================================================
is_wgs84 = np.max(np.abs(sample_lon)) <= 180 and np.max(np.abs(sample_lat)) <= 90
if is_wgs84:
    print(f"🔄 Mengonversi titik sampel WGS84 ke {crs_str}...")
    tr = Transformer.from_crs("EPSG:4326", crs_str, always_xy=True)
    sample_x, sample_y = tr.transform(sample_lon, sample_lat)
else:
    sample_x, sample_y = sample_lon, sample_lat

# =========================================================================
# 5. ALGORITMA INVERSE DISTANCE WEIGHTING (IDW) KINERJA TINGGI
# =========================================================================
print(f"\n⚙️ Mengeksekusi Interpolasi IDW ke {len(node_x):,} Node Jaring...")
# Menghitung matriks jarak antara semua node mesh dengan semua titik sampel
mesh_coords = np.column_stack((node_x, node_y))
sample_coords = np.column_stack((sample_x, sample_y))

# scipy cdist menghitung jarak Euclidean murni
distances = cdist(mesh_coords, sample_coords)
distances[distances == 0] = 1e-10

# Formula IDW: W_i = 1 / d^p (Power / p biasanya 2)
power = 2.0
weights = 1.0 / (distances ** power)

# Z = Sum(W_i * Z_i) / Sum(W_i)
interp_val_mm = np.sum(weights * sample_val, axis=1) / np.sum(weights, axis=1)

# =========================================================================
# 6. FORMULASI HIDRODINAMIKA MADSEN (SEDIMEN -> Ks Nikuradse)
# =========================================================================
print("\n🧮 Mengonversi ukuran butir sedimen (mm) menjadi Kekasaran Nikuradse Ks (m)...")
# Asumsi data dalam mm. Diubah ke meter, lalu dikalikan 2.5 (Skin Friction Theory)
# Note: Walaupun pengguna memilih D90, rasio proporsional tetap aman digunakan sbg basis Ks dasar
interp_val_m = interp_val_mm / 1000.0
ks_nikuradse = 2.5 * interp_val_m

avg_ks = np.mean(ks_nikuradse)
print(f"   -> Rata-rata Kekasaran Dasar: {avg_ks:.5f} m")

# =========================================================================
# 7. EXPORT FILE KEKASARAN DELFT3D (.XYZ)
# =========================================================================
out_dir = os.path.join(os.getcwd(), "Ecosystem_Forcing")
os.makedirs(out_dir, exist_ok=True)
fric_file = os.path.join(out_dir, f"Friction_Base_{sel_val}.xyz")

print(f"💾 Mengekspor matriks spasial friksi ke: {fric_file}")
df_out = pd.DataFrame({'x': node_x, 'y': node_y, 'z': ks_nikuradse})
df_out.to_csv(fric_file, sep=' ', index=False, header=False)

# Simpan state ke globals agar bisa digunakan oleh Tahap 10
globals()['spatial_friction_ks'] = ks_nikuradse

# =========================================================================
# 8. ENTERPRISE VISUALIZATION (SEDIMENT DIGITAL TWIN)
# =========================================================================
try:
    plt.close('all')
    fig, ax = plt.subplots(figsize=(12, 10), dpi=150)
    ax.set_aspect('equal', adjustable='datalim')

    # Buat Xarray Ugrid sementara untuk plotting presisi
    temp_uds = xu.UgridDataset(ds_mesh.grid)
    temp_uds['ks'] = xr.DataArray(ks_nikuradse, dims=[ds_mesh.grid.node_dimension])
    
    # Plot IDW Spasial
    # Karena jaring hanya ada di laut (hasil crop coastline), kontur IDW tidak akan overlap ke darat
    plot_obj = temp_uds['ks'].ugrid.plot(ax=ax, cmap='YlOrBr', add_colorbar=False, zorder=1)
    
    # Plot Titik Sampel Asli
    ax.scatter(sample_x, sample_y, c='blue', marker='^', s=45, zorder=3, edgecolors='white', linewidths=0.8, label=f'Sampel {sel_val}')
    
    # Overlay Mesh Wireframe
    ds_mesh.grid.plot(ax=ax, linewidth=0.1, color='gray', alpha=0.3, zorder=2)
    
    # Plot Land Boundary (Coastline) sebagai outline penegas daratan
    if gdf_coast is not None:
        if any(gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])):
            gdf_coast.boundary.plot(ax=ax, color='#16A34A', linewidth=2.0, zorder=4, label="Garis Pesisir (Darat)")
        else:
            gdf_coast.plot(ax=ax, color='#16A34A', linewidth=2.0, zorder=4, label="Garis Pesisir (Darat)")
            
    cbar = plt.colorbar(plot_obj, ax=ax, label=f'Kekasaran Dasar Nikuradse berdasar {sel_val}, $K_s$ (meter)', fraction=0.046, pad=0.04)
    
    ax.set_title(f"Distribusi Spasial Sedimen & Kekasaran Dasar\nMetode Interpolasi: Inverse Distance Weighting (IDW) pada {sel_val}", fontweight='bold', fontsize=14, pad=15)
    ax.set_xlabel(f"Easting ({crs_str})", fontsize=12)
    ax.set_ylabel("Northing", fontsize=12)
    
    ax.grid(True, linestyle=':', alpha=0.6, color='gray')
    ax.legend(loc='best', framealpha=0.9, edgecolor='black')

    plt.tight_layout()
    plt.show()

except Exception as e:
    print(f"⚠️ [WARNING] Proses render plot visual mengalami kendala: {e}")

print("="*60)
print("🚀 TAHAP 9: SPATIAL SEDIMENT IDW SELESAI!")
print("============================================================")

def _section(title: str) -> widgets.HTML:
    return widgets.HTML(
        f'<div style="margin:10px 0 4px 0;padding:5px 10px;'
        f'background:#1e3a5f;color:white;border-radius:4px;font-size:13px">'
        f'<b>{title}</b></div>'
    )

display(widgets.VBox([
    widgets.HTML(
        '<div style="background:#0f172a;color:#e2e8f0;padding:12px 16px;'
        'border-radius:6px;margin-bottom:8px">'
        '<h3 style="margin:0;font-size:16px">🌊 TAHAP 10 — DYNAMIC WAVE FORCING GENERATOR</h3>'
        '<span style="font-size:11px;color:#94a3b8">'
        'Multi-TPAR/BCW for SWAN | ERA5 NetCDF → .tpar/.bcw + .pli | '
        'Spreading: Auto ERA5 (dwi) / Physics fallback</span>'
        '</div>'
    ),

    _section('📁 1. Konfigurasi Path File'),
    w_macro, w_micro, w_era5, w_outdir,

    _section('⚙️  2. Parameter Pemrosesan'),
    widgets.HBox([w_method, w_bname]),
    widgets.HBox([w_export_mode, w_epsg]),
    widgets.HBox([w_t_start, w_t_end]),

    _section('🌀 3. Directional Spreading (σθ)'),
    widgets.HTML(
        '<div style="background:#f0f9ff;border-left:4px solid #0ea5e9;'
        'padding:8px 12px;font-size:12px;margin-bottom:4px">'
        '<b>Auto:</b> Prioritas → ERA5 <code>dwi</code> (radian→°) → '
        '<code>dspr</code> → physics ε=Hs/L₀ → [10°–30°]<br>'
        '<b>Manual:</b> Override dengan nilai konstanta Anda.'
        '</div>'
    ),
    widgets.HBox([w_spread_mode, w_spread_manual]),

    _section('▶  4. Eksekusi Pipeline'),
    html_status,
    btn_load,
    btn_reset,
    out_map,
    log_draw,
    btn_generate,
    out_phase2,
], layout=widgets.Layout(padding='8px'))
)

def parse_rgfgrid_grd(file_path: str):
    """Baca .grd RGFGRID Deltares secara tangguh."""
    if not file_path or not os.path.exists(file_path):
        return None, None, "Cartesian"

    with open(file_path, 'r') as f:
        lines = [ln.strip() for ln in f.readlines()]

    clean_lines, coord_sys = [], "Cartesian"
    for ln in lines:
        if ln.startswith('*'):
            continue
        if "coordinate system" in ln.lower():
            coord_sys = "Spherical" if "spherical" in ln.lower() else coord_sys
            continue
        if "missing value" in ln.lower():
            continue
        if ln:
            clean_lines.append(ln)

    mx, my, dim_idx = None, None, -1
    for idx, ln in enumerate(clean_lines):
        parts = ln.split()
        if len(parts) >= 2 and all(p.isdigit() for p in parts[:2]):
            mx, my, dim_idx = int(parts[0]), int(parts[1]), idx
            break

    if mx is None or my is None:
        raise ValueError(f"Dimensi grid (mx, my) tidak ditemukan: {file_path}")

    numeric_tokens = []
    for ln in clean_lines[dim_idx + 2:]:
        parts = ln.split()
        if not parts:
            continue
        if parts[0].startswith("Eta="):
            numeric_tokens.extend(parts[1:] if parts[0] != "Eta=" else parts[2:])
        else:
            numeric_tokens.extend(parts)

    all_coords = np.array([float(v) for v in numeric_tokens])
    half = mx * my
    x_grid = all_coords[:half].reshape((my, mx))
    y_grid = all_coords[half: 2 * half].reshape((my, mx))
    return x_grid, y_grid, coord_sys


def add_grid_overlay(m: Map, lon_grid: np.ndarray, lat_grid: np.ndarray,
                     color: str, n_lines: int = 12) -> None:
    """Tambahkan overlay kisi grid (perimeter + jaring) ke peta Leaflet."""
    my_g, mx_g = lon_grid.shape
    pts = []
    for i in range(mx_g):           pts.append([lat_grid[0, i],  lon_grid[0, i]])
    for j in range(my_g):           pts.append([lat_grid[j, -1], lon_grid[j, -1]])
    for i in reversed(range(mx_g)): pts.append([lat_grid[-1, i], lon_grid[-1, i]])
    for j in reversed(range(my_g)): pts.append([lat_grid[j, 0],  lon_grid[j, 0]])
    m.add_layer(Polygon(locations=pts, color=color, fill_color=color,
                        fill_opacity=0.08, weight=3, interactive=False))
    for i in range(0, mx_g, max(1, mx_g // n_lines)):
        m.add_layer(Polyline(
            locations=[[lat_grid[j, i], lon_grid[j, i]] for j in range(my_g)],
            color=color, weight=1, opacity=0.4, interactive=False))
    for j in range(0, my_g, max(1, my_g // n_lines)):
        m.add_layer(Polyline(
            locations=[[lat_grid[j, i], lon_grid[j, i]] for i in range(mx_g)],
            color=color, weight=1, opacity=0.4, interactive=False))


def _normalize_path(raw: str, fallback_dir: str = "") -> str:
    p = raw.strip().strip('"\'')
    if p and not os.path.exists(p) and fallback_dir:
        fb = os.path.join(fallback_dir, os.path.basename(p))
        if os.path.exists(fb):
            return fb
    return p


def _fix_dep_to_grd(path: str) -> str:
    if path.lower().endswith('.dep'):
        for candidate in [path[:-4] + '.grd', path[:-4] + '.GRD']:
            if os.path.exists(candidate):
                logger.info(f"[AUTO-FIX] .dep → .grd: {os.path.basename(candidate)}")
                return candidate
    return path


def detect_spreading_from_era5(
    ds_wave: xr.Dataset,
    ds_slice: xr.Dataset,
    lat_name: str,
    lon_name: str,
    lat_idx: int,
    lon_idx: int,
    hs_arr: np.ndarray,
    tp_arr: np.ndarray,
    manual_value: float | None = None
) -> tuple[np.ndarray, str]:
    """Mendeteksi directional spreading (σθ, derajat) per timestep dari ERA5/Physics."""
    n_t = len(hs_arr)

    if manual_value is not None:
        arr = np.full(n_t, float(manual_value))
        return arr, f"manual override ({manual_value:.1f}°)"

    for var_name, (unit, label) in ERA5_SPREAD_CANDIDATES.items():
        if var_name not in ds_wave.data_vars:
            continue

        try:
            da_sta = ds_slice[var_name].isel({lat_name: lat_idx, lon_name: lon_idx})
            raw = da_sta.values.astype(float)

            if raw.shape[0] != n_t:
                raw = raw.ravel()[:n_t]

            if np.all(np.isnan(raw)):
                ds_area = ds_slice[var_name].isel({
                    lat_name: slice(max(0, lat_idx - 1), min(ds_slice.sizes[lat_name], lat_idx + 2)),
                    lon_name: slice(max(0, lon_idx - 1), min(ds_slice.sizes[lon_name], lon_idx + 2))
                })
                raw = ds_area.mean(dim=[lat_name, lon_name], skipna=True).values.astype(float)

            if np.all(np.isnan(raw)):
                logger.warning(f"  [SPREAD] Variabel '{var_name}' semua NaN, lanjut ke fallback.")
                continue

            if unit == 'radian':
                spread = np.degrees(raw)
            else:
                spread = raw.copy()

            nan_mask = np.isnan(spread)
            if nan_mask.any():
                idx_valid = np.where(~nan_mask)[0]
                idx_all   = np.arange(n_t)
                if len(idx_valid) > 1:
                    spread = np.interp(idx_all, idx_valid, spread[idx_valid])
                else:
                    spread[nan_mask] = 20.0

            spread = np.clip(spread, 5.0, 60.0)
            logger.info(f"  [SPREAD] ✅ Menggunakan: {label}  "
                        f"[{spread.min():.1f}°–{spread.max():.1f}°, mean={spread.mean():.1f}°]")
            return spread, label

        except Exception as e_var:
            logger.debug(f"  [SPREAD] Gagal baca '{var_name}': {e_var}")
            continue

    # Physics-based fallback (Mitsuyasu simplified)
    g  = 9.81
    Lp = np.where(tp_arr > 0.1, g * tp_arr**2 / (2.0 * np.pi), 1.0)
    hs_safe = np.where(np.isnan(hs_arr), 0.0, hs_arr)
    steepness = np.clip(hs_safe / Lp, 0.0, 0.10)
    spread = np.clip(10.0 + (20.0 / 0.06) * steepness, 10.0, 30.0)
    spread = np.where(np.isnan(hs_arr), np.nanmedian(spread), spread)

    label = (f"physics (steepness ε=Hs/L₀): "
             f"[{spread.min():.1f}°–{spread.max():.1f}°, mean={spread.mean():.1f}°]")
    logger.info(f"  [SPREAD] ⚠️  Fallback ke {label}")
    return spread, label


def scan_era5_spread_variables(ds: xr.Dataset) -> dict:
    found = {}
    for v, (unit, label) in ERA5_SPREAD_CANDIDATES.items():
        if v in ds.data_vars:
            found[v] = label
    return found



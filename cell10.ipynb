# FUNGSI PEMBANTU GEOSPASIAL & MATEMATIKA KRIGING
# =========================================================================
def compute_mean_sample_spacing(sample_xy: np.ndarray) -> float:
    """Mengestimasi jarak rata-rata antar sampel lapangan menggunakan metode K-NN (k=2)."""
    if len(sample_xy) < 2:
        return 500.0
    tree = cKDTree(sample_xy)
    dist, _ = tree.query(sample_xy, k=min(2, len(sample_xy)))
    if dist.ndim == 1:
        return float(np.mean(dist))
    return float(np.mean(dist[:, 1]))

def idw_interpolate(query_xy: np.ndarray, sample_xy: np.ndarray,
                    sample_vals: np.ndarray, k: int = 10, p: float = 2.0) -> np.ndarray:
    """Melakukan interpolasi Inverse Distance Weighting (IDW) berbasis cKDTree."""
    tree = cKDTree(sample_xy)
    k_actual = min(k, len(sample_vals))
    dist, idx = tree.query(query_xy, k=k_actual)
    dist = np.where(dist < 1e-10, 1e-10, dist)
    if dist.ndim == 1:
        dist = dist[:, np.newaxis]
        idx = idx[:, np.newaxis]
    weights = 1.0 / (dist ** p)
    values = np.sum(weights * sample_vals[idx], axis=1) / np.sum(weights, axis=1)
    return values

# -------------------------------------------------------------------------
# MESIN ORDINARY KRIGING VECTORIZED
# -------------------------------------------------------------------------
class OrdinaryKrigingEngine:
    """
    Mesin pemecah persamaan Ordinary Kriging lokal dengan kinerja tinggi.
    Dibuat menggunakan pendekatan vektor untuk mencegah kehabisan memori RAM.
    """
    def __init__(self, sample_xy: np.ndarray, sample_vals: np.ndarray, 
                 model: str = "exponential", range_a: float = 2000.0, 
                 sill_c: float = 1.0, nugget_c0: float = 0.0):
        self.sample_xy = sample_xy
        self.sample_vals = sample_vals
        self.model = model.lower()
        self.range_a = range_a
        self.sill_c = sill_c
        self.nugget_c0 = nugget_c0
        self.tree = cKDTree(sample_xy)

    def variogram(self, h: np.ndarray) -> np.ndarray:
        """Menghitung nilai semivariogram teoritis pada jarak h."""
        c0 = self.nugget_c0
        c = self.sill_c
        a = self.range_a
        h = np.where(h == 0, 1e-10, h)
        
        if self.model == "spherical":
            val = np.where(h <= a, 
                           c0 + c * (1.5 * (h / a) - 0.5 * (h / a)**3), 
                           c0 + c)
        elif self.model == "gaussian":
            val = c0 + c * (1.0 - np.exp(-3.0 * (h / a)**2))
        else: # Exponential
            val = c0 + c * (1.0 - np.exp(-3.0 * h / a))
        return val

    def solve_local_kriging(self, query_points: np.ndarray, k: int = 12) -> np.ndarray:
        """Menyelesaikan sistem persamaan matriks Kriging lokal dengan regularisasi."""
        num_queries = len(query_points)
        k_actual = min(k, len(self.sample_vals))
        
        dists, indices = self.tree.query(query_points, k=k_actual)
        if dists.ndim == 1:
            dists = dists[:, np.newaxis]
            indices = indices[:, np.newaxis]
            
        estimates = np.zeros(num_queries)
        
        for i in range(num_queries):
            idx = indices[i]
            local_pts = self.sample_xy[idx]
            local_vals = self.sample_vals[idx]
            local_dists = np.linalg.norm(local_pts[:, np.newaxis, :] - local_pts[np.newaxis, :, :], axis=-1)
            
            K = self.variogram(local_dists)
            
            A = np.zeros((k_actual + 1, k_actual + 1))
            A[:k_actual, :k_actual] = K
            A[:k_actual, k_actual] = 1.0
            A[k_actual, :k_actual] = 1.0
            
            np.fill_diagonal(A[:k_actual, :k_actual], np.diagonal(A[:k_actual, :k_actual]) + 1e-6)
            
            d_query = dists[i]
            r = np.zeros(k_actual + 1)
            r[:k_actual] = self.variogram(d_query)
            r[k_actual] = 1.0
            
            try:
                weights_lagrange = np.linalg.solve(A, r)
                weights = weights_lagrange[:k_actual]
                estimates[i] = np.sum(weights * local_vals)
            except np.linalg.LinAlgError:
                w_fallback = 1.0 / np.where(d_query < 1e-10, 1e-10, d_query)**2
                estimates[i] = np.sum(w_fallback * local_vals) / np.sum(w_fallback)
                
        return estimates

def apply_coastline_mask(node_xy: np.ndarray, coast_gdf: gpd.GeoDataFrame, crs_str: str) -> np.ndarray:
    """Memotong nilai simulasi di daratan menggunakan spatial join batas garis pantai."""
    print("   ⏳ Menerapkan pemotongan garis pantai (Coastline Masking) via Geopandas...")
    try:
        coast_gdf = coast_gdf.copy()
        coast_gdf['geometry'] = coast_gdf.geometry.buffer(0)
    except Exception: pass

    geom_types = coast_gdf.geom_type.unique()
    has_poly = any(g in geom_types for g in ['Polygon', 'MultiPolygon'])

    if not has_poly:
        print("   ⚠️  Coastline bertipe LineString — proses masking daratan dilewati.")
        return np.ones(len(node_xy), dtype=bool)

    node_gdf = gpd.GeoDataFrame(
        {'node_id': np.arange(len(node_xy))},
        geometry=[Point(x, y) for x, y in node_xy],
        crs=crs_str
    )

    land_gdf = coast_gdf[coast_gdf.geom_type.isin(['Polygon', 'MultiPolygon'])].copy()
    joined = gpd.sjoin(node_gdf, land_gdf[['geometry']], how='left', predicate='within')
    
    on_land = ~joined['index_right'].isna()
    on_land = on_land.groupby(level=0).any()
    
    water_mask = ~on_land.values
    print(f"   ✅ Masking selesai: {water_mask.sum():,} node di perairan, {(~water_mask).sum():,} node di daratan.")
    return water_mask

def distance_decay_blend(node_xy: np.ndarray, sample_xy: np.ndarray,
                         val_interpolated: np.ndarray, val_background: float,
                         r_inner: float, r_outer: float) -> np.ndarray:
    """Meluruhkan nilai interpolasi secara halus menuju nilai background berdasarkan fungsi cosinus."""
    tree = cKDTree(sample_xy)
    dist_to_nearest, _ = tree.query(node_xy, k=1)
    
    val_final = np.full_like(val_interpolated, val_background)
    
    mask_inner = dist_to_nearest <= r_inner
    val_final[mask_inner] = val_interpolated[mask_inner]
    
    mask_trans = (dist_to_nearest > r_inner) & (dist_to_nearest <= r_outer)
    if np.any(mask_trans):
        dist_t = dist_to_nearest[mask_trans]
        t = (dist_t - r_inner) / (r_outer - r_inner)
        alpha = (np.cos(t * np.pi) + 1.0) / 2.0
        val_final[mask_trans] = alpha * val_interpolated[mask_trans] + (1.0 - alpha) * val_background
        
    return val_final


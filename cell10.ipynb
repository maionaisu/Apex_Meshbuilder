    val_reg_base = ok_engine.solve_local_kriging(node_xy, k=k_val)
else:
    val_reg_base = idw_interpolate(node_xy, sample_xy_proj, sed_val, k=k_val, p=p_val)
val_reg_final = distance_decay_blend(node_xy, sample_xy_proj, val_reg_base, val_background, r_inner, r_outer)

# B. Penerapan Coastline Masking khusus untuk visualisasi jaring air
water_mask = np.ones(len(node_x), dtype=bool) 
gdf_coast = None
val_reg_masked = val_reg_final.copy()

if coast_path and os.path.exists(coast_path):
    print("\n🌊 [FASE 6] PENYARINGAN DARATAN (COASTLINE MASKING)")
    try:
        gdf_coast_raw = gpd.read_file(coast_path)
        if gdf_coast_raw.crs is not None and gdf_coast_raw.crs.to_epsg() != int(target_epsg):
            gdf_coast_raw = gdf_coast_raw.to_crs(crs_str)
        gdf_coast = gdf_coast_raw

        do_mask = input("   ❓ Berikan nilai NaN pada node daratan untuk kebersihan kontur? [Y/n]: ").strip().upper() != 'N'
        if do_mask:
            water_mask = apply_coastline_mask(node_xy, gdf_coast, crs_str)
            val_reg_masked = val_reg_final.copy().astype(float)
            val_reg_masked[~water_mask] = np.nan
        else:
            print("   ℹ️  Masking wilayah darat dilewati.")
    except Exception as e_coast:
        print(f"   ⚠️ Gagal memproses peta garis pantai: {e_coast}")

# =========================================================================
# 6. PEMBAGIAN FORMULASI UNIT & EKSPOR FILE DENGAN STRUKTUR DIREKTORI
# =========================================================================
print("\n📁 [FASE 7] SISTEM EKSPOR DUAL-GRID & DIREKTORI OUTPUT")

target_dir = input("   📂 Tentukan folder output ekspor file [Default: direktori aktif saat ini]: ").strip().strip('\'"')
if not target_dir:
    target_dir = os.getcwd()
os.makedirs(target_dir, exist_ok=True)

is_mm = input(f"   ❓ Apakah data input {param_label} terukur dalam satuan Milimeter (mm)? [Y/n]: ").strip().upper() != 'N'
convert = 1000.0 if is_mm else 1.0

# -------------------------------------------------------------------------
# [A] ALUR D-FLOW FM (MURNI UNTUK BOTTOM FRICTION KEKASARAN NIKURADSE KS)
# -------------------------------------------------------------------------
print("\n   [ALUR A: D-FLOW FM HYDRODYNAMIC BOTTOM FRICTION]")

# Input D-Flow FM bottom friction membutuhkan format Nikuradse (ks) dalam satuan METER
if '90' in param_label.upper(): suggested_const = 3.0
elif '10' in param_label.upper(): suggested_const = 1.0
else: suggested_const = 2.5
k_const = float(input(f"   ↳ Konstanta pengali kekasaran Nikuradse (ks = const * D50) [{suggested_const}]: ") or suggested_const)

# Hitung kekasaran Nikuradse ks dalam satuan METER (D50 dalam meter dikalikan konstanta)
val_reg_ks_export = (k_const * val_reg_final / convert)
# Atasi nilai daratan (NaN) agar mesh hidrodinamika tidak mengalami crash saat inisialisasi solver
val_reg_ks_export = np.where(np.isnan(val_reg_ks_export), (k_const * val_background / convert), val_reg_ks_export)

dfm_ks_file = os.path.join(target_dir, f"DFM_FlexibleMesh_Roughness_ks.xyz")
try:
    with open(dfm_ks_file, 'w') as f:
        for x, y, ks in zip(node_x, node_y, val_reg_ks_export):
            f.write(f"{x:.4f}    {y:.4f}    {ks:.8f}\n")
    print(f"   ✅ [D-FLOW FM SUCCESS] File bottom friction Nikuradse ks diekspor: {os.path.basename(dfm_ks_file)}")
except Exception as e_dfm:
    print(f"   ❌ Gagal mengekspor berkas D-Flow FM ks: {e_dfm}")

# Cadangan Ekspor Raw D50 dalam Meter (Jika sewaktu-waktu dibutuhkan)
dfm_sed_file = os.path.join(target_dir, f"DFM_FlexibleMesh_Raw_D50.xyz")
try:
    val_reg_d50_export = np.where(np.isnan(val_reg_final), val_background, val_reg_final) / convert
    with open(dfm_sed_file, 'w') as f:
        for x, y, d50 in zip(node_x, node_y, val_reg_d50_export):
            f.write(f"{x:.4f}    {y:.4f}    {d50:.8f}\n")
    print(f"   ℹ️  [BACKUP] Berkas cadangan diameter D50 (meter) juga tersimpan: {os.path.basename(dfm_sed_file)}")
except Exception: pass

# -------------------------------------------------------------------------
# [B] ALUR D-WAVES / SWAN (RECTILINEAR ROUGHNESS NIKURADSE KS)
# -------------------------------------------------------------------------
print("\n   [ALUR B: D-WAVES / SWAN RECTILINEAR BOTTOM FRICTION]")

# B1. Generasi SWAN Macro Grid (Rectilinear - ERA5 / Mega AOI Extent)
print("\n   [SWAN MACRO GRID] Memulai interpolasi rectilinear regional...")
dx_mac = float(input("   ↳ Tentukan ukuran resolusi sel grid regional SWAN Macro (m) [50.0]: ") or 50.0)
x_mac = np.arange(mac_min_x, mac_max_x + dx_mac, dx_mac)
y_mac = np.arange(mac_min_y, mac_max_y + dx_mac, dx_mac)
X_mac, Y_mac = np.meshgrid(x_mac, y_mac)
grid_mac_xy = np.c_[X_mac.ravel(), Y_mac.ravel()]

if engine_choice == "2":
    val_mac_base = ok_engine.solve_local_kriging(grid_mac_xy, k=k_val)
else:
    val_mac_base = idw_interpolate(grid_mac_xy, sample_xy_proj, sed_val, k=k_val, p=p_val)
val_mac_final = distance_decay_blend(grid_mac_xy, sample_xy_proj, val_mac_base, val_background, r_inner, r_outer)

# Konversi ke Kekasaran dasar Nikuradse (ks) dalam satuan METER
ks_mac_2d = (k_const * val_mac_final / convert).reshape(X_mac.shape)
swan_macro_file = os.path.join(target_dir, f"SWAN_Macro_Roughness_ks.txt")
try:
    np.savetxt(swan_macro_file, ks_mac_2d, fmt='%.6f', delimiter=' ')
    print(f"   ✅ [SWAN MACRO SUCCESS] File grid makro (Mega AOI) tersimpan: {os.path.basename(swan_macro_file)}")
except Exception as e_mac:
    print(f"   ❌ Gagal mengekspor berkas SWAN Macro: {e_mac}")

# B2. Generasi SWAN Micro Grid (Rectilinear - Focused Inner Area)
print("\n   [SWAN MICRO GRID] Memulai interpolasi rectilinear detail terfokus...")
dx_mic = float(input("   ↳ Tentukan ukuran resolusi sel grid lokal SWAN Micro (m) [10.0]: ") or 10.0)
dy_mic = dx_mic
x_mic = np.arange(mic_min_x, mic_max_x + dx_mic, dx_mic)
y_mic = np.arange(mic_min_y, mic_max_y + dy_mic, dy_mic)
X_mic, Y_mic = np.meshgrid(x_mic, y_mic)
grid_mic_xy = np.c_[X_mic.ravel(), Y_mic.ravel()]

if engine_choice == "2":
    val_mic_base = ok_engine.solve_local_kriging(grid_mic_xy, k=k_val)
else:
    val_mic_base = idw_interpolate(grid_mic_xy, sample_xy_proj, sed_val, k=k_val, p=p_val)
val_mic_final = distance_decay_blend(grid_mic_xy, sample_xy_proj, val_mic_base, val_background, r_inner, r_outer)

# Konversi ke Kekasaran dasar Nikuradse (ks) dalam satuan METER
ks_mic_2d = (k_const * val_mic_final / convert).reshape(X_mic.shape)
swan_micro_file = os.path.join(target_dir, f"SWAN_Micro_Roughness_ks.txt")
try:
    np.savetxt(swan_micro_file, ks_mic_2d, fmt='%.6f', delimiter=' ')
    print(f"   ✅ [SWAN MICRO SUCCESS] File grid mikro (Fokus Dalam) tersimpan: {os.path.basename(swan_micro_file)}")
except Exception as e_mic:
    print(f"   ❌ Gagal mengekspor berkas SWAN Micro: {e_mic}")

# =========================================================================
# 7. PANDUAN INTEGRASI PADA SOLVER SWAN (D-WAVES)
# =========================================================================
print("\n" + "=" * 80)
print("📑 PANDUAN INSTALASI & INJEKSI INPUT MODEL DELFT3D-FM:")
print("\n[A] MASUKAN MODEL UNTUK D-FLOW FM (Hidrodinamika - Aliran):")
print("    - Masukkan konfigurasi kekasaran dasar spasial ini pada file parameter eksternal (*.ext):")
print(f"      frictionTypeType = Nikuradse")
print(f"      frictionTypeFile = {os.path.basename(dfm_ks_file)}")
print("\n[B] MASUKAN MODEL UNTUK D-WAVES / SWAN (Propagasi Gelombang):")
print("    - Tambahkan konfigurasi ini pada modul input gelombang SWAN (*.mdw):")
print("    - Jaring Utama SWAN (Macro):")
print(f"      INPGRID FRICTION REGULAR {mac_min_x:.2f} {mac_min_y:.2f} 0.0 "
      f"{len(x_mac)-1} {len(y_mac)-1} {dx_mac:.2f} {dx_mac:.2f}")
print(f"      READINP FRICTION 1.0 '{swan_macro_file}' 1 0 FREE")
print("      FRICTION MADSEN")
print("    - Jaring Bersarang SWAN (Micro - Terfokus Estuari):")
print(f"      INPGRID FRICTION REGULAR {mic_min_x:.2f} {mic_min_y:.2f} 0.0 "
      f"{len(x_mic)-1} {len(y_mic)-1} {dx_mic:.2f} {dy_mic:.2f}")
print(f"      READINP FRICTION 1.0 '{swan_micro_file}' 1 0 FREE")
print("      FRICTION MADSEN")
print("=" * 80)

# =========================================================================
# 8. VISUALISASI INTEGRAL DAN PRESEPIK BEBAS BUG (MATPLOTLIB PRO)
# =========================================================================
print(f"\n🎨 [FASE 8] MEMBUAT GRAFIK KONTUR KOMPREHENSIF DENGAN MODEL: {engine_label.upper()}")

try:
    plt.close('all')

    triangles_list = []
    idx_p = 0
    for n in nodes_per_face:
        poly_nodes = face_nodes[idx_p: idx_p + n]
        idx_p += n
        for i in range(1, n - 1):
            triangles_list.append([poly_nodes[0], poly_nodes[i], poly_nodes[i + 1]])
    triang_full = mtri.Triangulation(node_x, node_y, np.asarray(triangles_list))

    vmin_data = sed_val.min()
    vmax_data = sed_val.max()

    fig = plt.figure(figsize=(15, 12), dpi=150)
    ax = fig.add_subplot(111)
    ax.set_aspect('equal')
    ax.set_facecolor('#b0d2ec')  # Skema warna air laut lepas

    n_levels = 20
    levels = np.linspace(vmin_data, vmax_data, n_levels)
    cmap = plt.cm.YlOrBr

    cf = ax.tricontourf(triang_full, val_reg_masked, levels=levels, cmap=cmap, alpha=0.90, zorder=2)
    cl = ax.tricontour(triang_full, val_reg_masked, levels=levels, colors='#3a2a10', linewidths=0.5, alpha=0.75, zorder=3)
    ax.clabel(cl, inline=True, inline_spacing=2, fontsize=7, fmt='%.2f')

    # Penggambaran garis pantai jika file GIS terdeteksi
    if gdf_coast is not None:
        try:
            has_poly_c = any(g in gdf_coast.geom_type.unique() for g in ['Polygon', 'MultiPolygon'])
            if has_poly_c:
                gdf_coast[gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])].plot(
                    ax=ax, color='#e5d5b7', edgecolor='#166534', linewidth=1.2, zorder=4)
            else:
                gdf_coast.plot(ax=ax, color='#166534', linewidth=1.5, zorder=4)
        except Exception: pass

    # Tampilkan stasiun sampel lapangan
    ax.scatter(sed_x_proj, sed_y_proj, c=sed_val, cmap=cmap, vmin=vmin_data, vmax=vmax_data,
               s=40, edgecolors='black', linewidth=0.8, zorder=8, label=f'Stasiun Sampel {param_label}')

    for i, (xi, yi, vi) in enumerate(zip(sed_x_proj, sed_y_proj, sed_val)):
        ax.annotate(f'#{i+1}: {vi:.2f}', xy=(xi, yi), xytext=(4, 4), textcoords='offset points',
                    fontsize=7, fontweight='bold', color='black', zorder=9)

    # 1. Plot Batas SWAN Macro Grid (Batas Terluar Mega AOI / ERA5 Scale)
    rect_macro = Rectangle((mac_min_x, mac_min_y), mac_max_x - mac_min_x, mac_max_y - mac_min_y,
                           lw=2.5, edgecolor='#dc2626', facecolor='none', ls='--', zorder=6,
                           label=f'SWAN Macro Grid (Mega AOI / ERA5 Scale)')
    ax.add_patch(rect_macro)

    # 2. Plot Batas SWAN Micro Grid (Fokus Aliran Dalam Terpilih)
    rect_micro = Rectangle((mic_min_x, mic_min_y), mic_max_x - mic_min_x, mic_max_y - mic_min_y,
                           lw=2.5, edgecolor='#7c3aed', facecolor='none', ls='-', zorder=7,
                           label=f'SWAN Micro Grid Terfokus ({dx_mic}m)')
    ax.add_patch(rect_micro)

    # Skala legenda warna (Colorbar)
    cbar = plt.colorbar(cf, ax=ax, label=f'Sebaran Spasial Diameter Butir {param_label} ({unit_str})', fraction=0.046, pad=0.04, shrink=0.85)
    cbar.ax.tick_params(labelsize=9)

    legend_elements = [
        mlines.Line2D([], [], color='none', marker='o', markerfacecolor='#f59e0b', markeredgecolor='black', markersize=7, label=f'Sampel {param_label} ({unit_str})'),
        mlines.Line2D([], [], color='#dc2626', ls='--', lw=2.2, label='Batas SWAN Macro (Skala ERA5)'),
        mlines.Line2D([], [], color='#7c3aed', ls='-', lw=2.2, label=f'Batas SWAN Micro Terfokus ({dx_mic}m)'),
    ]
    if gdf_coast is not None:
        legend_elements.append(mlines.Line2D([], [], color='#166534', lw=1.5, label='Garis Pantai'))

    ax.legend(handles=legend_elements, loc='upper right', framealpha=0.95, edgecolor='gray', fontsize=8)

    # Panel Ringkasan Metadata hasil analisis model spasial
    stats_text = (
        f"📊 METADATA INTEGRASI DUAL-GRID\n"
        f"Fokus Utama    : BOTTOM FRICTION (ks)\n"
        f"Model Spasial  : {engine_label.upper()}\n"
        f"Jumlah Sampel   : {len(sed_val)}\n"
        f"Rentang D50     : {sed_val.min():.2f} - {sed_val.max():.2f} {unit_str}\n"
        f"---------------------------------\n"
        f"Resolusi Macro  : {dx_mac:.1f} m (Mega AOI)\n"
        f"Resolusi Micro  : {dx_mic:.1f} m (Focused)\n"
        f"Batas Blending  : {r_inner:.0f}m s/d {r_outer:.0f}m\n"
        f"K-Neighbors     : {k_val}\n"
        f"Pengali Nikuradse: {k_const}\n"
    )
    if engine_choice == "2":
        stats_text += f"Bentuk Variogram: {var_model.upper()}\nRange Korelasi  : {range_a:.0f} m"
    else:
        stats_text += f"Bobot Jarak (P) : {p_val}"
        
    ax.text(0.02, 0.03, stats_text, transform=ax.transAxes, fontsize=8, verticalalignment='bottom',
            bbox=dict(boxstyle='round,pad=0.6', facecolor='white', alpha=0.92, edgecolor='gray', zorder=10))

    ax.set_title(f"Bottom Friction Generator ({param_label} -> Nikuradse ks) — Modul Hidrodinamika & Gelombang\nIntegrasi Jaring Fleksibel D-Flow FM Regional & Bersarang Rectilinear SWAN (D-Waves)", fontweight='bold', fontsize=12, pad=12)
    ax.set_xlabel(f"Easting Proyeksi ({crs_str}) [meter]", fontsize=10)
    ax.set_ylabel("Northing Proyeksi [meter]", fontsize=10)
    ax.grid(True, linestyle=':', alpha=0.5, color='gray')
    ax.ticklabel_format(style='sci', axis='both', scilimits=(0, 0))

    # =========================================================================
    # DETEKSI DAN AUTO-ZOOM PRESEPIK BEBAS BUG (SISTEM FALLBACK)
    # =========================================================================
    clean_sed_x = sed_x_proj[~np.isnan(sed_x_proj)]
    clean_sed_y = sed_y_proj[~np.isnan(sed_y_proj)]

    if len(clean_sed_x) > 0:
        f_min_x = min(clean_sed_x.min(), mic_min_x)
        f_max_x = max(clean_sed_x.max(), mic_max_x)
        f_min_y = min(clean_sed_y.min(), mic_min_y)
        f_max_y = max(clean_sed_y.max(), mic_max_y)
    else:
        f_min_x, f_max_x = mic_min_x, mic_max_x
        f_min_y, f_max_y = mic_min_y, mic_max_y

    if np.isnan(f_min_x) or np.isnan(f_max_x) or (f_max_x - f_min_x == 0):
        print("   ⚠️ Deteksi anomali pada koordinat zoom. Mengaktifkan batas jaring regional utama.")
        f_min_x, f_max_x = node_x.min(), node_x.max()
        f_min_y, f_max_y = node_y.min(), node_y.max()

    span_x = max(f_max_x - f_min_x, 1000.0)
    span_y = max(f_max_y - f_min_y, 1000.0)
    
    # 40% margin untuk visualisasi fokus
    pad_x, pad_y = span_x * 0.40, span_y * 0.40
    zoom_xlim = (f_min_x - pad_x, f_max_x + pad_x)
    zoom_ylim = (f_min_y - pad_y, f_max_y + pad_y)
    
    ax.set_xlim(zoom_xlim)
    ax.set_ylim(zoom_ylim)

    # Inset peta orientasi wilayah kerja (Minimap)
    try:
        ax_mini = inset_axes(ax, width="22%", height="22%", loc='lower right', borderpad=2.5)
        ax_mini.set_facecolor('#f0f4f8')
        ax_mini.tricontourf(triang_full, val_reg_masked, levels=levels, cmap=cmap, alpha=0.85)
        if gdf_coast is not None:
            try:
                gdf_coast[gdf_coast.geom_type.isin(['Polygon', 'MultiPolygon'])].plot(ax=ax_mini, color='#c8b89a', edgecolor='#166534', lw=0.5)
            except Exception: pass
        ax_mini.scatter(sed_x_proj, sed_y_proj, c='red', s=8, zorder=5, edgecolors='none')
        rect_zoom = Rectangle((zoom_xlim[0], zoom_ylim[0]), zoom_xlim[1] - zoom_xlim[0], zoom_ylim[1] - zoom_ylim[0],
                              lw=1.5, edgecolor='red', facecolor='rgba(255,0,0,0.05)', zorder=6)
        ax_mini.add_patch(rect_zoom)
        ax_mini.set_xlim(mac_min_x, mac_max_x)
        ax_mini.set_ylim(mac_min_y, mac_max_y)
        ax_mini.set_xticks([])
        ax_mini.set_yticks([])
        ax_mini.set_title("Orientasi Wilayah Kerja", fontsize=7, pad=2)
        for spine in ax_mini.spines.values(): spine.set_edgecolor('#64748b')
    except Exception: pass

    plt.tight_layout()
    out_fig = os.path.join(target_dir, f"Sediment_DualGrid_Contour_{param_label}_v8.png")
    plt.savefig(out_fig, dpi=180, bbox_inches='tight')
    plt.show()

    print("\n" + "=" * 80)
    print(f"🚀 SELESAI — Analisis spasial sukses dan grafik visualisasi bottom-friction dual-grid disimpan ke:")
    print(f"   📂 File Kontur: {out_fig}")
    print("=" * 80)

except Exception as e_plot:
    print(f"⚠️ [WARNING] Kegagalan sistem plot visualisasi: {e_plot}")
    import traceback
    traceback.print_exc()

def on_generate_clicked(b):
    btn_generate.disabled    = True
    btn_generate.description = '⏳  Memproses ERA5...'
    btn_load.disabled        = True
    btn_reset.disabled       = True
    _set_status('⏳  Fase 2: Membaca ERA5 dan mengekspor file...', '#f59e0b')

    with out_phase2:
        clear_output(wait=True)
        try:
            if not STATE['boundary_coords']:
                raise ValueError("STRUKTUR BATAS KOSONG. Fase 1 belum selesai.")

            crs_str       = w_epsg.value.strip() or DEFAULT_EPSG
            boundary_name = w_bname.value.strip() or 'DWaves_Macro_Boundary'
            out_dir       = _normalize_path(w_outdir.value)
            era5_path     = _normalize_path(w_era5.value)
            os.makedirs(out_dir, exist_ok=True)

            use_manual_spread = (w_spread_mode.value == 'manual')
            manual_spread_val = float(w_spread_manual.value) if use_manual_spread else None
            export_as_bcw     = (w_export_mode.value == 'bcw')

            if not os.path.exists(era5_path):
                raise FileNotFoundError(f"File ERA5 tidak ditemukan:\n  {era5_path}")

            try:
                t_start = datetime.strptime(w_t_start.value.strip(), '%Y-%m-%d')
                t_end   = datetime.strptime(w_t_end.value.strip(), '%Y-%m-%d').replace(hour=23, minute=59, second=0)
            except ValueError as e_t:
                raise ValueError(f"Format tanggal salah: {e_t}")
            if t_start >= t_end:
                raise ValueError(f"t_start harus sebelum t_end.")

            print("=" * 72)
            print("📅 [PHASE 2] MEMBACA DATABASE ERA5 GELOMBANG (.NC)")
            print("=" * 72)
            print(f"   File    : {os.path.basename(era5_path)}")
            print(f"   Periode : {t_start:%Y-%m-%d} → {t_end:%Y-%m-%d}")
            print(f"   Format  : {'Combined BCW File' if export_as_bcw else 'Multiple TPAR Files'}")

            ds_wave = xr.open_dataset(era5_path, engine='netcdf4')
            found_spread_vars = scan_era5_spread_variables(ds_wave)
            all_vars = list(ds_wave.data_vars)

            t_col = next((v for v in ['time', 'valid_time', 't'] if v in ds_wave.coords or v in ds_wave.dims or v in ds_wave.variables), None)
            if not t_col:
                raise KeyError("Dimensi waktu tidak ditemukan.")

            ds_slice   = ds_wave.sel({t_col: slice(t_start, t_end)})
            time_array = pd.to_datetime(ds_slice[t_col].values)

            if len(time_array) == 0:
                raise ValueError(f"Tidak ada data ERA5 dalam rentang tersebut.")

            var_hs  = next((v for v in ['swh', 'VHM0', 'hs'] if v in ds_wave.variables), None)
            var_tp  = next((v for v in ['pp1d', 'mwp', 'VTPK', 'tp'] if v in ds_wave.variables), None)
            var_dir = next((v for v in ['mwd', 'VMDR', 'dir'] if v in ds_wave.variables), None)

            if not all([var_hs, var_tp, var_dir]):
                raise KeyError(f"Variabel gelombang tidak lengkap.")

            lat_name = next((d for d in ds_wave.dims if 'lat' in d.lower()), 'latitude')
            lon_name = next((d for d in ds_wave.dims if 'lon' in d.lower()), 'longitude')
            era5_lats = ds_wave[lat_name].values
            era5_lons = ds_wave[lon_name].values

            lon_boundary = [pt[0] for pt in STATE['boundary_coords']]
            lat_boundary = [pt[1] for pt in STATE['boundary_coords']]
            num_points   = len(lon_boundary)

            transformer_utm = pyproj.Transformer.from_crs("epsg:4326", crs_str, always_xy=True)
            x_utm, y_utm    = transformer_utm.transform(lon_boundary, lat_boundary)

            pli_path = os.path.join(out_dir, f"{boundary_name}.pli")
            with open(pli_path, 'w') as f_pli:
                f_pli.write(f"{boundary_name}\n{num_points} 2\n")
                for i in range(num_points):
                    f_pli.write(f"{x_utm[i]:.3f} {y_utm[i]:.3f}\n")

            diagnostic_data  = {}
            spread_methods   = {}

            for idx in range(num_points):
                station_name = f"{boundary_name}_{idx + 1:04d}"
                lon_n = lon_boundary[idx]
                lat_n = lat_boundary[idx]

                lon_n_w = lon_n + 360.0 if (era5_lons.max() > 180 and lon_n < 0) else lon_n

                lat_idx_n = int(np.abs(era5_lats - lat_n).argmin())
                lon_idx_n = int(np.abs(era5_lons - lon_n_w).argmin())

                ds_sta = ds_slice.isel({lat_name: lat_idx_n, lon_name: lon_idx_n})
                hs  = ds_sta[var_hs].values.astype(float)
                tp  = ds_sta[var_tp].values.astype(float)
                wd  = ds_sta[var_dir].values.astype(float)

                if np.any(np.isnan(hs)):
                    ds_area = ds_slice.isel({
                        lat_name: slice(max(0, lat_idx_n - 1), min(len(era5_lats), lat_idx_n + 2)),
                        lon_name: slice(max(0, lon_idx_n - 1), min(len(era5_lons), lon_idx_n + 2))
                    })
                    ds_mean = ds_area.mean(dim=[lat_name, lon_name], skipna=True)
                    hs = ds_mean[var_hs].values.astype(float)
                    tp = ds_mean[var_tp].values.astype(float)
                    wd = ds_mean[var_dir].values.astype(float)

                spread_arr, spread_method = detect_spreading_from_era5(
                    ds_wave=ds_wave, ds_slice=ds_slice, lat_name=lat_name, lon_name=lon_name,
                    lat_idx=lat_idx_n, lon_idx=lon_idx_n, hs_arr=hs, tp_arr=tp, manual_value=manual_spread_val
                )
                spread_methods[station_name] = spread_method

                n_t = len(time_array)
                assert len(spread_arr) == n_t

                diagnostic_data[station_name] = {'hs': hs, 'tp': tp, 'dir': wd, 'spread': spread_arr}

                if not export_as_bcw:
                    tpar_path = os.path.join(out_dir, f"{station_name}.tpar")
                    with open(tpar_path, 'w') as f_t:
                        f_t.write("TPAR\n")
                        for t_i, dt_v in enumerate(time_array):
                            f_t.write(f"{dt_v.strftime('%Y%m%d.%H%M%S')} {hs[t_i]:.3f} {tp[t_i]:.2f} {wd[t_i]:.1f} {spread_arr[t_i]:.1f}\n")

            # BCW Generation...
            if export_as_bcw:
                bcw_path = os.path.join(out_dir, f"{boundary_name}.bcw")
                ref_date_yyyymmdd = t_start.strftime("%Y%m%d")
                
                with open(bcw_path, 'w') as f_bcw:
                    f_bcw.write(f"location '{boundary_name}'\n")
                    f_bcw.write("time-function 'non-equidistant'\n")
                    f_bcw.write(f"reference-time {ref_date_yyyymmdd}\n")
                    f_bcw.write("time-unit 'minutes'\n")
                    f_bcw.write("interpolation 'linear'\n")
                    f_bcw.write("parameter 'time ' unit '[min]'\n")
                    
                    for _ in range(num_points): f_bcw.write("parameter 'WaveHeight' unit '[m]'\n")
                    for _ in range(num_points): f_bcw.write("parameter 'Period' unit '[s]'\n")
                    for _ in range(num_points): f_bcw.write("parameter 'Direction' unit '[N^o]'\n")
                    for _ in range(num_points): f_bcw.write("parameter 'DirSpreading' unit '[-]'\n")
                        
                    base_time = time_array[0]
                    for t_i, dt_v in enumerate(time_array):
                        rel_min = (dt_v - base_time).total_seconds() / 60.0
                        hs_vals = []
                        tp_vals = []
                        dir_vals = []
                        spr_vals = []
                        for idx in range(num_points):
                            st_name = f"{boundary_name}_{idx + 1:04d}"
                            hs_vals.append(diagnostic_data[st_name]['hs'][t_i])
                            tp_vals.append(diagnostic_data[st_name]['tp'][t_i])
                            dir_vals.append(diagnostic_data[st_name]['dir'][t_i])
                            spr_vals.append(diagnostic_data[st_name]['spread'][t_i])
                            
                        formatted_vals = [f"{rel_min:.2f}"]
                        formatted_vals.extend([f"{v:.3f}" for v in hs_vals])
                        formatted_vals.extend([f"{v:.3f}" for v in tp_vals])
                        formatted_vals.extend([f"{v:.1f}" for v in dir_vals])
                        formatted_vals.extend([f"{v:.1f}" for v in spr_vals])
                        f_bcw.write(" ".join(formatted_vals) + "\n")

            unique_methods = set(spread_methods.values())
            STATE['spread_method'] = "; ".join(unique_methods)

            print(f"\n🎨 [PHASE 5.1] GENERATING HS & TP TIME-SERIES PLOT...")
            plt.close('all')
            
            fig_ts, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 8), dpi=150, sharex=True)
            colors = ['#EF4444', '#10B981', '#3B82F6', '#F59E0B', '#8B5CF6']
            
            plot_keys = list(diagnostic_data.keys())
            if len(plot_keys) > 5:
                s = len(plot_keys) // 4
                plot_keys = [plot_keys[0], plot_keys[s], plot_keys[s*2], plot_keys[s*3], plot_keys[-1]]

            for i, stn in enumerate(plot_keys):
                c = colors[i % len(colors)]
                d = diagnostic_data[stn]
                ax1.plot(time_array, d['hs'], color=c, lw=2.0, label=stn)
                ax2.plot(time_array, d['tp'], color=c, lw=1.8, ls='--')

            ax1.set_title("Tinggi Gelombang Signifikan ($H_s$)", fontweight='bold', fontsize=11)
            ax1.set_ylabel("Hs (meter)", fontsize=10)
            ax1.grid(True, ls=':', alpha=0.5)
            ax1.legend(loc='upper right', ncol=3, fontsize=8)

            ax2.set_title("Periode Puncak Gelombang ($T_p$)", fontweight='bold', fontsize=11)
            ax2.set_ylabel("Tp (detik)", fontsize=10)
            ax2.grid(True, ls=':', alpha=0.5)
            
            ax2.xaxis.set_major_formatter(mdates.DateFormatter('%d-%b\n%H:%M'))
            ax2.set_xlabel(f"Waktu ({t_start:%B %Y})", fontsize=10)
            
            fig_ts.suptitle(
                f"Analisis Deret Waktu Forcing Gelombang — {boundary_name}\n"
                f"Simulasi Dinamis {t_start:%Y-%m-%d} s.d. {t_end:%Y-%m-%d}",
                fontweight='bold', fontsize=12, y=0.98
            )
            plt.tight_layout(rect=[0, 0, 1, 0.96])
            fig_ts_path = os.path.join(out_dir, f"{boundary_name}_Hs_Tp_Diagnostics.png")
            plt.savefig(fig_ts_path, dpi=180, bbox_inches='tight')
            plt.show()

            print(f"\n🎨 [PHASE 5.2] GENERATING SCIENTIFIC COMPASS WAVE ROSES (LEFT & RIGHT)...")
            
            # Pool all boundary coordinates and wave heights to draw the comprehensive climate rose
            all_dirs = np.concatenate([d['dir'] for d in diagnostic_data.values()])
            all_hs   = np.concatenate([d['hs'] for d in diagnostic_data.values()])
            all_spr  = np.concatenate([d['spread'] for d in diagnostic_data.values()])
            
            fig_rose, (ax_wave_rose, ax_spread_rose) = plt.subplots(
                1, 2, figsize=(15, 8), dpi=150, 
                subplot_kw=dict(projection='polar')
            )
            
            # Set Theta Zero to North ('N') and proceed clockwise (-1) for both polar axes
            for ax_r in [ax_wave_rose, ax_spread_rose]:
                ax_r.set_theta_zero_location('N')
                ax_r.set_theta_direction(-1) # Clockwise
                ax_r.set_rlabel_position(112.5) # Put radial labels slightly tilted
                
            num_sectors = 16
            sector_width = 360.0 / num_sectors
            bar_width = np.radians(sector_width) * 0.85
            
            # Center of sectors in degrees -> convert directly to radians
            met_centers = np.arange(num_sectors) * sector_width
            polar_centers = np.radians(met_centers)
            
            # Helper logic to classify direction bins (aligned centered around North)
            shifted_dirs = np.mod(all_dirs + (sector_width / 2.0), 360.0)
            dir_indices  = (shifted_dirs // sector_width).astype(int)
            
            # ──────────────────────────────────────────────────────────────────
            # ROSE LEFT: Wave Height vs Wave Direction
            # ──────────────────────────────────────────────────────────────────
            hs_bins = [0.0, 1.0, 1.8, 2.5, np.inf]
            hs_labels = ['< 1.0 m (Calm)', '1.0 - 1.8 m (Moderate)', '1.8 - 2.5 m (Rough)', '> 2.5 m (Extreme)']
            hs_colors = ['#fed976', '#feb24c', '#fd8d3c', '#e31a1c']
            hs_indices = np.digitize(all_hs, hs_bins) - 1
            
            grid_hs_counts = np.zeros((len(hs_bins) - 1, num_sectors))
            for v_i in range(len(hs_bins) - 1):
                for s_i in range(num_sectors):
                    grid_hs_counts[v_i, s_i] = np.sum((dir_indices == s_i) & (hs_indices == v_i))
            
            # Percentage scaling
            total_samples = len(all_dirs)
            grid_hs_pct = (grid_hs_counts / total_samples) * 100.0
            
            bottoms_hs = np.zeros(num_sectors)
            for v_i in range(len(hs_bins) - 1):
                ax_wave_rose.bar(
                    polar_centers, grid_hs_pct[v_i, :], width=bar_width, bottom=bottoms_hs, 
                    color=hs_colors[v_i], label=hs_labels[v_i], edgecolor='black', linewidth=0.4
                )
                bottoms_hs += grid_hs_pct[v_i, :]
                
            ax_wave_rose.set_title("Wave Height Rose Climate ($H_s$ vs $Dir$)", fontweight='bold', fontsize=11, pad=15)
            ax_wave_rose.legend(loc='lower center', bbox_to_anchor=(0.5, -0.22), ncol=2, fontsize=8)
            
            # ──────────────────────────────────────────────────────────────────
            # ROSE RIGHT: Directional Spreading vs Wave Direction
            # ──────────────────────────────────────────────────────────────────
            spr_bins = [0.0, 12.0, 20.0, 30.0, np.inf]
            spr_labels = ['< 12° (Narrow Swell)', '12° - 20° (Moderate Swell)', '20° - 30° (Wind Sea)', '> 30° (Broad Sea)']
            spr_colors = ['#a1dab4', '#41b6c4', '#225ea8', '#081d58']
            spr_indices = np.digitize(all_spr, spr_bins) - 1
            
            grid_spr_counts = np.zeros((len(spr_bins) - 1, num_sectors))
            for v_i in range(len(spr_bins) - 1):
                for s_i in range(num_sectors):
                    grid_spr_counts[v_i, s_i] = np.sum((dir_indices == s_i) & (spr_indices == v_i))
                    
            grid_spr_pct = (grid_spr_counts / total_samples) * 100.0
            
            bottoms_spr = np.zeros(num_sectors)
            for v_i in range(len(spr_bins) - 1):
                ax_spread_rose.bar(
                    polar_centers, grid_spr_pct[v_i, :], width=bar_width, bottom=bottoms_spr,
                    color=spr_colors[v_i], label=spr_labels[v_i], edgecolor='black', linewidth=0.4
                )
                bottoms_spr += grid_spr_pct[v_i, :]
                
            ax_spread_rose.set_title("Directional Spreading Rose Climate ($\sigma_\\theta$ vs $Dir$)", fontweight='bold', fontsize=11, pad=15)
            ax_spread_rose.legend(loc='lower center', bbox_to_anchor=(0.5, -0.22), ncol=2, fontsize=8)
            
            # Formatting radial percent ticks
            for ax_r in [ax_wave_rose, ax_spread_rose]:
                ax_r.set_yticklabels([f"{val:.0f}%" for val in ax_r.get_yticks()], fontsize=8, color='gray')
            
            fig_rose.suptitle(
                f"Distribusi Spasial Klimatologi Spektral Arah Gelombang — {boundary_name}\n"
                f"Total Data Teranalisis: {total_samples:,} Timesteps | Spreading Fallback: {STATE.get('spread_method', 'auto')}",
                fontweight='bold', fontsize=13, y=0.99
            )
            plt.tight_layout(rect=[0, 0, 1, 0.95])
            fig_rose_path = os.path.join(out_dir, f"{boundary_name}_Direction_Spreading_Roses.png")
            plt.savefig(fig_rose_path, dpi=180, bbox_inches='tight')
            plt.show()

            STATE['phase2_done'] = True
            msg_suc = f'🚀 SELESAI GABUNGAN — File ditulis ke {out_dir}'
            _set_status(msg_suc, '#16a34a')
            btn_generate.description = f'✅ Selesai ({boundary_name})'
            btn_reset.disabled       = False
            btn_load.disabled        = False

            print(f"\n{'=' * 72}")
            print(f"🚀 TAHAP 10 EKSEKUSI INTEGRASI SUKSES")
            print(f"   ├ 1. Grafik Deret Waktu  : {os.path.basename(fig_ts_path)}")
            print(f"   ├ 2. Grafik Kompas Rose  : {os.path.basename(fig_rose_path)}")
            print(f"   └ Direktori Penyimpanan : {out_dir}")
            print("=" * 72)

        except Exception as e:
            _set_status(f'❌ Error Fase 2: {e}', '#dc2626')
            print(f"\n❌ ERROR FASE 2:\n{e}")
            traceback.print_exc()
            btn_generate.disabled    = False
            btn_generate.description = '▶  FASE 2: Coba Lagi'
            btn_load.disabled        = False
            btn_reset.disabled       = False


btn_generate.on_click(on_generate_clicked)



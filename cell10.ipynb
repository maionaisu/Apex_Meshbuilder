# ═══════════════════════════════════════════════════════════════════════════════
# CALLBACK: FASE 1 — LOAD GRID & RENDER MAP
# ═══════════════════════════════════════════════════════════════════════════════

def _set_status(msg: str, color: str = '#64748b') -> None:
    html_status.value = f'<b style="color:{color};font-size:13px">{msg}</b>'


def on_load_clicked(b):
    btn_load.disabled     = True
    btn_reset.disabled    = True
    btn_generate.disabled = True
    btn_load.description  = '⏳  Memuat grid...'
    _set_status('⏳  Fase 1: Memuat file grid dan membangun peta...', '#f59e0b')

    STATE['boundary_coords'] = []
    STATE['phase1_done']     = False

    with out_map:
        clear_output(wait=True)
        try:
            crs_str  = w_epsg.value.strip() or DEFAULT_EPSG
            out_dir  = _normalize_path(w_outdir.value)

            macro_path = _normalize_path(w_macro.value, out_dir)
            macro_path = _fix_dep_to_grd(macro_path)

            if not os.path.exists(macro_path):
                raise FileNotFoundError(
                    f"Macro Grid tidak ditemukan:\n  {macro_path}\n"
                    f"Periksa path atau salin file ke direktori output."
                )

            STATE['macro_path'] = macro_path
            transformer_ll = pyproj.Transformer.from_crs(crs_str, "epsg:4326", always_xy=True)

            # Parse Macro Grid
            x_m, y_m, c_sys = parse_rgfgrid_grd(macro_path)
            STATE['x_m'], STATE['y_m'] = x_m, y_m

            map_clat, map_clon = -8.44, 112.66
            log_lines = []

            if x_m is not None:
                lon_m, lat_m = transformer_ll.transform(x_m, y_m)
                STATE['lon_m'], STATE['lat_m'] = lon_m, lat_m
                map_clat = float(np.nanmean(lat_m))
                map_clon = float(np.nanmean(lon_m))
                my_m, mx_m = x_m.shape
                log_lines.append(f"✅ Macro Grid: {mx_m}×{my_m} sel (CRS: {c_sys})")
                log_lines.append(f"   Centroid: Lat={map_clat:.5f}, Lon={map_clon:.5f}")

            # Build map
            m = Map(center=(map_clat, map_clon), zoom=11,
                    basemap=basemaps.Esri.WorldImagery, scroll_wheel_zoom=True)

            if STATE['lon_m'] is not None:
                add_grid_overlay(m, STATE['lon_m'], STATE['lat_m'], '#dc2626', n_lines=12)

            # Micro Grid (opsional)
            micro_raw = w_micro.value.strip()
            if micro_raw:
                micro_path = _normalize_path(micro_raw, out_dir)
                if os.path.exists(micro_path):
                    try:
                        x_mi, y_mi, _ = parse_rgfgrid_grd(micro_path)
                        if x_mi is not None:
                            lon_mi, lat_mi = transformer_ll.transform(x_mi, y_mi)
                            STATE['lon_mi'], STATE['lat_mi'] = lon_mi, lat_mi
                            add_grid_overlay(m, lon_mi, lat_mi, '#7c3aed', n_lines=10)
                            my_mi, mx_mi = x_mi.shape
                            log_lines.append(f"✅ Micro Grid: {mx_mi}×{my_mi} sel")
                    except Exception as e_mi:
                        log_lines.append(f"⚠️  Micro Grid dilewati: {e_mi}")
                else:
                    log_lines.append("ℹ️  Micro Grid tidak ditemukan, dilewati.")

            # METODE 1: Manual Draw
            if w_method.value == '1':
                dc = DrawControl()
                dc.polyline     = {"shapeOptions": {"color": "#ff007f", "weight": 4, "opacity": 0.95}}
                dc.polygon      = {}
                dc.circlemarker = {}
                dc.rectangle    = {}
                dc.circle       = {}

                def on_draw(target, action, geo_json):
                    if action == 'created' and geo_json.get('geometry', {}).get('type') == 'LineString':
                        coords = [[float(p[0]), float(p[1])]
                                  for p in geo_json['geometry']['coordinates']]
                        STATE['boundary_coords'] = coords
                        n = len(coords)
                        txt = f"✅ BERHASIL DIREKAM! {n} titik batas gelombang:\n"
                        for i, pt in enumerate(coords):
                            txt += f"  Node {i+1:02d}: Lon={pt[0]:.5f}, Lat={pt[1]:.5f}\n"
                        log_draw.value = txt
                        btn_generate.disabled    = False
                        btn_generate.description = f'▶  FASE 2: Generate Files ({n} nodes)'
                        _set_status(
                            f'✅ Fase 1 Selesai — {n} node batas direkam. Klik FASE 2.',
                            '#16a34a'
                        )

                dc.on_draw(on_draw)
                m.add_control(dc)
                display(m)

                log_draw.value = "\n".join(log_lines) + (
                    "\n\n🗺️  PETA AKTIF\n"
                    "Gunakan tombol 'Draw a polyline' (panel kiri) untuk menggambar\n"
                    "garis batas gelombang di atas kisi merah (Macro Grid).\n"
                    "Tombol FASE 2 aktif otomatis setelah garis selesai digambar."
                )
                log_draw.disabled  = False
                btn_load.description = '✅  Grid Dimuat — Gambar batas di peta'
                btn_reset.disabled   = False
                STATE['phase1_done'] = True
                _set_status('🗺️  Peta aktif — Gambar polyline di kisi merah, lalu klik FASE 2.', '#2563eb')

            # METODE 2: Auto-Extract j=0
            else:
                if STATE['x_m'] is None:
                    raise RuntimeError("Grid gagal dimuat — tidak dapat auto-extract.")

                x_ext = STATE['x_m'][0, :]
                y_ext = STATE['y_m'][0, :]
                lon_ext, lat_ext = transformer_ll.transform(x_ext, y_ext)
                coords = [[float(lo), float(la)] for lo, la in zip(lon_ext, lat_ext)]
                STATE['boundary_coords'] = coords

                m.add_layer(Polyline(
                    locations=[[la, lo] for lo, la in zip(lon_ext, lat_ext)],
                    color='#ff007f', weight=4, opacity=0.95, interactive=False
                ))
                display(m)

                n = len(coords)
                log_draw.value = (
                    "\n".join(log_lines) +
                    f"\n\n✅ AUTO-EXTRACT j=0 SUKSES: {n} titik dari "
                    f"{os.path.basename(macro_path)}\n"
                    f"Klik FASE 2 untuk memulai generasi file forcing."
                )
                log_draw.disabled        = False
                btn_generate.disabled    = False
                btn_generate.description = f'▶  FASE 2: Generate Files ({n} nodes)'
                btn_load.description     = '✅  Auto-Extract Selesai'
                btn_reset.disabled       = False
                STATE['phase1_done']     = True
                _set_status(f'✅ Fase 1 Selesai (Auto-Extract) — {n} nodes. Klik FASE 2.', '#16a34a')

        except Exception as e:
            _set_status(f'❌ Error Fase 1: {e}', '#dc2626')
            log_draw.value    = f"❌ ERROR:\n{e}\n\nPeriksa path file dan coba lagi."
            log_draw.disabled = False
            btn_load.disabled    = False
            btn_reset.disabled   = True
            btn_load.description = '▶  FASE 1: Load Grid & Buka Peta (Coba Lagi)'
            traceback.print_exc()


def on_reset_clicked(b):
    STATE['boundary_coords'] = []
    STATE['phase1_done']     = False
    btn_generate.disabled    = True
    btn_generate.description = '▶  FASE 2: Generate Files'
    log_draw.value = (
        "🔄 State direset. Gambar ulang polyline di peta, "
        "atau klik FASE 1 untuk konfigurasi ulang."
    )
    _set_status('↺  Reset — Gambar ulang batas atau klik FASE 1 dengan konfigurasi baru.', '#7c3aed')


btn_load.on_click(on_load_clicked)
btn_reset.on_click(on_reset_clicked)


# ═══════════════════════════════════════════════════════════════════════════════
# CALLBACK: FASE 2 — ERA5 + EXPORT PIPELINE
# ═══════════════════════════════════════════════════════════════════════════════

def on_generate_clicked(b):
    btn_generate.disabled    = True
    btn_generate.description = '⏳  Memproses ERA5...'
    btn_load.disabled        = True
    btn_reset.disabled       = True
    _set_status('⏳  Fase 2: Membaca ERA5 dan mengekspor file...', '#f59e0b')

    with out_phase2:
        clear_output(wait=True)
        try:
            if not STATE['boundary_coords']:
                raise ValueError(
                    "STRUKTUR BATAS KOSONG.\n"
                    "Fase 1 belum selesai — gambar polyline di peta (Metode 1) "
                    "atau klik FASE 1 dengan Metode 2."
                )

            crs_str       = w_epsg.value.strip() or DEFAULT_EPSG
            boundary_name = w_bname.value.strip() or 'DWaves_Macro_Boundary'
            out_dir       = _normalize_path(w_outdir.value)
            era5_path     = _normalize_path(w_era5.value)
            os.makedirs(out_dir, exist_ok=True)

            # Mode spreading & ekspor
            use_manual_spread = (w_spread_mode.value == 'manual')
            manual_spread_val = float(w_spread_manual.value) if use_manual_spread else None
            export_as_bcw     = (w_export_mode.value == 'bcw')

            # ── Validasi ERA5 ──────────────────────────────────────────
            if not era5_path or not os.path.exists(era5_path):
                raise FileNotFoundError(
                    f"File ERA5 tidak ditemukan:\n  {era5_path}\n"
                    f"Periksa field 'ERA5 NetCDF (.nc)' di konfigurasi."
                )

            # ── Time Range ────────────────────────────────────────────
            try:
                t_start = datetime.strptime(w_t_start.value.strip(), '%Y-%m-%d')
                t_end   = datetime.strptime(w_t_end.value.strip(), '%Y-%m-%d') \
                              .replace(hour=23, minute=59, second=0)
            except ValueError as e_t:
                raise ValueError(
                    f"Format tanggal salah: {e_t}\n"
                    f"Gunakan YYYY-MM-DD, contoh: 2025-09-01"
                )
            if t_start >= t_end:
                raise ValueError(f"t_start ({t_start:%Y-%m-%d}) harus sebelum t_end ({t_end:%Y-%m-%d}).")

            print("=" * 72)
            print("📅 [PHASE 2] MEMBACA DATABASE ERA5 GELOMBANG (.NC)")
            print("=" * 72)
            print(f"   File    : {os.path.basename(era5_path)}")
            print(f"   Periode : {t_start:%Y-%m-%d} → {t_end:%Y-%m-%d}")
            print(f"   Spreading: {'Manual (' + str(manual_spread_val) + '°)' if use_manual_spread else 'Auto (ERA5 / steepness-physics)'}")
            print(f"   Format  : {'Combined BCW File' if export_as_bcw else 'Multiple TPAR Files'}")

            # ── Load ERA5 ──────────────────────────────────────────────
            print("\n   ⏳ Membuka NetCDF via xarray...")
            ds_wave = xr.open_dataset(era5_path, engine='netcdf4')

            # ── Inventory variabel ERA5 ────────────────────────────────
            found_spread_vars = scan_era5_spread_variables(ds_wave)
            all_vars = list(ds_wave.data_vars)
            print(f"\n   📦 Variabel ditemukan di ERA5 ({len(all_vars)} total):")
            print(f"      {', '.join(all_vars)}")
            if found_spread_vars:
                print(f"\n   🌀 Variabel spreading terdeteksi:")
                for v, label in found_spread_vars.items():
                    print(f"      ✅ '{v}' → {label}")
            else:
                print(f"\n   🌀 Tidak ada variabel spreading ERA5 — akan gunakan physics fallback")

            # ── Deteksi dimensi waktu ─────────────────────────────────
            t_col = next(
                (v for v in ['time', 'valid_time', 't']
                 if v in ds_wave.coords or v in ds_wave.dims or v in ds_wave.variables),
                None
            )
            if not t_col:
                raise KeyError(
                    "Dimensi waktu tidak ditemukan.\n"
                    "Variabel koordinat: " + str(list(ds_wave.coords))
                )

            ds_slice   = ds_wave.sel({t_col: slice(t_start, t_end)})
            time_array = pd.to_datetime(ds_slice[t_col].values)

            if len(time_array) == 0:
                t_range_file = (
                    f"{pd.to_datetime(ds_wave[t_col].values[0]):%Y-%m-%d} – "
                    f"{pd.to_datetime(ds_wave[t_col].values[-1]):%Y-%m-%d}"
                )
                raise ValueError(
                    f"Tidak ada data ERA5 dalam rentang {t_start:%Y-%m-%d}–{t_end:%Y-%m-%d}.\n"
                    f"Rentang tersedia di file: {t_range_file}"
                )

            print(f"\n   ✅ Waktu: {time_array[0]:%Y-%m-%d %H:%M} → "
                  f"{time_array[-1]:%Y-%m-%d %H:%M} ({len(time_array)} langkah)")

            # ── Deteksi variabel Hs, Tp, Dir ──────────────────────────
            var_hs  = next((v for v in ['swh', 'VHM0', 'hs']         if v in ds_wave.variables), None)
            var_tp  = next((v for v in ['pp1d', 'mwp', 'VTPK', 'tp'] if v in ds_wave.variables), None)
            var_dir = next((v for v in ['mwd', 'VMDR', 'dir']         if v in ds_wave.variables), None)

            if not all([var_hs, var_tp, var_dir]):
                raise KeyError(
                    f"Variabel gelombang tidak lengkap.\n"
                    f"  Ditemukan: Hs='{var_hs}', Tp='{var_tp}', Dir='{var_dir}'\n"
                    f"  Semua variabel: {all_vars}"
                )
            print(f"   ✅ Variabel: Hs='{var_hs}', Tp='{var_tp}', Dir='{var_dir}'")

            # ── Koordinat ERA5 ────────────────────────────────────────
            lat_name = next((d for d in ds_wave.dims if 'lat' in d.lower()), 'latitude')
            lon_name = next((d for d in ds_wave.dims if 'lon' in d.lower()), 'longitude')
            era5_lats = ds_wave[lat_name].values
            era5_lons = ds_wave[lon_name].values

            # ── Koordinat batas & transformasi UTM ────────────────────
            lon_boundary = [pt[0] for pt in STATE['boundary_coords']]
            lat_boundary = [pt[1] for pt in STATE['boundary_coords']]
            num_points   = len(lon_boundary)

            transformer_utm = pyproj.Transformer.from_crs("epsg:4326", crs_str, always_xy=True)
            x_utm, y_utm    = transformer_utm.transform(lon_boundary, lat_boundary)

            # ── Tulis .PLI ─────────────────────────────────────────────
            pli_path = os.path.join(out_dir, f"{boundary_name}.pli")
            with open(pli_path, 'w') as f_pli:
                f_pli.write(f"{boundary_name}\n{num_points} 2\n")
                for i in range(num_points):
                    f_pli.write(f"{x_utm[i]:.3f} {y_utm[i]:.3f}\n")
            print(f"\n   ✅ PLI ditulis: {pli_path}")

            # ═══════════════════════════════════════════════════════════
            # PHASE 3: PROCESSING DATA + DUAL FORMAT EXPORT
            # =========================================================================
            print(f"\n{'=' * 72}")
            if not export_as_bcw:
                print(f"🌊 [PHASE 3] GENERATING {num_points} FILE .TPAR")
            else:
                print(f"🌊 [PHASE 3] GENERATING COMBINED .BCW FILE (CondSpecAtDist)")
            print(f"{'=' * 72}")

            diagnostic_data  = {}
            spread_methods   = {}  # track metode spreading per node

            for idx in range(num_points):
                station_name = f"{boundary_name}_{idx + 1:04d}"
                lon_n = lon_boundary[idx]
                lat_n = lat_boundary[idx]

                # Lon wrap 0-360
                lon_n_w = lon_n + 360.0 if (era5_lons.max() > 180 and lon_n < 0) else lon_n

                lat_idx_n = int(np.abs(era5_lats - lat_n).argmin())
                lon_idx_n = int(np.abs(era5_lons - lon_n_w).argmin())

                ds_sta = ds_slice.isel({lat_name: lat_idx_n, lon_name: lon_idx_n})
                hs  = ds_sta[var_hs].values.astype(float)
                tp  = ds_sta[var_tp].values.astype(float)
                wd  = ds_sta[var_dir].values.astype(float)

                # Spatial average fallback jika NaN (land cell)
                if np.any(np.isnan(hs)):
                    logger.warning(f"NaN Hs di {station_name} — spatial avg 3×3...")
                    ds_area = ds_slice.isel({
                        lat_name: slice(max(0, lat_idx_n - 1),
                                        min(len(era5_lats), lat_idx_n + 2)),
                        lon_name: slice(max(0, lon_idx_n - 1),
                                        min(len(era5_lons), lon_idx_n + 2))
                    })
                    ds_mean = ds_area.mean(dim=[lat_name, lon_name], skipna=True)
                    hs = ds_mean[var_hs].values.astype(float)
                    tp = ds_mean[var_tp].values.astype(float)
                    wd = ds_mean[var_dir].values.astype(float)

                # ── AUTO SPREADING ────────────────────────────────────
                spread_arr, spread_method = detect_spreading_from_era5(
                    ds_wave=ds_wave,
                    ds_slice=ds_slice,
                    lat_name=lat_name,
                    lon_name=lon_name,
                    lat_idx=lat_idx_n,
                    lon_idx=lon_idx_n,
                    hs_arr=hs,
                    tp_arr=tp,
                    manual_value=manual_spread_val  # None jika mode auto
                )
                spread_methods[station_name] = spread_method

                # Pastikan panjang array sama
                n_t = len(time_array)
                assert len(spread_arr) == n_t, \
                    f"Panjang spread ({len(spread_arr)}) ≠ time_array ({n_t})"

                # Simpan diagnostik
                diagnostic_data[station_name] = {
                    'hs': hs, 'tp': tp, 'dir': wd, 'spread': spread_arr
                }

                # ── Tulis TPAR (Hanya jika mode TPAR dipilih) ──────────
                if not export_as_bcw:
                    tpar_path = os.path.join(out_dir, f"{station_name}.tpar")
                    with open(tpar_path, 'w') as f_t:
                        f_t.write("TPAR\n")
                        for t_i, dt_v in enumerate(time_array):
                            f_t.write(
                                f"{dt_v.strftime('%Y%m%d.%H%M%S')} "
                                f"{hs[t_i]:.3f} {tp[t_i]:.2f} {wd[t_i]:.1f} "
                                f"{spread_arr[t_i]:.1f}\n"
                            )
                    print(f"   ├── Node {idx + 1:02d}/{num_points:02d}: {station_name}.tpar  "
                          f"spread=[{spread_arr.min():.1f}°–{spread_arr.max():.1f}°]  ✅")

            # ── Tulis BCW (Hanya jika mode BCW dipilih) ─────────────
            if export_as_bcw:
                bcw_path = os.path.join(out_dir, f"{boundary_name}.bcw")
                reftime_str = t_start.strftime("%Y%m%d")
                num_vars = 4 * num_points
                
                with open(bcw_path, 'w') as f_bcw:
                    f_bcw.write("*\n")
                    f_bcw.write(f"* Combined Boundary Condition Wave (.bcw) for SWAN / D-Waves\n")
                    f_bcw.write(f"* Generated by APEX NEXUS Wave Forcing Generator\n")
                    f_bcw.write("*\n")
                    f_bcw.write(f"{reftime_str}\n")
                    f_bcw.write("minutes\n")
                    f_bcw.write(f"{num_vars}\n")
                    
                    # Tulis nama variabel (waveheight, waveperiod, wavedirection, wavespreading)
                    # Masing-masing di-loop sebanyak num_points
                    for _ in range(num_points):
                        f_bcw.write("waveheight\n")
                    for _ in range(num_points):
                        f_bcw.write("waveperiod\n")
                    for _ in range(num_points):
                        f_bcw.write("wavedirection\n")
                    for _ in range(num_points):
                        f_bcw.write("wavespreading\n")
                        
                    # Tulis data per-timestep
                    base_time = time_array[0]
                    for t_i, dt_v in enumerate(time_array):
                        rel_min = int((dt_v - base_time).total_seconds() / 60.0)
                        
                        # Kumpulkan variabel untuk semua titik node
                        hs_vals = []
                        tp_vals = []
                        dir_vals = []
                        spr_vals = []
                        
                        for idx in range(num_points):
                            st_name = f"{boundary_name}_{idx + 1:04d}"
                            hs_vals.append(diagnostic_data[st_name]['hs'][t_i])
                            tp_vals.append(diagnostic_data[st_name]['tp'][t_i])
                            dir_vals.append(diagnostic_data[st_name]['dir'][t_i])
                            spr_vals.append(diagnostic_data[st_name]['spread'][t_i])
                            
                        # Susun baris: rel_min hs_1..hs_N tp_1..tp_N dir_1..dir_N spread_1..spread_N
                        formatted_vals = [f"{rel_min:d}"]
                        formatted_vals.extend([f"{v:.3f}" for v in hs_vals])
                        formatted_vals.extend([f"{v:.2f}" for v in tp_vals])
                        formatted_vals.extend([f"{v:.1f}" for v in dir_vals])
                        formatted_vals.extend([f"{v:.1f}" for v in spr_vals])
                        
                        f_bcw.write(" ".join(formatted_vals) + "\n")
                
                print(f"   ✅ [BCW EXPORT SUCCESS] Berkas gabungan BCW berhasil ditulis ke: {os.path.basename(bcw_path)}")
                print(f"      Total Node: {num_points} | Timesteps: {len(time_array)}")

            # ── Ringkasan metode spreading ─────────────────────────────
            unique_methods = set(spread_methods.values())
            print(f"\n   🌀 Metode spreading digunakan:")
            for m_str in unique_methods:
                count = sum(1 for v in spread_methods.values() if v == m_str)
                print(f"      {count} node → {m_str}")

            STATE['spread_method'] = "; ".join(unique_methods)

            # =========================================================================
            # PHASE 4: Panduan Injeksi .MDW
            # =========================================================================
            print(f"\n{'=' * 72}")
            print("🎬 [PHASE 4] PANDUAN INTEGRASI KE D-WAVES (.MDW)")
            print("=" * 72)
            if not export_as_bcw:
                for idx in range(num_points):
                    sn = f"{boundary_name}_{idx + 1:04d}"
                    print(f"  [{idx + 1:04d}] X={x_utm[idx]:.2f}  Y={y_utm[idx]:.2f}  → {sn}.tpar")
            else:
                bcw_file_name = f"{boundary_name}.bcw"
                print(f"  Anda memilih format .bcw gabungan! Ini memungkinkan penggunaan 'CondSpecAtDist'.")
                print(f"  Di dalam .mdw, buat satu segmen boundary tunggal dengan {num_points} titik pendukung:")
                for idx in range(num_points):
                    print(f"    Titik {idx+1:02d}: X={x_utm[idx]:.2f}  Y={y_utm[idx]:.2f}")
                print(f"\n  Tautkan berkas BCW tunggal berikut: {bcw_file_name}")
                print(f"  Aktifkan opsi interpolasi spasial 'CondSpecAtDist' di pengaturan batas SWAN.")
            print("=" * 72)

            # =========================================================================
            # PHASE 5: ENTERPRISE VISUALIZATION — 4 PANEL (+ SPREADING)
            # =========================================================================
            print(f"\n🎨 [PHASE 5] VISUALISASI DIAGNOSTIK 4-PANEL...")
            plt.close('all')
            fig, axes = plt.subplots(4, 1, figsize=(15, 15), dpi=150, sharex=True)
            ax1, ax2, ax3, ax4 = axes
            colors = ['#EF4444', '#10B981', '#3B82F6', '#F59E0B', '#8B5CF6']

            # Subsample ke max 5 node untuk keterbacaan
            plot_keys = list(diagnostic_data.keys())
            if len(plot_keys) > 5:
                s = len(plot_keys) // 4
                plot_keys = [plot_keys[0], plot_keys[s], plot_keys[s*2],
                             plot_keys[s*3], plot_keys[-1]]

            for i, stn in enumerate(plot_keys):
                c = colors[i % len(colors)]
                d = diagnostic_data[stn]
                ax1.plot(time_array, d['hs'],     color=c, lw=2.0,  label=stn)
                ax2.plot(time_array, d['tp'],     color=c, lw=1.8,  ls='--')
                ax3.scatter(time_array, d['dir'], color=c, s=15,    alpha=0.8)
                ax4.plot(time_array, d['spread'], color=c, lw=1.8,  alpha=0.9)

            # Panel 1: Hs
            ax1.set_title("Tinggi Gelombang Signifikan ($H_s$)", fontweight='bold', fontsize=11)
            ax1.set_ylabel("Hs (m)", fontsize=10)
            ax1.grid(True, ls=':', alpha=0.5)
            ax1.legend(loc='upper right', ncol=2, fontsize=8)

            # Panel 2: Tp
            ax2.set_title("Periode Puncak ($T_p$)", fontweight='bold', fontsize=11)
            ax2.set_ylabel("Tp (s)", fontsize=10)
            ax2.grid(True, ls=':', alpha=0.5)

            # Panel 3: Dir
            ax3.set_title("Arah Gelombang ($Dir$)", fontweight='bold', fontsize=11)
            ax3.set_ylabel("Dir (°N)", fontsize=10)
            ax3.set_ylim(0, 360)
            ax3.set_yticks([0, 90, 180, 270, 360])
            ax3.grid(True, ls=':', alpha=0.5)

            # Panel 4: Directional Spreading (NEW)
            # Tentukan label sumber spreading
            spread_src_label = (
                f"Manual ({manual_spread_val:.0f}°)" if use_manual_spread
                else STATE.get('spread_method', 'auto')
            )
            export_label = "BCW" if export_as_bcw else "TPAR"
            ax4.set_title(
                f"Directional Spreading (σθ) — Sumber: {spread_src_label}",
                fontweight='bold', fontsize=11
            )
            ax4.set_ylabel("Spread (°)", fontsize=10)
            ax4.set_ylim(0, 65)
            ax4.axhline(y=10, color='gray', ls=':', lw=1, alpha=0.6, label='10° (swell)')
            ax4.axhline(y=30, color='gray', ls='--', lw=1, alpha=0.6, label='30° (wind sea)')
            ax4.fill_between(time_array, 10, 30, alpha=0.05, color='gray')
            ax4.legend(fontsize=8, loc='upper right')
            ax4.grid(True, ls=':', alpha=0.5)

            # X axis
            ax4.xaxis.set_major_formatter(mdates.DateFormatter('%d-%b\n%H:%M'))
            ax4.set_xlabel(f"Waktu ({t_start:%b %Y})", fontsize=10)

            fig.suptitle(
                f"Diagnostik ERA5 Spasial-Temporal — {boundary_name}\n"
                f"{num_points} nodes | "
                f"{t_start:%Y-%m-%d} → {t_end:%Y-%m-%d} | "
                f"Format: {export_label} | Spreading: {spread_src_label}",
                fontweight='bold', fontsize=13, y=0.99
            )
            plt.tight_layout(rect=[0, 0, 1, 0.97])

            fig_path = os.path.join(out_dir, f"{boundary_name}_Diagnostics.png")
            plt.savefig(fig_path, dpi=180, bbox_inches='tight')
            plt.show()

            # ── Final Status ───────────────────────────────────────────
            STATE['phase2_done'] = True
            if not export_as_bcw:
                msg_suc = f'🚀 SELESAI — {num_points} .tpar + .pli → {out_dir}'
                btn_desc = f'✅  Selesai ({num_points} .tpar)'
            else:
                msg_suc = f'🚀 SELESAI — 1 .bcw + .pli → {out_dir}'
                btn_desc = f'✅  Selesai ({boundary_name}.bcw)'

            _set_status(msg_suc, '#16a34a')
            btn_generate.description = btn_desc
            btn_reset.disabled       = False
            btn_load.disabled        = False

            print(f"\n{'=' * 72}")
            print(f"🚀 TAHAP 10 SELESAI")
            if not export_as_bcw:
                print(f"   {num_points} file .tpar + {boundary_name}.pli")
            else:
                print(f"   1 berkas gabungan {boundary_name}.bcw + {boundary_name}.pli")
            print(f"   Spreading: {STATE['spread_method']}")
            print(f"   Diagnostik: {os.path.basename(fig_path)}")
            print(f"   Output: {out_dir}")
            print("=" * 72)

        except Exception as e:
            _set_status(f'❌ Error Fase 2: {e}', '#dc2626')
            print(f"\n❌ ERROR FASE 2:\n{e}")
            traceback.print_exc()
            btn_generate.disabled    = False
            btn_generate.description = '▶  FASE 2: Coba Lagi'
            btn_load.disabled        = False
            btn_reset.disabled       = False


btn_generate.on_click(on_generate_clicked)


# ═══════════════════════════════════════════════════════════════════════════════
# DISPLAY LAYOUT
# ═══════════════════════════════════════════════════════════════════════════════

def _section(title: str) -> widgets.HTML:
    return widgets.HTML(
        f'<div style="margin:10px 0 4px 0;padding:5px 10px;'
        f'background:#1e3a5f;color:white;border-radius:4px;font-size:13px">'
        f'<b>{title}</b></div>'
    )

display(widgets.VBox([
    widgets.HTML(
        '<div style="background:#0f172a;color:#e2e8f0;padding:12px 16px;'
        'border-radius:6px;margin-bottom:8px">'
        '<h3 style="margin:0;font-size:16px">🌊 TAHAP 10 — DYNAMIC WAVE FORCING GENERATOR</h3>'
        '<span style="font-size:11px;color:#94a3b8">'
        'Multi-TPAR/BCW for SWAN | ERA5 NetCDF → .tpar/.bcw + .pli | '
        'Spreading: Auto ERA5 (dwi) / Physics fallback</span>'
        '</div>'
    ),

    _section('📁 1. Konfigurasi Path File'),
    w_macro, w_micro, w_era5, w_outdir,

    _section('⚙️  2. Parameter Pemrosesan'),
    widgets.HBox([w_method, w_bname]),
    widgets.HBox([w_export_mode, w_epsg]),
    widgets.HBox([w_t_start, w_t_end]),

    _section('🌀 3. Directional Spreading (σθ)'),
    widgets.HTML(
        '<div style="background:#f0f9ff;border-left:4px solid #0ea5e9;'
        'padding:8px 12px;font-size:12px;margin-bottom:4px">'
        '<b>Auto:</b> Prioritas → ERA5 <code>dwi</code> (radian→°) → '
        '<code>dspr</code> → physics ε=Hs/L₀ → [10°–30°]<br>'
